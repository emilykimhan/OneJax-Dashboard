@model DashboardViewModel
@using OneJaxDashboard.Models
@{
    var goal = ViewData["Goal"] as StrategicGoal;
    var canManageData = ViewData["CanManageData"] as bool? ?? false;
    var userAuthenticated = ViewData["UserAuthenticated"] as bool? ?? false;
    var selectedStatus = ViewData["SelectedStatus"]?.ToString() ?? string.Empty;
    var activeFiscalYear = ViewData["ActiveFiscalYear"]?.ToString() ?? string.Empty;

    decimal CurrentGoalProgress(IEnumerable<GoalMetric>? metrics)
    {
        return DashboardMetricRules.CalculateGoalProgress(metrics, activeFiscalYear);
    }

    string GetEventHeaderColor(string? status)
    {
        return status switch
        {
            "Completed" => "#10b981",
            "Active" => "#3b82f6",
            "In Progress" => "#f59e0b",
            "Planned" => "#6b7280",
            _ => "#374151"
        };
    }

    string GetEventHeaderColorSecondary(string? status)
    {
        return status switch
        {
            "Completed" => "#059669",
            "Active" => "#2563eb",
            "In Progress" => "#d97706",
            "Planned" => "#4b5563",
            _ => "#1f2937"
        };
    }

    DateTime? EventDisplayDate(Event eventItem)
    {
        return eventItem.DueDate ?? eventItem.StartDate;
    }

    bool IsPastEvent(Event eventItem)
    {
        var eventDate = EventDisplayDate(eventItem);
        return eventDate.HasValue && eventDate.Value.Date < DateTime.Today;
    }

    string GetDashboardEventStatus(Event eventItem)
    {
        if (string.Equals(eventItem.Status, "Completed", StringComparison.OrdinalIgnoreCase) || IsPastEvent(eventItem))
        {
            return "Completed";
        }

        return string.IsNullOrWhiteSpace(eventItem.Status) ? "Planned" : eventItem.Status;
    }
}

@if (goal != null)
{
                            <!-- Public Summary Section - For Non-Authenticated Users -->
                            @if (!userAuthenticated)
                            {
                                <div class="mb-4">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <h5 style="color:var(--onejax-navy); margin-bottom:0;">🌟 Goal Progress Summary</h5>
                                        <small class="text-muted">
                                            <i class="fas fa-chart-bar"></i> Public progress overview
                                        </small>
                                    </div>
                                    <div class="row">
                                        <div class="col-md-6 col-lg-6 mb-3">
                                            <div class="card" style="border-radius: 12px; border: 1px solid var(--onejax-border); transition: all 0.2s ease;">
                                                <div class="card-body text-center" style="padding: 1.5rem;">
                                                    <h6 style="color: var(--onejax-navy); margin-bottom: 1rem; font-weight: 600;">Overall Progress</h6>
                                                    @{
                                                        var currentGoalProgress = CurrentGoalProgress(goal.Metrics);
                                                    }
                                                    <div style="font-size: 2rem; font-weight: 700; color: var(--onejax-navy); margin-bottom: 1rem;">@Math.Round(currentGoalProgress, 1)%</div>
                                                    <div class="progress" style="height: 8px; border-radius: 4px; background: rgba(59, 130, 246, 0.1);">
                                                        <div class="progress-bar" style="width: @Math.Min(currentGoalProgress, 100)%; background: var(--gradient-secondary); border-radius: 4px;"></div>
                                                    </div>
                                                    <small class="text-muted mt-2 d-block">Strategic Initiative Progress</small>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6 col-lg-6 mb-3">
                                            <div class="card" style="border-radius: 12px; border: 1px solid var(--onejax-border); transition: all 0.2s ease;">
                                                <div class="card-body text-center" style="padding: 1.5rem;">
                                                    <h6 style="color: var(--onejax-navy); margin-bottom: 1rem; font-weight: 600;">
                                                        <i class="fas fa-calendar-check"></i> Strategic Events
                                                    </h6>
                                                    <div style="font-size: 2rem; font-weight: 700; color: var(--onejax-navy); margin-bottom: 1rem;">@(goal.Events?.Count() ?? 0)</div>
                                                    @{
                                                        var upcomingCount = goal.Events?.Count(e => GetDashboardEventStatus(e) != "Completed") ?? 0;
                                                        var completedCount = goal.Events?.Count(e => GetDashboardEventStatus(e) == "Completed") ?? 0;
                                                        var nextUpcomingEvent = goal.Events?
                                                            .Where(e => EventDisplayDate(e).HasValue && EventDisplayDate(e) >= DateTime.Today && GetDashboardEventStatus(e) != "Completed")
                                                            .OrderBy(EventDisplayDate)
                                                            .FirstOrDefault();
                                                    }
                                                    @if (goal.Events != null && goal.Events.Any())
                                                    {
                                                        <div style="color: var(--onejax-text-muted); font-size: 0.9rem;">
                                                            @upcomingCount upcoming • @completedCount completed
                                                        </div>
                                                        @if (upcomingCount > 0)
                                                        {
                                                            <div style="margin-top: 0.5rem;">
                                                                <span class="badge" style="background: var(--gradient-secondary); color: white; font-size: 0.75rem;">
                                                                    Next: @(nextUpcomingEvent != null ? EventDisplayDate(nextUpcomingEvent)?.ToString("MMM dd") : "TBD")
                                                                </span>
                                                            </div>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <div style="color: var(--onejax-text-muted); font-size: 0.9rem;">No events scheduled yet</div>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                            
	                            <!-- Events Section - Enhanced Display -->
	                            @if (goal.Events != null && goal.Events.Any())
	                            {
                                <div class="mb-4">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <h5 style="color:var(--onejax-navy); margin-bottom:0; font-weight: 600;">
                                            <i class="fas fa-calendar-check"></i> Strategic Events & Activities
                                        </h5>
                                        <span class="badge" style="background: var(--gradient-secondary); color: white;">
                                            @goal.Events.Count() Total Events
                                        </span>
                                    </div>
                                    
                                    <!-- Event Status Summary -->
                                    @{
                                        var upcomingEvents = goal.Events.Count(e => GetDashboardEventStatus(e) != "Completed");
                                        var completedEvents = goal.Events.Count(e => GetDashboardEventStatus(e) == "Completed");
                                        var activeEvents = goal.Events.Count(e => GetDashboardEventStatus(e) == "Active" || GetDashboardEventStatus(e) == "In Progress");
                                        var carouselId = $"events-carousel-{goal.Id}";
                                    }
                                    
                                    <div class="row mb-3">
                                        <div class="col-md-4">
                                            <div class="text-center p-2" style="background: rgba(59, 130, 246, 0.1); border-radius: 8px;">
                                                <div style="font-size: 1.5rem; font-weight: 700; color: var(--onejax-blue);">@upcomingEvents</div>
                                                <small style="color: var(--onejax-text-muted);">Upcoming</small>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="text-center p-2" style="background: rgba(16, 185, 129, 0.1); border-radius: 8px;">
                                                <div style="font-size: 1.5rem; font-weight: 700; color: var(--onejax-green);">@activeEvents</div>
                                                <small style="color: var(--onejax-text-muted);">Active</small>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="text-center p-2" style="background: rgba(34, 197, 94, 0.1); border-radius: 8px;">
                                                <div style="font-size: 1.5rem; font-weight: 700; color: #22c55e;">@completedEvents</div>
                                                <small style="color: var(--onejax-text-muted);">Completed</small>
                                            </div>
                                        </div>
                                    </div>

                                    <style>
                                        .dashboard-event-strip {
                                            position: relative;
                                        }

                                        .dashboard-event-rail {
                                            display: flex;
                                            gap: 1rem;
                                            overflow-x: auto;
                                            overflow-y: hidden;
                                            scroll-behavior: smooth;
                                            scroll-snap-type: x mandatory;
                                            padding: 0.25rem 0.25rem 0.85rem;
                                            min-height: 230px;
                                        }

                                        .dashboard-event-rail::-webkit-scrollbar {
                                            height: 8px;
                                        }

                                        .dashboard-event-rail::-webkit-scrollbar-track {
                                            background: rgba(15, 61, 87, 0.08);
                                            border-radius: 999px;
                                        }

                                        .dashboard-event-rail::-webkit-scrollbar-thumb {
                                            background: rgba(54, 163, 189, 0.65);
                                            border-radius: 999px;
                                        }

                                        .dashboard-event-slide {
                                            flex: 0 0 min(360px, 82vw);
                                            scroll-snap-align: start;
                                        }

                                        .dashboard-event-slide .event-card {
                                            height: 100%;
                                            min-height: 212px;
                                        }

                                        .dashboard-event-card-body {
                                            min-height: 128px;
                                            display: flex;
                                            flex-direction: column;
                                            justify-content: space-between;
                                        }

                                        .dashboard-event-arrow {
                                            width: 2.35rem;
                                            height: 2.35rem;
                                            border-radius: 999px;
                                            border: 1px solid var(--onejax-border);
                                            background: var(--onejax-white);
                                            color: var(--onejax-navy);
                                            display: inline-flex;
                                            align-items: center;
                                            justify-content: center;
                                            font-size: 1.45rem;
                                            font-weight: 800;
                                            line-height: 1;
                                            box-shadow: 0 6px 16px rgba(15, 61, 87, 0.12);
                                        }

                                        .dashboard-event-arrow:hover {
                                            background: rgba(54, 163, 189, 0.1);
                                        }
                                    </style>

                                    <!-- Event Cards -->
                                    <div class="dashboard-event-strip">
                                        <div class="d-flex justify-content-end gap-2 mb-2">
                                            <button type="button" class="dashboard-event-arrow" aria-label="Previous events" onclick="scrollDashboardEvents('@carouselId', -1)">
                                                &lsaquo;
                                            </button>
                                            <button type="button" class="dashboard-event-arrow" aria-label="Next events" onclick="scrollDashboardEvents('@carouselId', 1)">
                                                &rsaquo;
                                            </button>
                                        </div>
                                        <div class="dashboard-event-rail" id="@carouselId">
                                        @foreach (var eventItem in goal.Events
                                            .Where(e => string.IsNullOrEmpty(selectedStatus) || GetDashboardEventStatus(e) == selectedStatus)
                                            .OrderBy(e => EventDisplayDate(e) ?? DateTime.MaxValue))
                                        {
                                            var displayStatus = GetDashboardEventStatus(eventItem);
                                            var eventDate = EventDisplayDate(eventItem);
                                            <div class="dashboard-event-slide">
                                                <div class="card event-card" 
                                                     style="background-color:var(--onejax-white); border-radius:12px; border: 1px solid var(--onejax-border); transition: all 0.3s ease; cursor: pointer;"
                                                     data-status="@displayStatus"
                                                     data-date="@eventDate?.ToString("yyyy-MM-dd")"
                                                     data-quarter="@((eventDate?.Month - 1) / 3 + 1)"
                                                     data-year="@eventDate?.Year"
                                                     onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 4px 12px rgba(0,0,0,0.15)';"
                                                     onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 2px 8px rgba(0,0,0,0.1)';">
                                                    
                                                    <!-- Event Header -->
                                                    <div class="card-header" style="background: linear-gradient(135deg, @(GetEventHeaderColor(displayStatus)), @(GetEventHeaderColorSecondary(displayStatus))); color: white; border-radius: 12px 12px 0 0; border: none;">
                                                        <div class="d-flex justify-content-between align-items-center">
                                                            <div>
                                                                <h6 style="margin: 0; font-weight: 600;">@eventItem.Title</h6>
                                                                <small style="opacity: 0.9;">@eventItem.Type Event</small>
                                                            </div>
                                                            <span class="badge" style="background: rgba(255,255,255,0.2);">
                                                                @displayStatus
                                                            </span>
                                                        </div>
                                                    </div>
                                                    
                                                    <!-- Event Body -->
                                                    <div class="card-body dashboard-event-card-body" style="padding: 1rem;">
                                                        <div class="event-details">
                                                            <div class="mb-2">
                                                                <i class="fas fa-calendar" style="color: var(--onejax-blue); width: 16px;"></i>
                                                                <strong>Date:</strong> 
                                                                <span style="color: var(--onejax-navy);">
                                                                    @(eventDate?.ToString("MMM dd, yyyy") ?? "TBD")
                                                                </span>
                                                            </div>
                                                            
                                                            <div class="mb-2">
                                                                <i class="fas fa-map-marker-alt" style="color: var(--onejax-orange); width: 16px;"></i>
                                                                <strong>Location:</strong> 
                                                                <span style="color: var(--onejax-navy);">@(eventItem.Location ?? "TBD")</span>
                                                            </div>
                                                            
                                                            @if (eventItem.Attendees > 0)
                                                            {
                                                                <div class="mb-2">
                                                                    <i class="fas fa-users" style="color: var(--onejax-green); width: 16px;"></i>
                                                                    <strong>Expected:</strong> 
                                                                    <span style="color: var(--onejax-navy);">@eventItem.Attendees attendees</span>
                                                                </div>
                                                            }
                                                            
                                                            @if (!string.IsNullOrEmpty(eventItem.Description))
                                                            {
                                                                <div class="mb-3">
                                                                    <small style="color: var(--onejax-text-muted);">
                                                                        @(eventItem.Description.Length > 80 ? eventItem.Description.Substring(0, 80) + "..." : eventItem.Description)
                                                                    </small>
                                                                </div>
                                                            }
                                                            
                                                            @if (!string.IsNullOrEmpty(eventItem.Notes))
                                                            {
                                                                <div class="mb-3">
                                                                    <small style="color: var(--onejax-text-muted); font-style: italic;">
                                                                        📝 @(eventItem.Notes.Length > 60 ? eventItem.Notes.Substring(0, 60) + "..." : eventItem.Notes)
                                                                    </small>
                                                                </div>
                                                            }
                                                        </div>
                                                        
                                                        <!-- Action Buttons -->
                                                        <div class="d-flex justify-content-between align-items-center">
                                                            @if (canManageData)
                                                            {
                                                                <a href="/Strategy/ViewEvents?goalId=@goal.Id" class="btn btn-sm btn-outline-primary" style="border-radius: 8px;">
                                                                    <i class="fas fa-cog"></i> Manage
                                                                </a>
                                                            }
                                                            else
                                                            {
                                                                <a href="/Public/Events?goalId=@goal.Id" class="btn btn-sm btn-outline-primary" style="border-radius: 8px;">
                                                                    <i class="fas fa-eye"></i> View
                                                                </a>
                                                            }
                                                            
                                                            @if (eventDate.HasValue)
                                                            {
                                                                var daysUntil = (eventDate.Value.Date - DateTime.Today).Days;
                                                                @if (displayStatus == "Completed")
                                                                {
                                                                    <small style="color: var(--onejax-green); font-weight: 600;">
                                                                        <i class="fas fa-check-circle"></i> Completed
                                                                    </small>
                                                                }
                                                                else if (daysUntil >= 0)
                                                                {
                                                                    <small style="color: var(--onejax-blue); font-weight: 600;">
                                                                        @if (daysUntil == 0)
                                                                        {
                                                                            <span>📅 Today!</span>
                                                                        }
                                                                        else if (daysUntil == 1)
                                                                        {
                                                                            <span>📅 Tomorrow</span>
                                                                        }
                                                                        else if (daysUntil <= 7)
                                                                        {
                                                                            <span style="color: var(--onejax-orange);">📅 In @daysUntil days</span>
                                                                        }
                                                                        else
                                                                        {
                                                                            <span>📅 In @daysUntil days</span>
                                                                        }
                                                                    </small>
                                                                }
                                                            }
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                        </div>
                                    </div>
                                    
	                                    <!-- Quick Action Buttons -->
	                                    <div class="text-center mt-3">
	                                        @if (canManageData)
	                                        {
	                                            <a href="/Strategy/Index?goalId=@goal.Id" class="btn btn-outline-primary btn-sm me-2">
	                                                <i class="fas fa-plus"></i> Add New Event
	                                            </a>
	                                        }
	                                        @if (canManageData)
	                                        {
	                                            <form style="display: inline;" method="get" action="/Strategy/ViewEvents">
	                                                <input type="hidden" name="goalId" value="@goal.Id" />
	                                                <button type="submit" class="btn btn-outline-secondary btn-sm">
	                                                    <i class="fas fa-calendar"></i> View All Events
	                                                </button>
	                                            </form>
	                                        }
	                                        else
	                                        {
	                                            <a href="/Public/Events?goalId=@goal.Id" class="btn btn-outline-secondary btn-sm">
	                                                <i class="fas fa-eye"></i> View Public Events
	                                            </a>
	                                        }
                                    </div>
                                </div>
                                <script>
                                    window.scrollDashboardEvents = window.scrollDashboardEvents || function (id, direction) {
                                        var rail = document.getElementById(id);
                                        if (!rail) return;
                                        var amount = Math.max(rail.clientWidth * 0.85, 320);
                                        rail.scrollBy({ left: amount * direction, behavior: 'smooth' });
                                    };
                                </script>
                            }
                            else
                            {
                                <!-- No Events State -->
                                <div class="mb-4">
                                    <div class="text-center py-4" style="background: rgba(59, 130, 246, 0.05); border-radius: 12px; border: 2px dashed var(--onejax-border);">
                                        <i class="fas fa-calendar-plus" style="font-size: 3rem; color: var(--onejax-blue); margin-bottom: 1rem;"></i>
                                        <h6 style="color: var(--onejax-navy); margin-bottom: 0.5rem;">No Events Yet for @goal.Name</h6>
	                                        <p style="color: var(--onejax-text-muted); margin-bottom: 1rem;">Start planning your strategic initiatives and events.</p>
	                                        @if (canManageData)
	                                        {
	                                            <a href="/Strategy/Index?goalId=@goal.Id" class="btn btn-primary btn-sm">
	                                                <i class="fas fa-plus"></i> Create First Event
	                                            </a>
	                                        }
	                                        else
	                                        {
	                                            <a href="/Public/Events?goalId=@goal.Id" class="btn btn-outline-primary btn-sm">
	                                                <i class="fas fa-eye"></i> View Public Events
	                                            </a>
	                                        }
                                    </div>
                                </div>
                            }
                            
                            @if ((goal.Events == null || !goal.Events.Any()) && (goal.Metrics == null || !goal.Metrics.Any()))
	                            {
	                                <p style="color:var(--onejax-text-muted);">No data in this category yet.</p>
	                                <p style="color:var(--onejax-text-muted); font-size:0.9em;">Data will be managed through the Core Strategies tab above.</p>
	                            }
}
