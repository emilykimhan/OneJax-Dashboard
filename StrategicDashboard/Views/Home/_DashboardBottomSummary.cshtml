@model DashboardViewModel
@using OneJaxDashboard.Models
@{
    var activeFiscalYear = ViewData["ActiveFiscalYear"]?.ToString() ?? string.Empty;
    bool IsScheduledMetric(GoalMetric metric)
    {
        return MetricTrackingSchedule.IsScheduledForFiscalYear(metric.Name, activeFiscalYear);
    }

    bool IsReportingMetric(GoalMetric metric)
    {
        var clean = (metric.Target ?? string.Empty).Replace("$", "").Replace(",", "").Replace("%", "").Trim();
        return IsScheduledMetric(metric)
            && !string.Equals(metric.Status, "Planning", StringComparison.OrdinalIgnoreCase)
            && decimal.TryParse(clean, out var target)
            && target > 0;
    }

    decimal LiveGoalProgress(IEnumerable<GoalMetric>? metrics)
    {
        var liveMetrics = (metrics ?? Enumerable.Empty<GoalMetric>())
            .Where(IsReportingMetric)
            .Select(m => Math.Min(m.ProgressPercentage, 100))
            .ToList();

        return liveMetrics.Any() ? Math.Round(liveMetrics.Average(), 1) : 0;
    }

    var allMetrics = Model.StrategicGoals?.SelectMany(g => g.Metrics ?? new List<GoalMetric>()).ToList() ?? new List<GoalMetric>();
    var scheduledMetrics = allMetrics.Where(IsScheduledMetric).ToList();
    var reportingMetrics = scheduledMetrics.Where(IsReportingMetric).ToList();
    var inScopeMetricsLabel = string.IsNullOrWhiteSpace(activeFiscalYear) || string.Equals(activeFiscalYear, "All Years", StringComparison.OrdinalIgnoreCase)
        ? "Across the full strategic plan"
        : $"Counted toward {activeFiscalYear}";
    var activeMetricsCount = scheduledMetrics.Count(m => string.Equals(m.Status, "Active", StringComparison.OrdinalIgnoreCase));
    var metricsAtTargetCount = reportingMetrics.Count(m => m.ProgressPercentage >= 100);
    var reportingMetricsPercentage = scheduledMetrics.Count > 0 ? (reportingMetrics.Count * 100.0 / scheduledMetrics.Count) : 0;
    var activeMetricsPercentage = scheduledMetrics.Count > 0 ? (activeMetricsCount * 100.0 / scheduledMetrics.Count) : 0;
    var metricsAtTargetPercentage = reportingMetrics.Count > 0 ? (metricsAtTargetCount * 100.0 / reportingMetrics.Count) : 0;
    var goalProgresses = (Model.StrategicGoals ?? new List<StrategicGoal>())
        .Where(g => (g.Metrics ?? new List<GoalMetric>()).Any(IsReportingMetric))
        .Select(g => LiveGoalProgress(g.Metrics))
        .ToList();
    var overallGoalProgress = goalProgresses.Any()
        ? goalProgresses.Average()
        : 0;
}

<style>
    .dashboard-summary-card {
        height: 100%;
        display: flex;
        align-items: stretch;
    }

    .dashboard-summary-card > div {
        width: 100%;
    }

    .dashboard-summary-card .stat-card-modern {
        height: 100%;
    }

    .dashboard-summary-card-content {
        color: white;
        min-height: 164px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .dashboard-summary-card-copy {
        min-height: 2.8rem;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
    }
</style>

<div class="row mt-6 fade-in">
    <div class="col-12 mb-4 text-center">
        <h2 style="color: var(--onejax-navy); font-weight: 700; margin-bottom: 1rem;">
            Metrics Summary & Strategic Overview
        </h2>
        <p style="color: var(--onejax-text-muted); font-size: 1.1rem;">Live tracking of dashboard metrics across the strategic plan</p>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-3 slide-in-left dashboard-summary-card">
        <div class="stat-card-modern" style="background: var(--gradient-primary);">
            <div class="dashboard-summary-card-content">
                <div style="font-size: 0.9rem; margin-bottom: 1.5rem; opacity: 0.9;">IN-SCOPE METRICS</div>
                <h2 style="color: white; margin-bottom: 1rem; font-weight: 700;">@scheduledMetrics.Count</h2>
                <small class="dashboard-summary-card-copy" style="opacity: 0.8;">@inScopeMetricsLabel</small>
                <div class="progress-modern mt-3" style="background: rgba(255,255,255,0.2);">
                    <div class="progress-bar" style="width: @reportingMetricsPercentage%; background: rgba(255,255,255,0.8);"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3 slide-in-left dashboard-summary-card" style="animation-delay: 0.1s;">
        <div class="stat-card-modern" style="background: var(--gradient-secondary);">
            <div class="dashboard-summary-card-content">
                <div style="font-size: 0.9rem; margin-bottom: 1.5rem; opacity: 0.9;">ACTIVE METRICS</div>
                <h2 style="color: white; margin-bottom: 1rem; font-weight: 700;">@activeMetricsCount</h2>
                <small class="dashboard-summary-card-copy" style="opacity: 0.8;">Scheduled metrics with live data</small>
                <div class="progress-modern mt-3" style="background: rgba(255,255,255,0.2);">
                    <div class="progress-bar" style="width: @activeMetricsPercentage%; background: rgba(255,255,255,0.8);"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3 slide-in-right dashboard-summary-card" style="animation-delay: 0.2s;">
        <div class="stat-card-modern" style="background: linear-gradient(135deg, var(--onejax-green), #059669);">
            <div class="dashboard-summary-card-content">
                <div style="font-size: 0.9rem; margin-bottom: 1.5rem; opacity: 0.9;">METRICS AT TARGET</div>
                <h2 style="color: white; margin-bottom: 1rem; font-weight: 700;">@metricsAtTargetCount</h2>
                <small class="dashboard-summary-card-copy" style="opacity: 0.8;">Reporting metrics meeting target</small>
                <div class="progress-modern mt-3" style="background: rgba(255,255,255,0.2);">
                    <div class="progress-bar" style="width: @metricsAtTargetPercentage%; background: rgba(255,255,255,0.8);"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3 slide-in-right dashboard-summary-card" style="animation-delay: 0.3s;">
        <div class="stat-card-modern" style="background: var(--gradient-accent);">
            <div class="dashboard-summary-card-content">
                <div style="font-size: 0.9rem; margin-bottom: 1.5rem; opacity: 0.9;">OVERALL PROGRESS</div>
                <h2 style="color: white; margin-bottom: 1rem; font-weight: 700;">@Math.Round(overallGoalProgress, 1)%</h2>
                <small class="dashboard-summary-card-copy" style="opacity: 0.8;">Average progress across reporting goals</small>
                <div class="progress-modern mt-3" style="background: rgba(255,255,255,0.2);">
                    <div class="progress-bar" style="width: @Math.Min(overallGoalProgress, 100)%; background: rgba(255,255,255,0.8);"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mt-6 fade-in">
    <div class="col-12">
        <div class="floating-card" style="background: var(--gradient-primary); color: white;">
            <div class="card-body text-center" style="padding: 3rem;">
                <div class="row align-items-center">
                    <div class="col-md-8">
                        <h5 style="color: white; margin-bottom: 1rem; font-weight: 600;">
                            Questions or feedback about this dashboard?
                        </h5>
                        <p style="color: rgba(255,255,255,0.9); margin-bottom: 0; font-size: 1.1rem;">
                            Email us at <a href="mailto:onejax@onejax.org" style="color: var(--onejax-orange); text-decoration: none; font-weight: 600;">onejax@onejax.org</a>
                        </p>
                    </div>
                    <div class="col-md-4 text-end">
                        <div style="background: rgba(255,255,255,0.1); border-radius: 15px; padding: 1.5rem; backdrop-filter: blur(10px);">
                            <div style="font-size: 0.9rem; opacity: 0.8; margin-bottom: 0.5rem;">LAST UPDATED</div>
                            <div style="font-weight: 600; font-size: 1.1rem;">@DateTime.Now.ToString("MMM dd, yyyy")</div>
                        </div>
                    </div>
                </div>

                <div class="row mt-4">
                    <div class="col-12">
                        <div style="height: 1px; background: rgba(255,255,255,0.2); margin: 1rem 0;"></div>
                        <p style="color: rgba(255,255,255,0.7); margin-bottom: 0; font-size: 0.9rem;">
                            OneJax Strategic Dashboard | Fiscal Year @activeFiscalYear |
                            Secure & Confidential |
                            Real-time Data Analytics
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
