                                                                        </div>
                                                                        <small style="color: var(--onejax-text-muted);">2026 Target</small>
                                                                    </div>
                                                                </div>
                                                                <div class="col-md-3">
                                                                    <div class="text-center">
                                                                        <div style="font-size: 1.5rem; font-weight: 600; color: #94a3b8; line-height: 1;">
                                                                            @successRate%
                                                                        </div>
                                                                        <small style="color: var(--onejax-text-muted);">Success Rate</small>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                            
                                                            <!-- Quarterly Column Chart -->
                                                            <div class="mb-4">
                                                                <div class="d-flex justify-content-between align-items-center mb-3">
                                                                    <h6 style="color: var(--onejax-navy); margin: 0; font-weight: 600;">Quarterly Progress Breakdown</h6>
                                                                    <small style="color: var(--onejax-text-muted);">
                                                                        <i class="fas fa-chart-column"></i> Prospecting vs Recruitment by Quarter
                                                                    </small>
                                                                </div>
                                                                
                                                                <div style="height: 280px; position: relative;">
                                                                    <canvas id="board-recruitment-chart-@(metric.Id)" style="width: 100%; height: 100%;"></canvas>
                                                                </div>
                                                                
                                                                <!-- Legend -->
                                                                <div class="d-flex justify-content-center mt-2" style="gap: 2rem;">
                                                                    <div class="d-flex align-items-center">
                                                                        <div style="width: 15px; height: 15px; background: rgba(148, 163, 184, 0.8); border: 1px solid #94a3b8; border-radius: 3px; margin-right: 8px;"></div>
                                                                        <small style="color: var(--onejax-text-muted); font-weight: 500; font-size: 0.8rem;">Prospected Candidates</small>
                                                                    </div>
                                                                    <div class="d-flex align-items-center">
                                                                        <div style="width: 15px; height: 15px; background: #475569; border: 1px solid #334155; border-radius: 3px; margin-right: 8px;"></div>
                                                                        <small style="color: var(--onejax-text-muted); font-weight: 500; font-size: 0.8rem;">Actually Recruited</small>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                            
                                                            <!-- Goal progress -->
                                                            <div class="mt-2 pt-2" style="border-top: 1px solid #e2e8f0;">
                                                                <div class="d-flex justify-content-between align-items-center">
                                                                    <div>
                                                                        <small style="color: var(--onejax-text-muted);">Goal: Recruit @targetRecruitment new board members by Q2 2026</small>
                                                                    </div>
                                                                    <div>
                                                                        <span class="badge @(metricIsScheduled && hasRecruitmentData && totalRecruitedForYear >= targetRecruitment ? "bg-success" : "")" style="@(!metricIsScheduled ? "background: #dbeafe; color: #1e3a8a;" : hasRecruitmentData && totalRecruitedForYear >= targetRecruitment ? "" : hasRecruitmentData ? "background: #64748b; color: white;" : "background: #94a3b8; color: white;")">
                                                                            @ScheduleBadgeText(metricIsScheduled, metricStartFiscalYear, hasRecruitmentData && totalRecruitedForYear >= targetRecruitment ? "Target Achieved" : hasRecruitmentData ? "In Progress" : "Ready to Track")
                                                                        </span>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                            }
                                                        </div>
                                                    </div>
                                                </div>
                                                
                                                <script>
                                                    // Initialize the board recruitment chart
                                                    document.addEventListener('DOMContentLoaded', function() {
                                                        const recruitmentCtx = document.getElementById('board-recruitment-chart-@(metric.Id)');
                                                        if (recruitmentCtx) {
                                                            const hasData = @hasRecruitmentData.ToString().ToLower();
                                                            const quarterLabels = ['@quarterLabels[0]', '@quarterLabels[1]', '@quarterLabels[2]', '@quarterLabels[3]'];
                                                            const quarterlyData = {
                                                                prospected: [@string.Join(", ", quarterlyProspected)],
                                                                recruited: [@string.Join(", ", quarterlyRecruited)]
                                                            };
                                                            
                                                            new Chart(recruitmentCtx, {
                                                                type: 'bar',
                                                                data: {
                                                                    labels: quarterLabels,
                                                                    datasets: [{
                                                                        label: 'Prospected Candidates',
                                                                        data: quarterlyData.prospected,
                                                                        backgroundColor: 'rgba(148, 163, 184, 0.8)',
                                                                        borderColor: '#94a3b8',
                                                                        borderWidth: 1,
                                                                        borderRadius: 4,
                                                                        borderSkipped: false,
                                                                        categoryPercentage: 0.8,
                                                                        barPercentage: 0.7
                                                                    }, {
                                                                        label: 'Actually Recruited',
                                                                        data: quarterlyData.recruited,
                                                                        backgroundColor: '#475569',
                                                                        borderColor: '#334155',
                                                                        borderWidth: 1,
                                                                        borderRadius: 4,
                                                                        borderSkipped: false,
                                                                        categoryPercentage: 0.8,
                                                                        barPercentage: 0.7
                                                                    }]
                                                                },
                                                                options: {
                                                                    responsive: true,
                                                                    maintainAspectRatio: false,
                                                                    plugins: {
                                                                        legend: {
                                                                            display: false
                                                                        },
                                                                        tooltip: {
                                                                            backgroundColor: 'rgba(71, 85, 105, 0.95)',
                                                                            titleColor: 'white',
                                                                            bodyColor: 'white',
                                                                            borderColor: '#475569',
                                                                            borderWidth: 1,
                                                                            cornerRadius: 8,
                                                                            displayColors: true,
                                                                            callbacks: {
                                                                                title: function(context) {
                                                                                    return context[0].label;
                                                                                },
                                                                                label: function(context) {
                                                                                    const datasetLabel = context.dataset.label;
                                                                                    const value = context.parsed.y;
                                                                                    return datasetLabel + ': ' + value + (value === 1 ? ' person' : ' people');
                                                                                }
                                                                            }
                                                                        }
                                                                    },
                                                                    scales: {
                                                                        y: {
                                                                            beginAtZero: true,
                                                                            max: Math.max(6, ...quarterlyData.prospected, ...quarterlyData.recruited) + 1,
                                                                            ticks: {
                                                                                stepSize: 1,
                                                                                color: '#64748b',
                                                                                font: {
                                                                                    size: 12,
                                                                                    family: 'Inter, sans-serif'
                                                                                }
                                                                            },
                                                                            grid: {
                                                                                color: 'rgba(148, 163, 184, 0.2)',
                                                                                lineWidth: 1
                                                                            },
                                                                            title: {
                                                                                display: true,
                                                                                text: 'Number of People',
                                                                                color: '#64748b',
                                                                                font: {
                                                                                    size: 12,
                                                                                    weight: 500
                                                                                }
                                                                            }
                                                                        },
                                                                        x: {
                                                                            ticks: {
                                                                                color: '#64748b',
                                                                                font: {
                                                                                    size: 12,
                                                                                    family: 'Inter, sans-serif',
                                                                                    weight: 500
                                                                                }
                                                                            },
                                                                            grid: {
                                                                                display: false
                                                                            },
                                                                            title: {
                                                                                display: true,
                                                                                text: 'Fiscal Year Quarters',
                                                                                color: '#64748b',
                                                                                font: {
                                                                                    size: 12,
                                                                                    weight: 500
                                                                                }
                                                                            }
                                                                        }
                                                                    },
                                                                    layout: {
                                                                        padding: {
                                                                            top: 10,
                                                                            bottom: 10,
                                                                            left: 10,
                                                                            right: 10
                                                                        }
                                                                    }
                                                                }
                                                            });
                                                        }
                                                    });
                                                </script>
		                                            }
                                            else if (metricName.Contains("Media Placements", StringComparison.OrdinalIgnoreCase) || 
                                                     metricName.Contains("Key Plan Milestones", StringComparison.OrdinalIgnoreCase) || 
                                                     metricName.Contains("Content calendar", StringComparison.OrdinalIgnoreCase) ||
                                                     metricName.Contains("brand messaging", StringComparison.OrdinalIgnoreCase) ||
                                                     metricName.Contains("Budget Variance", StringComparison.OrdinalIgnoreCase) ||
                                                     (metric.Description ?? string.Empty).Contains("Variance from annual budget", StringComparison.OrdinalIgnoreCase))
                                            {
                                                // Skip these unwanted metrics - they don't have proper forms
                                            }
                                            else
                                            {
                                                <div class="col-md-6 mb-3">
                                                    <div class="card" style="background:var(--onejax-white); border-radius:12px; border-left: 5px solid var(--onejax-orange);">
                                                        <div class="card-body">
                                                            <h6 class="card-title" style="color:var(--onejax-navy);">@metric.Name</h6>
                                                            <p class="card-text" style="color:var(--onejax-navy); font-size:0.9em;">@metric.Description</p>
                                                            
                                                            <div class="d-flex justify-content-between align-items-center mb-2">
                                                                <span style="color:var(--onejax-navy);"><strong>Progress:</strong></span>
                                                                <span class="badge bg-primary">@metric.CurrentValue @metric.Unit / @metric.Target @metric.Unit</span>
                                                            </div>
                                                            
                                                            <div class="progress mb-2" style="height: 12px; border-radius:6px;">
                                                                <div class="progress-bar" role="progressbar" 
                                                                     style="width: @(metric.ProgressPercentage > 0 ? Math.Max(metric.ProgressPercentage, 2) : 0)%; background-color: var(--onejax-blue);"
                                                                     aria-valuenow="@metric.ProgressPercentage" aria-valuemin="0" aria-valuemax="100"></div>
                                                            </div>
                                                            <small style="color:var(--onejax-navy);">
                                                                <strong>Target:</strong> @metric.TargetDate.ToString("MMM yyyy") | 
                                                                <span class="badge @(metric.Status == "Active" ? "bg-success" : "bg-secondary")">@metric.Status</span>
                                                            </small>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
    }
}
