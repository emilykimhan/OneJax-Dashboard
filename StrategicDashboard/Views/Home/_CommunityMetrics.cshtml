@model DashboardViewModel
@using OneJaxDashboard.Models
@{
    var goal = ViewData["Goal"] as StrategicGoal;
    var canManageData = ViewData["CanManageData"] as bool? ?? false;
    var activeFiscalYearLabel = ViewBag.ActiveFiscalYearLabel as string ?? string.Empty;
    var goalMetrics = goal?.Metrics ?? new List<GoalMetric>();
    var scheduledGoalMetrics = goalMetrics
        .Where(m => MetricTrackingSchedule.IsScheduledForFiscalYear(m.Name, activeFiscalYearLabel))
        .ToList();
}

	                                        @if (goal?.Name.Contains("Community", StringComparison.OrdinalIgnoreCase) == true)
	                                        {
	                                            bool IsScheduledMetric(string metricName) => MetricTrackingSchedule.IsScheduledForFiscalYear(metricName, activeFiscalYearLabel);
	                                            var interfaithScheduled = IsScheduledMetric("Interfaith Events Hosted");
	                                            var youthScheduled = IsScheduledMetric("Youth Attendance Growth");
	                                            var partnersScheduled = IsScheduledMetric("Cross-Sector Collaborations");
	                                            var faithScheduled = IsScheduledMetric("Faith Representation");
	                                            var satisfactionScheduled = IsScheduledMetric("Event Satisfaction");
	                                            var clergyScheduled = IsScheduledMetric("Clergy Network Growth");
	                                            var diversityScheduled = IsScheduledMetric("Participant Diversity");
	                                            var firstTimeScheduled = IsScheduledMetric("First-Time Participants");
	                                            var mInterfaith = scheduledGoalMetrics.FirstOrDefault(m => (m.Name ?? "").Contains("Interfaith", StringComparison.OrdinalIgnoreCase) && (m.Name ?? "").Contains("Events", StringComparison.OrdinalIgnoreCase));
	                                            var mYouth = scheduledGoalMetrics.FirstOrDefault(m => (m.Name ?? "").Contains("Youth", StringComparison.OrdinalIgnoreCase) && (m.Name ?? "").Contains("Attendance", StringComparison.OrdinalIgnoreCase));
	                                            var mSatisfaction = scheduledGoalMetrics.FirstOrDefault(m => (m.Name ?? "").Contains("Satisfaction", StringComparison.OrdinalIgnoreCase) && (m.Name ?? "").Contains("Event", StringComparison.OrdinalIgnoreCase))
	                                                ?? scheduledGoalMetrics.FirstOrDefault(m => (m.Name ?? "").Contains("Satisfaction", StringComparison.OrdinalIgnoreCase));
	                                            var mPartners = scheduledGoalMetrics.FirstOrDefault(m => (m.Name ?? "").Contains("Partner", StringComparison.OrdinalIgnoreCase) && (m.Name ?? "").Contains("Touchpoints", StringComparison.OrdinalIgnoreCase))
	                                                ?? scheduledGoalMetrics.FirstOrDefault(m => (m.Name ?? "").Contains("Collaboration", StringComparison.OrdinalIgnoreCase));
	                                            var mFaith = scheduledGoalMetrics.FirstOrDefault(m => (m.Name ?? "").Contains("Faith", StringComparison.OrdinalIgnoreCase) && (m.Name ?? "").Contains("Representation", StringComparison.OrdinalIgnoreCase));
	                                            var mClergy = scheduledGoalMetrics.FirstOrDefault(m => (m.Name ?? "").Contains("Clergy", StringComparison.OrdinalIgnoreCase) && (m.Name ?? "").Contains("Network", StringComparison.OrdinalIgnoreCase));
	                                            var mDiversity = goalMetrics.FirstOrDefault(m => (m.Name ?? "").Contains("Diversity", StringComparison.OrdinalIgnoreCase) && (m.Name ?? "").Contains("Participant", StringComparison.OrdinalIgnoreCase));
	                                            var mFirstTime = goalMetrics.FirstOrDefault(m => (m.Name ?? "").Contains("First-Time", StringComparison.OrdinalIgnoreCase) && (m.Name ?? "").Contains("Participants", StringComparison.OrdinalIgnoreCase));

	                                            decimal parseTarget(string? raw)
	                                            {
	                                                if (string.IsNullOrWhiteSpace(raw)) return 0;
	                                                var clean = raw.Replace("$", "", StringComparison.OrdinalIgnoreCase)
	                                                    .Replace(",", "", StringComparison.OrdinalIgnoreCase)
	                                                    .Replace("%", "", StringComparison.OrdinalIgnoreCase)
	                                                    .Trim();
	                                                return decimal.TryParse(clean, out var v) ? v : 0;
	                                            }

	                                            decimal? targetOrNull(GoalMetric? metric)
	                                            {
	                                                var parsed = parseTarget(metric?.Target);
	                                                return parsed > 0 ? parsed : null;
	                                            }

                                            string metricStatus(bool isScheduled, bool hasValue, decimal current, decimal? target, string? fallbackStatus)
                                            {
                                                if (!isScheduled) return "Starts later";
                                                if (!hasValue) return "No entries yet";
                                                if (target.HasValue && target.Value > 0 && current >= target.Value) return "Target met";
                                                return string.IsNullOrWhiteSpace(fallbackStatus) ? "Tracking" : fallbackStatus!;
                                            }

	                                            decimal? bagNullable(string key)
	                                            {
	                                                var raw = ViewData[key];
	                                                if (raw == null) return null;
	                                                if (raw is decimal dec) return dec;
	                                                if (raw is double dbl) return Convert.ToDecimal(dbl);
	                                                if (raw is float flt) return Convert.ToDecimal(flt);
	                                                if (raw is int i) return i;
	                                                if (raw is long l) return l;
	                                                if (raw is short s) return s;
	                                                if (raw is string text && decimal.TryParse(text, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var parsed)) return parsed;
	                                                return null;
	                                            }

	                                            decimal bagNumber(string key)
	                                            {
	                                                return bagNullable(key) ?? 0;
	                                            }

	                                            decimal progressValue(decimal current, decimal? target)
	                                            {
	                                                if (!target.HasValue || target.Value <= 0) return 0;
	                                                return Math.Round(current / target.Value * 100, 1);
	                                            }

                                            string valueLabel(decimal? value, string format = "0.#", string suffix = "", bool signed = false)
                                            {
                                                if (!value.HasValue) return "No data";
	                                                var rendered = value.Value.ToString(format, System.Globalization.CultureInfo.InvariantCulture);
	                                                if (signed && value.Value > 0) rendered = $"+{rendered}";
	                                                return $"{rendered}{suffix}";
	                                            }

	                                            string targetLabel(decimal? target, string format = "0.#", string prefix = "", string suffix = "")
	                                            {
	                                                if (!target.HasValue) return "No target set";
                                                return $"{prefix}{target.Value.ToString(format, System.Globalization.CultureInfo.InvariantCulture)}{suffix}";
                                            }

                                            string scheduledValueLabel(bool isScheduled, decimal? value, string format = "0.#", string suffix = "", bool signed = false)
                                            {
                                                return isScheduled ? valueLabel(value, format, suffix, signed) : "--";
                                            }

                                            string earliestStartFiscalYear(params string[] metricNames)
                                            {
                                                return metricNames
                                                    .Select(MetricTrackingSchedule.GetStartFiscalYear)
                                                    .Where(label => !string.IsNullOrWhiteSpace(label))
                                                    .OrderBy(label => label)
                                                    .FirstOrDefault() ?? string.Empty;
                                            }

                                            string panelBadgeText(bool anyScheduled, bool allScheduled, params string[] metricNames)
                                            {
                                                if (allScheduled) return "In scope";
                                                if (anyScheduled) return "Some start later";
                                                var start = earliestStartFiscalYear(metricNames);
                                                return string.IsNullOrWhiteSpace(start) ? "Starts later" : $"Starts FY {start}";
                                            }

                                            string panelNoteText(bool anyScheduled, bool allScheduled, params string[] metricNames)
                                            {
                                                if (allScheduled) return string.Empty;
                                                if (anyScheduled) return $"Some metrics in this section do not count toward {activeFiscalYearLabel} yet.";
                                                var start = earliestStartFiscalYear(metricNames);
                                                return string.IsNullOrWhiteSpace(start)
                                                    ? $"This section does not count toward {activeFiscalYearLabel} yet."
                                                    : $"This section starts in FY {start} and does not count toward {activeFiscalYearLabel} yet.";
                                            }

                                            string earlyMetricStatus(bool isScheduled, bool hasEntry, bool hasValue, decimal current, decimal? target, string? fallbackStatus, string metricName)
                                            {
                                                if (isScheduled) return metricStatus(true, hasValue, current, target, fallbackStatus);
                                                if (!hasEntry) return "Starts later";

                                                var start = MetricTrackingSchedule.GetStartFiscalYear(metricName);
                                                return string.IsNullOrWhiteSpace(start)
                                                    ? "Logged early"
                                                    : $"Logged early; starts FY {start}";
                                            }

                                            string metricStartText(string metricName)
                                            {
                                                var start = MetricTrackingSchedule.GetStartFiscalYear(metricName);
                                                return string.IsNullOrWhiteSpace(start) ? "Starts later" : $"Starts FY {start}";
                                            }

                                            double progressWidth(decimal progress)
                                            {
                                                return Math.Clamp((double)progress, 0, 100);
                                            }

                                            /*string startsLaterText(string metricName)
                                            {
                                                var start = MetricTrackingSchedule.GetStartFiscalYear(metricName);
                                                return string.IsNullOrWhiteSpace(start) ? "Starts later" : $"Starts in FY {start}";
                                            }

                                            string countLabel(decimal count, string singular, string plural)
                                            {
                                                return $"{count:0} {(count == 1 ? singular : plural)}";
                                            }*/

	                                            var youthTarget = targetOrNull(mYouth);
	                                            var partnersTarget = targetOrNull(mPartners);
	                                            var interfaithTarget = targetOrNull(mInterfaith);
	                                            var faithTarget = targetOrNull(mFaith);
	                                            var clergyTarget = targetOrNull(mClergy);
	                                            var diversityTarget = targetOrNull(mDiversity);
	                                            var firstTimeTarget = targetOrNull(mFirstTime);
	                                            var satisfactionTarget = targetOrNull(mSatisfaction);
                                                var diversityEntryCountRaw = bagNumber("CommunityDiversityEntryCount");
                                                var firstTimeEntryCountRaw = bagNumber("CommunityFirstTimeEntryCount");
                                                var diversityHasEarlyData = diversityEntryCountRaw > 0;
                                                var firstTimeHasEarlyData = firstTimeEntryCountRaw > 0;
                                                var diversityVisible = diversityScheduled || diversityHasEarlyData;
                                                var firstTimeVisible = firstTimeScheduled || firstTimeHasEarlyData;
	                                            var youthValueRaw = youthScheduled ? bagNullable("CommunityYouthGrowthPercent") : null;
	                                            var satisfactionValueRaw = satisfactionScheduled ? bagNullable("CommunityEventSatisfactionAvg") : null;
	                                            var firstTimeValueRaw = firstTimeVisible ? bagNullable("CommunityFirstTimeRateAvg") : null;
	                                            var faithValueRaw = faithScheduled ? bagNullable("CommunityFaithPercentMeetingGoal") : null;
	                                            var interfaithValueRaw = interfaithScheduled ? bagNullable("CommunityInterfaithEventsCount") : null;
	                                            var partnersValueRaw = partnersScheduled ? bagNullable("CommunityPartnersCurrentCount") : null;
	                                            var clergyValueRaw = clergyScheduled ? bagNullable("CommunityClergyGrowthPercent") : null;
	                                            var diversityValueRaw = diversityVisible ? bagNullable("CommunityDiversityGrowthPercent") : null;
	                                            var youthValue = youthValueRaw ?? 0;
	                                            var satisfactionValue = satisfactionValueRaw ?? 0;
	                                            var firstTimeValue = firstTimeValueRaw ?? 0;
	                                            var faithValue = faithValueRaw ?? 0;
	                                            var interfaithValue = interfaithValueRaw ?? 0;
	                                            var partnersValue = partnersValueRaw ?? 0;
	                                            var clergyValue = clergyValueRaw ?? 0;
	                                            var diversityValue = diversityValueRaw ?? 0;
	                                            var youthEntryCount = youthScheduled ? bagNumber("CommunityYouthEntryCount") : 0;
	                                            var faithEntryCount = faithScheduled ? bagNumber("CommunityFaithEntryCount") : 0;
	                                            var satisfactionEntryCount = satisfactionScheduled ? bagNumber("CommunitySatisfactionEntryCount") : 0;
	                                            var contactEntryCount = clergyScheduled ? bagNumber("CommunityContactEntryCount") : 0;
	                                            var diversityEntryCount = diversityVisible ? diversityEntryCountRaw : 0;
	                                            var firstTimeEntryCount = firstTimeVisible ? firstTimeEntryCountRaw : 0;
	                                            var youthHasValue = youthValueRaw.HasValue;
	                                            var satisfactionHasValue = satisfactionValueRaw.HasValue;
	                                            var firstTimeHasValue = firstTimeValueRaw.HasValue;
	                                            var faithHasValue = faithValueRaw.HasValue;
	                                            var interfaithEntryCount = interfaithScheduled ? bagNumber("CommunityInterfaithEntryCount") : 0;
	                                            var partnerEntryCount = partnersScheduled ? bagNumber("CommunityPartnerEntryCount") : 0;
	                                            var interfaithHasValue = interfaithEntryCount > 0;
	                                            var partnersHasValue = partnerEntryCount > 0;
	                                            var faithEventsMeetingGoal = faithScheduled ? bagNumber("CommunityFaithEventsMeetingGoal") : 0;
	                                            var faithTotalEvents = faithScheduled ? bagNumber("CommunityFaithTotalEvents") : 0;
                                                var faithCoverageCount = faithTotalEvents > 0
                                                    ? $"{faithEventsMeetingGoal:0} of {faithTotalEvents:0}"
                                                    : "No data";
	                                            var clergyLatestTotal = clergyScheduled ? bagNumber("CommunityClergyLatestTotal") : 0;
	                                            var diversityLatestCount = diversityVisible ? bagNumber("CommunityDiversityLatestCount") : 0;
	                                            var firstTimeTotalParticipants = firstTimeVisible ? bagNumber("CommunityFirstTimeTotalParticipants") : 0;
	                                            var youthProgress = progressValue(youthValue, youthTarget);
	                                            var partnersProgress = progressValue(partnersValue, partnersTarget);
	                                            var interfaithProgress = progressValue(interfaithValue, interfaithTarget);
	                                            var faithProgress = progressValue(faithValue, faithTarget);
	                                            var satisfactionProgress = progressValue(satisfactionValue, satisfactionTarget);
	                                            var diversityProgress = progressValue(diversityValue, diversityTarget);
	                                            var firstTimeProgress = progressValue(firstTimeValue, firstTimeTarget);
                                            var youthStatusText = metricStatus(youthScheduled, youthHasValue, youthValue, youthTarget, mYouth?.Status);
                                            var interfaithStatusText = metricStatus(interfaithScheduled, interfaithHasValue, interfaithValue, interfaithTarget, mInterfaith?.Status);
                                            var partnersStatusText = metricStatus(partnersScheduled, partnersHasValue, partnersValue, partnersTarget, mPartners?.Status);
                                            var faithStatusText = metricStatus(faithScheduled, faithHasValue, faithValue, faithTarget, mFaith?.Status);
                                            var satisfactionStatusText = metricStatus(satisfactionScheduled, satisfactionHasValue, satisfactionValue, satisfactionTarget, mSatisfaction?.Status);
                                            var clergyStatusText = metricStatus(clergyScheduled, clergyValueRaw.HasValue, clergyValue, clergyTarget, mClergy?.Status);
                                            var diversityStatusText = earlyMetricStatus(diversityScheduled, diversityEntryCount > 0, diversityValueRaw.HasValue, diversityValue, diversityTarget, mDiversity?.Status, "Participant Diversity");
                                            var firstTimeStatusText = earlyMetricStatus(firstTimeScheduled, firstTimeEntryCount > 0, firstTimeHasValue, firstTimeValue, firstTimeTarget, mFirstTime?.Status, "First-Time Participants");

                                            var latestPartners = partnersScheduled ? ViewBag.CommunityPartnersLatest as IEnumerable<dynamic> : null;
                                            var anyLatestPartners = latestPartners != null && latestPartners.Any();
                                            var pulseAnyScheduled = youthScheduled || satisfactionScheduled || interfaithScheduled || faithScheduled;
                                            var pulseAllScheduled = youthScheduled && satisfactionScheduled && interfaithScheduled && faithScheduled;
                                            var relationshipAnyScheduled = partnersScheduled;
                                            var relationshipAllScheduled = partnersScheduled;
                                            var representationAnyScheduled = faithScheduled || diversityScheduled || firstTimeScheduled;
                                            var representationAllScheduled = faithScheduled && diversityScheduled && firstTimeScheduled;
                                            var networkAnyScheduled = interfaithScheduled || clergyScheduled;
                                            var networkAllScheduled = interfaithScheduled && clergyScheduled;
                                            var diversityStartText = metricStartText("Participant Diversity");
                                            var firstTimeStartText = metricStartText("First-Time Participants");

