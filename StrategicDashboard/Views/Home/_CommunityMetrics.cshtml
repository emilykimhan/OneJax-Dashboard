	                                                                    <div class="community-stat-card accent-teal">
	                                                                        <div class="community-stat-label">Interfaith events</div>
                                                                        <div class="community-stat-value">@(interfaithScheduled ? interfaithValue.ToString("0") : "--")</div>
                                                                        <div class="community-stat-meta">@(interfaithScheduled ? $"Target: {targetLabel(interfaithTarget)} events hosted" : interfaithStatusText)</div>
	                                                                    </div>
                                                                        }
                                                                        @if (clergyScheduled)
                                                                        {
	                                                                    <div class="community-stat-card accent-coral">
	                                                                        <div class="community-stat-label">Network growth</div>
                                                                        <div class="community-stat-value">@scheduledValueLabel(clergyScheduled, clergyValueRaw, "0.#", "%", true)</div>
                                                                        <div class="community-stat-meta">@(clergyScheduled ? $"Latest logged contacts: {clergyLatestTotal:0} | Target: {targetLabel(clergyTarget, "0.#", "+", "%")}" : clergyStatusText)</div>
	                                                                    </div>
                                                                        }
	                                                                </div>
	                                                            </section>
	                                                        </div>
	                                                    </div>
	                                                </div>
	                                            </div>

	                                            <script>
	                                                (function initCommunityCharts() {
	                                                    if (window.__onejaxCommunityChartsInit) return;
	                                                    window.__onejaxCommunityChartsInit = true;

	                                                    function waitForChartJs(tries) {
	                                                        if (window.Chart) return setup();
	                                                        if ((tries || 0) > 50) return;
	                                                        setTimeout(() => waitForChartJs((tries || 0) + 1), 60);
	                                                    }

	                                                    function setup() {
	                                                        const youthSeries = @Html.Raw(Json.Serialize(ViewBag.CommunityYouthAttendanceSeries ?? new List<object>()));
	                                                        const youthAvg = @Html.Raw(Json.Serialize(ViewBag.CommunityYouthPrePostAvg ?? new { pre = 0.0, post = 0.0 }));

	                                                        const youthLineEl = document.getElementById('commYouthAttendanceLine');
	                                                        if (youthLineEl) {
	                                                            const labels = (youthSeries || []).map(p => p.label);
	                                                            const values = (youthSeries || []).map(p => p.attendees);
	                                                            const ctx = youthLineEl.getContext('2d');
	                                                            const gradient = ctx.createLinearGradient(0, 0, 0, 260);
	                                                            gradient.addColorStop(0, 'rgba(42, 166, 164, 0.34)');
	                                                            gradient.addColorStop(1, 'rgba(42, 166, 164, 0.02)');

	                                                            new Chart(youthLineEl, {
	                                                                type: 'line',
	                                                                data: {
	                                                                    labels,
	                                                                    datasets: [{
	                                                                        label: 'Youth attendees',
	                                                                        data: values,
	                                                                        borderColor: '#17838c',
	                                                                        backgroundColor: gradient,
	                                                                        fill: true,
	                                                                        tension: 0.42,
	                                                                        borderWidth: 3,
	                                                                        pointRadius: 4,
	                                                                        pointHoverRadius: 6,
	                                                                        pointBackgroundColor: '#ffffff',
	                                                                        pointBorderWidth: 2,
	                                                                        pointBorderColor: '#17838c'
	                                                                    }]
	                                                                },
	                                                                options: {
	                                                                    responsive: true,
	                                                                    maintainAspectRatio: false,
	                                                                    plugins: { legend: { display: false } },
	                                                                    scales: {
	                                                                        x: { ticks: { color: '#6c879a' }, grid: { display: false } },
	                                                                        y: { ticks: { color: '#6c879a' }, grid: { color: 'rgba(23, 50, 77, 0.10)' }, beginAtZero: true }
	                                                                    }
	                                                                }
	                                                            });
	                                                        }

	                                                        const youthBarEl = document.getElementById('commYouthPrePostBar');
	                                                        if (youthBarEl) {
	                                                            new Chart(youthBarEl, {
	                                                                type: 'bar',
	                                                                data: {
	                                                                    labels: ['Pre-assessment', 'Post-assessment'],
	                                                                    datasets: [{
	                                                                        data: [youthAvg?.pre || 0, youthAvg?.post || 0],
	                                                                        backgroundColor: ['rgba(239, 125, 87, 0.62)', 'rgba(42, 166, 164, 0.68)'],
	                                                                        borderRadius: 999,
	                                                                        borderSkipped: false
	                                                                    }]
	                                                                },
	                                                                options: {
	                                                                    responsive: true,
	                                                                    maintainAspectRatio: false,
	                                                                    indexAxis: 'y',
	                                                                    layout: { padding: { right: 8 } },
	                                                                    plugins: { legend: { display: false }, tooltip: { callbacks: { label: (ctx) => `${ctx.parsed.x}%` } } },
	                                                                    scales: {
	                                                                        x: { ticks: { color: '#6c879a' }, grid: { color: 'rgba(23, 50, 77, 0.08)' }, beginAtZero: true, suggestedMax: 100 },
	                                                                        y: { ticks: { color: '#5d768b' }, grid: { display: false } }
	                                                                    }
	                                                                }
	                                                            });
	                                                        }

	                                                        const partnersFy = @Html.Raw(Json.Serialize(ViewBag.CommunityPartnersByFiscalYear ?? new List<object>()));
	                                                        const partnersEl = document.getElementById('commPartnersFyBar');
	                                                        if (partnersEl) {
	                                                            const labels = (partnersFy || []).map(p => p.fiscalYear);
	                                                            const values = (partnersFy || []).map(p => p.count);
	                                                            new Chart(partnersEl, {
	                                                                type: 'bar',
	                                                                data: {
	                                                                    labels,
	                                                                    datasets: [{
	                                                                        label: 'New partners',
	                                                                        data: values,
	                                                                        backgroundColor: ['rgba(244, 201, 138, 0.90)', 'rgba(42, 166, 164, 0.82)', 'rgba(239, 125, 87, 0.86)'],
	                                                                        borderRadius: 14,
	                                                                        borderSkipped: false
	                                                                    }]
	                                                                },
	                                                                options: {
	                                                                    responsive: true,
	                                                                    maintainAspectRatio: false,
	                                                                    indexAxis: 'y',
	                                                                    plugins: { legend: { display: false } },
	                                                                    scales: {
	                                                                        x: { ticks: { color: 'rgba(255,255,255,0.86)', precision: 0 }, grid: { color: 'rgba(255,255,255,0.10)' }, beginAtZero: true },
	                                                                        y: { ticks: { color: 'rgba(255,255,255,0.86)' }, grid: { display: false } }
	                                                                    }
	                                                                }
	                                                            });
	                                                        }

	                                                    }

	                                                    waitForChartJs(0);
	                                                })();
	                                            </script>
	                                        }
