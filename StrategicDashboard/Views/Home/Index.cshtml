	                                                    font-size: 0.78rem;
	                                                    margin-top: 0.2rem;
	                                                }

	                                                .community-pulse-shell .community-chart-card,
	                                                .community-pulse-shell .community-mini-card,
	                                                .community-pulse-shell .community-rail-card,
	                                                .community-pulse-shell .community-insight-card {
	                                                    background: rgba(255,255,255,0.78);
	                                                    border: 1px solid rgba(23, 50, 77, 0.08);
	                                                    border-radius: 20px;
	                                                    padding: 1rem;
	                                                }

	                                                .community-pulse-shell .community-relationships .community-chart-card,
