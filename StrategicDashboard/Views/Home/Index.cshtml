	                                                                },
	                                                                options: {
	                                                                    responsive: true,
	                                                                    maintainAspectRatio: false,
	                                                                    plugins: { legend: { display: false } },
	                                                                    scales: {
	                                                                        x: { ticks: { color: '#6c879a' }, grid: { display: false } },
	                                                                        y: { ticks: { color: '#6c879a' }, grid: { color: 'rgba(23, 50, 77, 0.10)' }, beginAtZero: true }
