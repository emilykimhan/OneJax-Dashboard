                                                            <small class="text-muted">Trust Rating Score</small>
                                                            @if (metric.CurrentValue >= Convert.ToDecimal(metric.Target))
                                                            {
                                                                <div class="mt-3">
                                                                    <span class="badge bg-success">Target Achieved</span>
                                                                </div>
                                                            }
                                                            else
