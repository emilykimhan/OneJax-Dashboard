@{
    string GetEventHeaderColor(string status)
    {
        return status switch
        {
            "Completed" => "#10b981",
            "Active" => "#3b82f6",
            "In Progress" => "#f59e0b",
            "Planned" => "#6b7280",
            _ => "#374151"
        };
    }

    string GetEventHeaderColorSecondary(string status)
    {
        return status switch
        {
            "Completed" => "#059669",
            "Active" => "#2563eb",
            "In Progress" => "#d97706",
            "Planned" => "#4b5563",
            _ => "#1f2937"
        };
    }
}
