                                                        if (satisfactionCtx) {
                                                            const satisfactionValue = @metric.CurrentValue;
                                                            const targetValue = @Convert.ToDecimal(metric.Target);
                                                            const progressPercentage = Math.min((satisfactionValue / targetValue) * 100, 100);
                                                            
                                                            new Chart(satisfactionCtx, {
                                                                type: 'doughnut',
                                                                data: {
                                                                    datasets: [{
                                                                        data: [progressPercentage, 100 - progressPercentage],
                                                                        backgroundColor: [
