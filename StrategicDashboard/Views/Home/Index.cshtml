	                                                    function waitForChartJs(tries) {
	                                                        if (window.Chart) return setup();
	                                                        if ((tries || 0) > 50) return;
	                                                        setTimeout(() => waitForChartJs((tries || 0) + 1), 60);
	                                                    }

	                                                    function setup() {
	                                                        const youthSeries = @Html.Raw(Json.Serialize(ViewBag.CommunityYouthAttendanceSeries ?? new List<object>()));
