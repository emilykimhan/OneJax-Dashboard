                                                                        tooltip: {
                                                                            callbacks: {
                                                                                label: function(context) {
                                                                                    const label = context.dataset.label || '';
                                                                                    const value = context.parsed.y;
                                                                                    if (label === 'Net Income') {
                                                                                        return label + ': ' + (value >= 0 ? '+' : '') + '$' + value.toLocaleString();
                                                                                    }
                                                                                    return label + ': $' + value.toLocaleString();
                                                                                }
                                                                            }
                                                                        }
                                                                    },
                                                                    scales: {
                                                                        y: {
                                                                            beginAtZero: true,
                                                                            ticks: { 
                                                                                color: '#64748b',
