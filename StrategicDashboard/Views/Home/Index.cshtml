	                                                            const gradient = ctx.createLinearGradient(0, 0, 0, 260);
	                                                            gradient.addColorStop(0, 'rgba(42, 166, 164, 0.34)');
	                                                            gradient.addColorStop(1, 'rgba(42, 166, 164, 0.02)');

