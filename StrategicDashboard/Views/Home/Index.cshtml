                    </div>
                </div>
            `;
        })
        .catch(error => {
            console.error('Error loading event details:', error);
            modalLabel.textContent = 'Error Loading Event';
            modalContent.innerHTML = `
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-circle"></i>
                    <strong>Error loading event details.</strong><br>
                    ${error.message || 'Please try again later.'}
                    <br><br>
                    <a href="/Events/Details/${eventId}" class="btn btn-primary">
                        <i class="fas fa-external-link-alt"></i> View Full Details Page
                    </a>
                </div>
            `;
        });
}

	// Force manage buttons to stay in same tab - AGGRESSIVE APPROACH
	document.addEventListener('DOMContentLoaded', function() {
	    const canManageData = @canManageData.ToString().ToLower();
	    if (!canManageData) return;
	    // Find ALL links that go to Strategy/ViewEvents 
	    const manageLinks = document.querySelectorAll('a[href*="/Strategy/ViewEvents"], a[href*="Strategy/ViewEvents"]');
	    console.log('Found manage links:', manageLinks.length);
    
    manageLinks.forEach(function(link, index) {
        console.log('Processing link', index, ':', link.href);
        
        // Force remove any target attributes
        link.removeAttribute('target');
        link.removeAttribute('rel'); 
        
        // Set explicit target to self
        link.target = '_self';
        
	        // Override the click completely
	        link.onclick = function(e) {
            e.preventDefault();
            e.stopPropagation();
            e.stopImmediatePropagation();
            
	            console.log('Navigating to Strategy/ViewEvents in same tab');
	            
	            // Use location.href for same-tab navigation
	            window.location.href = '/Strategy/ViewEvents';
	            
	            return false;
	        };
	        
	        // Also set as attribute for double safety
	        link.setAttribute('onclick', 'event.preventDefault(); window.location.href=\"/Strategy/ViewEvents\"; return false;');
	    });
	});
</script>

@{
    string GetEventHeaderColor(string status)
    {
        return status switch
        {
            "Completed" => "#10b981",
            "Active" => "#3b82f6",
            "In Progress" => "#f59e0b",
            "Planned" => "#6b7280",
            _ => "#374151"
        };
    }

    string GetEventHeaderColorSecondary(string status)
    {
        return status switch
        {
            "Completed" => "#059669",
            "Active" => "#2563eb",
            "In Progress" => "#d97706",
            "Planned" => "#4b5563",
            _ => "#1f2937"
        };
    }
}
