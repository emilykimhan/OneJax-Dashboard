	                                                                    labels: ['Pre-assessment', 'Post-assessment'],
	                                                                    datasets: [{
	                                                                        data: [youthAvg?.pre || 0, youthAvg?.post || 0],
	                                                                        backgroundColor: ['rgba(239, 125, 87, 0.62)', 'rgba(42, 166, 164, 0.68)'],
	                                                                        borderRadius: 999,
	                                                                        borderSkipped: false
	                                                                    }]
	                                                                },
	                                                                options: {
	                                                                    responsive: true,
	                                                                    maintainAspectRatio: false,
	                                                                    indexAxis: 'y',
	                                                                    layout: { padding: { right: 8 } },
	                                                                    plugins: { legend: { display: false }, tooltip: { callbacks: { label: (ctx) => `${ctx.parsed.x}%` } } },
	                                                                    scales: {
	                                                                        x: { ticks: { color: '#6c879a' }, grid: { color: 'rgba(23, 50, 77, 0.08)' }, beginAtZero: true, suggestedMax: 100 },
	                                                                        y: { ticks: { color: '#5d768b' }, grid: { display: false } }
	                                                                    }
	                                                                }
	                                                            });
	                                                        }

	                                                        const partnersFy = @Html.Raw(Json.Serialize(ViewBag.CommunityPartnersByFiscalYear ?? new List<object>()));
	                                                        const partnersEl = document.getElementById('commPartnersFyBar');
	                                                        if (partnersEl) {
	                                                            const labels = (partnersFy || []).map(p => p.fiscalYear);
	                                                            const values = (partnersFy || []).map(p => p.count);
	                                                            new Chart(partnersEl, {
	                                                                type: 'bar',
	                                                                data: {
	                                                                    labels,
	                                                                    datasets: [{
	                                                                        label: 'New partners',
	                                                                        data: values,
	                                                                        backgroundColor: ['rgba(244, 201, 138, 0.90)', 'rgba(42, 166, 164, 0.82)', 'rgba(239, 125, 87, 0.86)'],
	                                                                        borderRadius: 14,
	                                                                        borderSkipped: false
	                                                                    }]
	                                                                },
	                                                                options: {
	                                                                    responsive: true,
	                                                                    maintainAspectRatio: false,
	                                                                    indexAxis: 'y',
	                                                                    plugins: { legend: { display: false } },
	                                                                    scales: {
	                                                                        x: { ticks: { color: 'rgba(255,255,255,0.86)', precision: 0 }, grid: { color: 'rgba(255,255,255,0.10)' }, beginAtZero: true },
	                                                                        y: { ticks: { color: 'rgba(255,255,255,0.86)' }, grid: { display: false } }
	                                                                    }
	                                                                }
	                                                            });
	                                                        }

	                                                        const representationRadarEl = document.getElementById('commRepresentationRadar');
	                                                        if (representationRadarEl) {
	                                                            new Chart(representationRadarEl, {
	                                                                type: 'radar',
	                                                                data: {
	                                                                    labels: ['Interfaith', 'Faith Mix', 'Satisfaction', 'Diversity', 'First-Time'],
	                                                                    datasets: [{
	                                                                        label: 'Progress to goal',
	                                                                        data: [
	                                                                            @Math.Min((double)interfaithProgress, 140).ToString(System.Globalization.CultureInfo.InvariantCulture),
	                                                                            @Math.Min((double)faithProgress, 140).ToString(System.Globalization.CultureInfo.InvariantCulture),
	                                                                            @Math.Min((double)satisfactionProgress, 140).ToString(System.Globalization.CultureInfo.InvariantCulture),
	                                                                            @Math.Min((double)diversityProgress, 140).ToString(System.Globalization.CultureInfo.InvariantCulture),
	                                                                            @Math.Min((double)firstTimeProgress, 140).ToString(System.Globalization.CultureInfo.InvariantCulture)
	                                                                        ],
	                                                                        backgroundColor: 'rgba(42, 166, 164, 0.18)',
	                                                                        borderColor: '#17838c',
	                                                                        borderWidth: 2.5,
	                                                                        pointBackgroundColor: ['#17838c', '#2aa6a4', '#ef7d57', '#f4c98a', '#17324d'],
	                                                                        pointBorderColor: '#ffffff',
	                                                                        pointRadius: 4
	                                                                    }]
	                                                                },
	                                                                options: {
	                                                                    responsive: true,
	                                                                    maintainAspectRatio: false,
	                                                                    plugins: { legend: { display: false } },
	                                                                    scales: {
	                                                                        r: {
	                                                                            suggestedMin: 0,
	                                                                            suggestedMax: 140,
	                                                                            ticks: { color: '#7892a4', backdropColor: 'transparent', stepSize: 20 },
	                                                                            pointLabels: { color: '#4f6b81', font: { size: 12, weight: '600' } },
	                                                                            grid: { color: 'rgba(23, 50, 77, 0.10)' },
	                                                                            angleLines: { color: 'rgba(23, 50, 77, 0.10)' }
	                                                                        }
	                                                                    }
	                                                                }
	                                                            });
	                                                        }
	                                                    }

	                                                    waitForChartJs(0);
	                                                })();
	                                            </script>
	                                        }
	                                        else
	                                        {
	                                            @foreach (var metric in orderedMetrics)
