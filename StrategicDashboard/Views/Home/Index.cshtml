	                                                .community-pulse-shell .community-panel h4 {
	                                                    color: var(--community-ink);
	                                                    font-weight: 800;
	                                                    margin: 0.55rem 0 0.25rem;
	                                                }

	                                                .community-pulse-shell .community-relationships h4,
	                                                .community-pulse-shell .community-relationships p,
	                                                .community-pulse-shell .community-relationships .community-stat-label,
	                                                .community-pulse-shell .community-relationships .community-mini-table th,
	                                                .community-pulse-shell .community-relationships .community-mini-table td,
	                                                .community-pulse-shell .community-relationships .community-kpi-caption,
