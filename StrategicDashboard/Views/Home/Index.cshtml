@model DashboardViewModel
@using OneJaxDashboard.Models
@inject OneJaxDashboard.Services.IDashboardNotesStore DashboardNotesStore
@{
    ViewData["Title"] = "OneJax Strategic Dashboard - Enhanced";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var selectedGoal = Context.Request.Query["goal"].ToString();
    var selectedStatus = Context.Request.Query["status"].ToString();
    var selectedTime = Context.Request.Query["time"].ToString();
    var selectedFiscalYear = ViewBag.SelectedFiscalYear?.ToString() ?? string.Empty;
    var selectedQuarter = Context.Request.Query["quarter"].ToString();
    var activeFiscalYear = ViewBag.ActiveFiscalYearLabel?.ToString() ?? (string.IsNullOrWhiteSpace(selectedFiscalYear) ? "All Years" : selectedFiscalYear);
    
    // Check if we have enhanced metrics
    var hasEnhancedMetrics = Model.StrategicGoals?.Any(g => g.Metrics?.Any(m => !string.IsNullOrEmpty(m.DataSource)) == true) == true;

    // Gate all data-entry/admin actions from public viewers.
    var canManageData = (User?.Identity?.IsAuthenticated ?? false) && (User.IsInRole("Admin") || User.IsInRole("Staff"));

}

<!-- Enhanced Header Section -->
<div class="dashboard-header dashboard-header-content">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-8 slide-in-left">
                <div class="dashboard-hero-badge-wrap">
                    <span class="badge-modern dashboard-hero-badge">FISCAL YEAR @activeFiscalYear</span>
                </div>
                <h1 class="display-3 mb-4 dashboard-hero-title">
                    Your Investment at Work
                </h1>
                <p class="lead mb-4 dashboard-hero-lead">See the Revenue and the Projects</p>
                <p class="mb-3 dashboard-hero-copy">The OneJax Strategic Dashboard provides comprehensive financial and project progress tracking of our strategic initiatives.</p>
                <div class="mt-4">
                    <a href="@(canManageData ? "/Strategy/ViewEvents" : "/Public/Events")" class="btn btn-outline-light btn-lg dashboard-hero-cta">
                        @(canManageData ? "View Events" : "View Public Events")
                    </a>
                </div>
            </div>
            <div class="col-md-4 text-end slide-in-right">
                <div class="pulse-animation">
                    <img src="~/Images/OneJax Logo.png" alt="OneJax Logo" class="dashboard-hero-logo">
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Comprehensive Metrics are now integrated directly into each goal tab below -->

<!-- Enhanced Introduction Section -->
<div class="container mb-5 fade-in">
    <div class="row">
        <div class="col-12">
            <div class="floating-card dashboard-intro-card">
                <div class="row">
                    <div class="col-md-12">
                        <h3 class="dashboard-intro-title">Dashboard Overview & Navigation</h3>
                        
                        <p class="mb-3 dashboard-intro-copy">
                            <strong>Use the sorting features</strong> to focus in on goals or areas of interest. Click over to different tabs to see what is happening now, and what is planned for the near future. As projects are funded and prepared ready to implement, the progress tracking will show OneJax's goals for community engagement, organizational building, and financial stability.
                        </p>
                        
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <div class="dashboard-callout dashboard-callout-impact">
                                    <h6 class="dashboard-callout-title">Strategic Impact</h6>
                                    <p class="dashboard-callout-copy">OneJax's Strategic Plan provides enhanced community engagement and organizational capacity, addresses infrastructure needs, and reduces operational inefficiencies.</p>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="dashboard-callout dashboard-callout-reach">
                                    <h6 class="dashboard-callout-title">Community Reach</h6>
                                    <p class="dashboard-callout-copy">Serving residents from Downtown to the Beaches and from Riverside to Mandarin with economic opportunity and community development.</p>
                                </div>
                            </div>
                        </div>
                        
	                        <div class="text-center">
	                            <p class="dashboard-feedback">
	                                Questions or feedback? <a href="mailto:onejax@onejax.org" class="dashboard-feedback-link">Email our team</a>
	                            </p>
	                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container mt-4">
    <div class="card p-4 dashboard-content-shell">



        <!-- Modern Navigation Tabs -->
        <partial name="_DashboardTabs" model="Model" view-data='new ViewDataDictionary(ViewData) { ["SelectedGoal"] = selectedGoal }' />

        <!-- Modern Dashboard Controls -->
        <partial name="_DashboardControls" model="Model" view-data='new ViewDataDictionary(ViewData) { ["SelectedFiscalYear"] = selectedFiscalYear }' />

        <!-- Strategic Projects Dashboard: Revenue & Progress Tracking -->
        <div class="row" id="dashboard-content">
            <!-- Summary Section -->
            <partial name="_SummarySection" model="Model" view-data='new ViewDataDictionary(ViewData) { ["SelectedGoal"] = selectedGoal, ["CanManageData"] = canManageData }' />
            
            @if (Model.StrategicGoals != null)
            {
                @foreach (var goal in Model.StrategicGoals)
                {
                    @* Municipal dashboard styling *@
                    var isSelectedGoal = !string.IsNullOrEmpty(selectedGoal) && goal.Name == selectedGoal;
                    var shouldShow = !string.IsNullOrEmpty(selectedGoal) && goal.Name == selectedGoal;
                
                <div class="col-12 mb-4 goal-section" 
                     data-goal="@goal.Name.Replace(" ", "_")" 
                     style="@(shouldShow ? "" : "display: none;")">
                    <div class="card goal-panel-card @(isSelectedGoal ? "is-selected" : "")">
                        <div class="card-header goal-panel-header">
                            <div class="row align-items-center">
                                <div class="col-md-8">
                                    <h3 class="goal-panel-title">
                                        @goal.Name @(isSelectedGoal ? "★" : "")
                                    </h3>
                                    <p class="goal-panel-subtitle">Strategic Initiative | Investment Tracking & Progress</p>
                                </div>
                                <div class="col-md-4 text-end">
                                    @{
                                        var goalMetrics = goal.Metrics ?? new List<GoalMetric>();
                                        var scheduledMetricCount = DashboardMetricRules.ScheduledMetrics(goalMetrics, activeFiscalYear).Count();
                                        var reportingMetricCount = DashboardMetricRules.ReportingMetrics(goalMetrics, activeFiscalYear).Count();
                                        var goalProgress = DashboardMetricRules.CalculateGoalProgress(goalMetrics, activeFiscalYear);
                                    }
                                    <div class="goal-panel-progress">
                                        <div class="goal-panel-progress-value">@(reportingMetricCount > 0 ? $"{Math.Round(goalProgress, 1)}%" : scheduledMetricCount > 0 ? "Awaiting data" : "Starts later")</div>
                                        <small>Overall Progress</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="card-body goal-panel-body">
                            <div class="row mb-4">
                                <div class="col-md-12">
                                    <div class="progress goal-panel-progress-track">
                                        <div class="progress-bar goal-panel-progress-bar" style="width: @Math.Min(goalProgress, 100)%;" role="progressbar"></div>
                                    </div>
                                    <div class="d-flex justify-content-between mt-2">
                                        <small class="goal-panel-progress-label-muted">Project Start</small>
                                        <small class="goal-panel-progress-label-active">@(reportingMetricCount > 0 ? $"{Math.Round(goalProgress, 1)}% Complete" : scheduledMetricCount > 0 ? "Awaiting data" : "Starts later")</small>
                                        <small class="goal-panel-progress-label-muted">Target Completion</small>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Metrics Section -->
                            @if (goal.Metrics != null && goal.Metrics.Any() && !(goal.Name.Contains("Identity") || goal.Name.Contains("Value")))
                            {
	                                var isFinancialGoal = goal.Name.Contains("Financial") || goal.Name.Contains("Sustainability");
	                                IEnumerable<GoalMetric> orderedMetrics = isFinancialGoal
	                                    ? goal.Metrics
	                                        .OrderBy(m =>
	                                            ((m.Name.Contains("Fee-for-Service") || m.Name.Contains("Service Income")) ? 1 :
	                                            ((m.Name.Contains("Donor") && m.Name.Contains("Communication") && m.Name.Contains("Satisfaction")) ? 2 :
	                                            ((m.Name.Contains("Donor") && m.Name.Contains("Engagement")) ? 3 :
	                                            ((m.Name.Contains("General Income") || m.Name.Contains("Income Streams") || m.Name.Contains("Diversified Income")) ? 4 : 99)))))
	                                        // Prefer showing the metric row that actually has data when duplicates exist.
	                                        .ThenByDescending(m => m.CurrentValue)
	                                        .ThenBy(m => m.Name)
	                                    : goal.Metrics.AsEnumerable();

	                                <div class="mb-4">
	                                    <h5 class="goal-panel-metrics-title">Key Metrics</h5>
	                                    <div class="row g-3">
	                                        @{
	                                            // If the database has duplicate metric rows (same "type" with zeros),
	                                            // render the enhanced visualization only once per type.
	                                            var renderedFinancialCards = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
	                                        }
	                                        @if (goal.Name.Contains("Community", StringComparison.OrdinalIgnoreCase))
	                                        {
	                                            <partial name="_CommunityMetrics" model="Model" view-data='new ViewDataDictionary(ViewData) { ["Goal"] = goal, ["CanManageData"] = canManageData }' />
	                                        }
	                                        else if (goal.Name.Contains("Organizational", StringComparison.OrdinalIgnoreCase) || goal.Name.Contains("Building", StringComparison.OrdinalIgnoreCase))
	                                        {
	                                            <partial name="_OrganizationalMetrics" model="Model" view-data='new ViewDataDictionary(ViewData) { ["Goal"] = goal, ["CanManageData"] = canManageData }' />
	                                        }
	                                        else
	                                        {
	                                            <partial name="_FinancialMetrics" model="Model" view-data='new ViewDataDictionary(ViewData) { ["Goal"] = goal, ["CanManageData"] = canManageData }' />
	                                        }
	                                    </div>
	                                </div>
                            }
                            
                            <partial name="_IdentitySection" model="Model" view-data='new ViewDataDictionary(ViewData) { ["Goal"] = goal, ["CanManageData"] = canManageData }' />

                            
                            <partial name="_GoalFooterSection" model="Model" view-data='new ViewDataDictionary(ViewData) { ["Goal"] = goal, ["CanManageData"] = canManageData, ["UserAuthenticated"] = (User?.Identity?.IsAuthenticated ?? false), ["SelectedStatus"] = selectedStatus }' />
                        </div>
                    </div>
                </div>
                }
            }
        </div>

        <partial name="_DashboardBottomSummary" model="Model" view-data='new ViewDataDictionary(ViewData) { ["ActiveFiscalYear"] = activeFiscalYear }' />
    </div>
</div>

<partial name="_EventDetailsModal" view-data='new ViewDataDictionary(ViewData) { ["CanManageData"] = canManageData }' />

<partial name="_DashboardScripts" model="Model" view-data='new ViewDataDictionary(ViewData) { ["CanManageData"] = canManageData }' />
