	                                                                type: 'line',
	                                                                data: {
	                                                                    labels,
	                                                                    datasets: [{
	                                                                        label: 'Youth attendees',
	                                                                        data: values,
	                                                                        borderColor: '#17838c',
	                                                                        backgroundColor: gradient,
	                                                                        fill: true,
	                                                                        tension: 0.42,
	                                                                        borderWidth: 3,
	                                                                        pointRadius: 4,
	                                                                        pointHoverRadius: 6,
	                                                                        pointBackgroundColor: '#ffffff',
	                                                                        pointBorderWidth: 2,
	                                                                        pointBorderColor: '#17838c'
