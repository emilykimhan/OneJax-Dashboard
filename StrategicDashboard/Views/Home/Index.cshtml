                                                                    <div class="text-center">
                                                                        <div style="font-size: 2rem; font-weight: 600; color: #374151;">@(donorEventCount > 0 ? $"{Math.Round(donorSatisfactionRate, 1)}%" : "0%")</div>
                                                                        <small style="color: var(--onejax-text-muted); font-weight: 500;">Satisfaction Rate</small>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                            
                                                            <!-- Event-by-event growth visualization -->
                                                            <div class="mb-4">
                                                                <div class="d-flex justify-content-between align-items-center mb-3">
                                                                    <h6 style="color: #6b7280; font-weight: 600; margin: 0;">Event-by-Event Engagement Growth</h6>
                                                                    <small style="color: var(--onejax-text-muted);">Target: 3 events/year, +10% per event</small>
                                                                </div>
                                                                
                                                                <div style="height: 150px; position: relative;">
                                                                    <canvas id="donorEngagementChart" width="400" height="150"></canvas>
                                                                </div>
                                                            </div>
                                                            
                                                            <!-- Goal progress -->
                                                            <div class="mt-3 pt-3" style="border-top: 1px solid rgba(14, 165, 233, 0.2);">
                                                                <div class="progress" style="height: 12px; border-radius: 6px; background: rgba(14, 165, 233, 0.1);">
                                                                    <div class="progress-bar" style="width: @Math.Min((metric.CurrentValue / donorTarget) * 100, 100)%; background: linear-gradient(90deg, #0ea5e9, #0284c7); border-radius: 6px;" role="progressbar"></div>
                                                                </div>
                                                                <div class="d-flex justify-content-between mt-2">
                                                                    <small style="color: var(--onejax-text-muted);">
                                                                        @Math.Round((metric.CurrentValue / donorTarget) * 100, 1)% of annual participant target
                                                                    </small>
                                                                    <small style="color: var(--onejax-text-muted);">
                                                                        Goal: @donorTarget participants annually
                                                                    </small>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                
                                                <script>
                                                    // Initialize the donor engagement chart
                                                    document.addEventListener('DOMContentLoaded', function() {
                                                        const donorCtx = document.getElementById('donorEngagementChart');
                                                        if (donorCtx) {
                                                            const hasData = @hasDonorData.ToString().ToLower();
                                                            
                                                            // Goal model: 3 events annually and +10% engagement per event.
                                                            const engagementIndex = hasData ? [100, 110, 121] : [0, 0, 0];
                                                            const recordedEventCount = @donorEventCount;
                                                            const eventsHosted = hasData ? [
                                                                recordedEventCount >= 1 ? 1 : 0,
                                                                recordedEventCount >= 2 ? 1 : 0,
                                                                recordedEventCount >= 3 ? 1 : 0
                                                            ] : [0, 0, 0];
                                                            
                                                            new Chart(donorCtx, {
                                                                type: 'bar',
                                                                data: {
                                                                    labels: ['Event 1', 'Event 2', 'Event 3'],
                                                                    datasets: [
                                                                        {
                                                                            type: 'bar',
                                                                            label: 'Events Hosted',
                                                                            data: eventsHosted,
                                                                            backgroundColor: 'rgba(14, 165, 233, 0.25)',
                                                                            borderColor: '#0284c7',
                                                                            borderWidth: 1,
                                                                            borderRadius: 4,
                                                                            yAxisID: 'yEvents'
                                                                        },
                                                                        {
                                                                            type: 'line',
                                                                            label: 'Engagement Index (Event 1 = 100)',
                                                                            data: engagementIndex,
                                                                            borderColor: '#0f766e',
                                                                            backgroundColor: '#0f766e',
                                                                            pointBackgroundColor: '#0f766e',
                                                                            pointRadius: 4,
                                                                            pointHoverRadius: 5,
                                                                            borderWidth: 3,
                                                                            tension: 0.3,
                                                                            yAxisID: 'yEngagement'
                                                                        }
                                                                    ]
                                                                },
                                                                options: {
                                                                    responsive: true,
                                                                    maintainAspectRatio: false,
                                                                    plugins: {
                                                                        legend: {
                                                                            display: true,
                                                                            position: 'bottom'
                                                                        },
                                                                        tooltip: {
                                                                            callbacks: {
                                                                                label: function(context) {
                                                                                    if (context.dataset.yAxisID === 'yEngagement') {
                                                                                        return context.dataset.label + ': ' + context.parsed.y + '%';
                                                                                    }
                                                                                    return context.dataset.label + ': ' + context.parsed.y;
                                                                                }
                                                                            }
                                                                        }
                                                                    },
                                                                    scales: {
                                                                        yEvents: {
                                                                            type: 'linear',
                                                                            position: 'left',
                                                                            beginAtZero: true,
                                                                            max: 1.5,
                                                                            ticks: {
                                                                                stepSize: 1,
                                                                                color: '#64748b'
                                                                            },
                                                                            title: {
                                                                                display: true,
                                                                                text: 'Events'
                                                                            },
                                                                            grid: { display: false }
                                                                        },
                                                                        yEngagement: {
                                                                            type: 'linear',
                                                                            position: 'right',
                                                                            beginAtZero: false,
                                                                            min: hasData ? 90 : 0,
                                                                            max: hasData ? 130 : 10,
                                                                            ticks: { color: '#64748b' },
                                                                            title: {
                                                                                display: true,
                                                                                text: 'Engagement Index (%)'
                                                                            },
                                                                            grid: { color: 'rgba(148, 163, 184, 0.2)' }
                                                                        },
                                                                        x: {
                                                                            ticks: { color: '#64748b' },
                                                                            grid: { display: false }
                                                                        }
                                                                    }
                                                                }
                                                            });
                                                        }
                                                    });
                                                </script>
                                            }
                                            else if ((metric.Name.Contains("General Income") || metric.Name.Contains("Income Streams") || metric.Name.Contains("Diversified Income")) && (goal.Name.Contains("Financial") || goal.Name.Contains("Sustainability")))
                                            {
                                                <!-- Enhanced General Income Streams Card -->
                                                <div class="col-md-12 mb-3">
                                                    <div class="card" style="background: linear-gradient(150deg, #fefce8, #f8fafc); border: 1px solid #eab308; border-radius: 28px 12px 28px 12px; box-shadow: 0 10px 22px rgba(161, 98, 7, 0.12); position: relative; overflow: hidden;">
                                                        <!-- Header with blue accent -->
                                                        <div class="card-header" style="background: linear-gradient(135deg, #a16207, #ca8a04); color: white; border: none; border-radius: 28px 12px 0 0; padding: 1.25rem;">
                                                            <div class="d-flex justify-content-between align-items-center">
                                                                <div>
                                                                    <h6 class="mb-0" style="font-weight: 600; font-size: 1.1rem;">
                                                                        <i class="fas fa-coins me-2"></i>General Income Streams
                                                                    </h6>
                                                                    <small style="opacity: 0.9;">Diversified Revenue Portfolio</small>
                                                                </div>
                                                                <div class="text-end">
                                                                    @{
                                                                        decimal incomeTarget = 500000; // Based on comprehensive income tracking
                                                                        bool hasIncomeData = metric.CurrentValue > 0;
                                                                        var incomeSourceCount = (int)Math.Max(0, Math.Round(metric.Q1Value));
                                                                    }
                                                                    @if (hasIncomeData && metric.CurrentValue >= incomeTarget * 0.85m)
                                                                    {
                                                                        <span class="badge" style="background: #10b981; font-size: 0.75rem;">
                                                                            <i class="fas fa-chart-line"></i> Excellent Diversification
                                                                        </span>
                                                                    }
                                                                    else if (hasIncomeData)
                                                                    {
                                                                        <span class="badge" style="background: #3b82f6; font-size: 0.75rem;">
                                                                            <i class="fas fa-trending-up"></i> Growing Portfolio
                                                                        </span>
                                                                    }
                                                                    else
                                                                    {
                                                                        <span class="badge" style="background: #6b7280; font-size: 0.75rem;">
                                                                            <i class="fas fa-seedling"></i> Building Streams
                                                                        </span>
                                                                    }
                                                                </div>
                                                            </div>
                                                        </div>
                                                        
                                                        <div class="card-body" style="padding: 2rem;">
                                                            <div class="row">
                                                                <!-- Main income display -->
                                                                <div class="col-md-4 mb-4">
                                                                    <div class="text-center" style="background: rgba(139, 92, 246, 0.1); border-radius: 12px; padding: 2rem;">
                                                                        <div style="font-size: 3rem; font-weight: 700; color: var(--onejax-blue); line-height: 1; margin-bottom: 0.5rem;">
                                                                            $@((metric.CurrentValue).ToString("N0"))
                                                                        </div>
                                                                        <small style="color: var(--onejax-text-muted); font-weight: 500; font-size: 0.9rem;">Total Annual Income</small>
                                                                        <div class="mt-3">
                                                                            <div class="progress" style="height: 8px; border-radius: 4px; background: rgba(139, 92, 246, 0.2);">
                                                                                <div class="progress-bar" style="width: @Math.Min((metric.CurrentValue / incomeTarget) * 100, 100)%; background: linear-gradient(90deg, #8b5cf6, #7c3aed); border-radius: 4px;" role="progressbar"></div>
                                                                            </div>
                                                                            <small style="color: var(--onejax-text-muted); margin-top: 0.5rem; display: block;">
                                                                                @Math.Round((metric.CurrentValue / incomeTarget) * 100, 1)% of $@(incomeTarget.ToString("N0")) target
                                                                            </small>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                
                                                                <!-- Real data summary -->
                                                                <div class="col-md-8">
                                                                    <h6 style="color: #6b7280; font-weight: 600; margin-bottom: 1.5rem;">
                                                                        <i class="fas fa-database me-2"></i>Income Data Summary
                                                                    </h6>
                                                                    
                                                                    <div class="row">
                                                                        <div class="col-md-6 mb-3">
                                                                            <div class="d-flex justify-content-between align-items-center p-3" style="background: rgba(75, 180, 200, 0.05); border-left: 4px solid var(--onejax-blue); border-radius: 0 8px 8px 0;">
                                                                                <div>
                                                                                    <div style="font-weight: 600; color: #6b7280;">Income Entries</div>
                                                                                    <small style="color: var(--onejax-text-muted);">Records from Income form</small>
                                                                                </div>
                                                                                <div class="text-end">
                                                                                    <div style="font-weight: 700; color: #374151; font-size: 1.1rem;">
                                                                                        @incomeSourceCount
                                                                                    </div>
                                                                                    <small style="color: var(--onejax-text-muted);">entries</small>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                        
                                                                        <div class="col-md-6 mb-3">
                                                                            <div class="d-flex justify-content-between align-items-center p-3" style="background: rgba(75, 180, 200, 0.05); border-left: 4px solid var(--onejax-blue); border-radius: 0 8px 8px 0;">
                                                                                <div>
                                                                                    <div style="font-weight: 600; color: #6b7280;">Average Per Entry</div>
                                                                                    <small style="color: var(--onejax-text-muted);">Total income / entry count</small>
                                                                                </div>
                                                                                <div class="text-end">
                                                                                    <div style="font-weight: 700; color: #374151; font-size: 1.1rem;">
                                                                                        @(incomeSourceCount > 0 ? "$" + Math.Round(metric.CurrentValue / incomeSourceCount, 0).ToString("N0") : "$0")
                                                                                    </div>
                                                                                    <small style="color: var(--onejax-text-muted);">per entry</small>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                        
                                                                        <div class="col-md-6 mb-3">
                                                                            <div class="d-flex justify-content-between align-items-center p-3" style="background: rgba(107, 114, 128, 0.05); border-left: 4px solid #d1d5db; border-radius: 0 8px 8px 0;">
                                                                                <div>
                                                                                    <div style="font-weight: 600; color: #6b7280;">Data Status</div>
                                                                                    <small style="color: var(--onejax-text-muted);">Current availability</small>
                                                                                </div>
                                                                                <div class="text-end">
                                                                                    <div style="font-weight: 700; color: #374151; font-size: 1.1rem;">
                                                                                        @(hasIncomeData ? "Active" : "Planning")
                                                                                    </div>
                                                                                    <small style="color: var(--onejax-text-muted);">from forms</small>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                        
                                                                        <div class="col-md-6 mb-3">
                                                                            <div class="d-flex justify-content-between align-items-center p-3" style="background: rgba(107, 114, 128, 0.05); border-left: 4px solid #e5e7eb; border-radius: 0 8px 8px 0;">
                                                                                <div>
                                                                                    <div style="font-weight: 600; color: #6b7280;">Target Remaining</div>
                                                                                    <small style="color: var(--onejax-text-muted);">To annual target</small>
                                                                                </div>
                                                                                <div class="text-end">
                                                                                    <div style="font-weight: 700; color: #374151; font-size: 1.1rem;">
                                                                                        $@Math.Max(incomeTarget - metric.CurrentValue, 0).ToString("N0")
                                                                                    </div>
                                                                                    <small style="color: var(--onejax-text-muted);">remaining</small>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                            else if (metric.Name.Contains("Media Placements") || 
                                                     metric.Name.Contains("Key Plan Milestones") || 
                                                     metric.Name.Contains("Content calendar") ||
                                                     metric.Name.Contains("brand messaging") ||
                                                     metric.Name.Contains("Budget Variance", StringComparison.OrdinalIgnoreCase) ||
                                                     metric.Description.Contains("Variance from annual budget", StringComparison.OrdinalIgnoreCase))
                                            {
                                                // Skip these unwanted metrics - they don't have proper forms
                                            }
                                            else
                                            {
                                                var financialDefaultCardStyle = "background:var(--onejax-white); border-radius:12px; border-left: 5px solid var(--onejax-orange);";
                                                if (isFinancialGoal)
                                                {
                                                    var styleVariant = metric.Id % 3;
                                                    financialDefaultCardStyle = styleVariant == 0
                                                        ? "background: linear-gradient(145deg, #f8fafc, #eef2ff); border: 1px solid #c7d2fe; border-radius: 20px 10px 20px 10px; border-left: 6px solid #4f46e5; box-shadow: 0 8px 18px rgba(79, 70, 229, 0.10);"
                                                        : styleVariant == 1
                                                            ? "background: linear-gradient(145deg, #fffbeb, #fef3c7); border: 1px solid #fcd34d; border-radius: 10px 20px 10px 20px; border-left: 6px solid #d97706; box-shadow: 0 8px 18px rgba(217, 119, 6, 0.10);"
                                                            : "background: linear-gradient(145deg, #ecfeff, #f0fdfa); border: 1px solid #99f6e4; border-radius: 18px; border-left: 6px solid #0f766e; box-shadow: 0 8px 18px rgba(15, 118, 110, 0.10);";
                                                }

                                                <!-- Default Progress Bar Style -->
                                                <div class="@(isFinancialGoal ? "col-md-12" : "col-md-6") mb-3">
                                                    <div class="card" style="@financialDefaultCardStyle">
                                                        <div class="card-body">
                                                            <h6 class="card-title" style="color:var(--onejax-navy);">@metric.Name</h6>
                                                            <p class="card-text" style="color:var(--onejax-navy); font-size:0.9em;">@metric.Description</p>
                                                            
                                                            <div class="d-flex justify-content-between align-items-center mb-2">
                                                                <span style="color:var(--onejax-navy);"><strong>Progress:</strong></span>
                                                                <span class="badge bg-primary">@metric.CurrentValue @metric.Unit / @metric.Target @metric.Unit</span>
                                                            </div>
                                                            
                                            <div class="progress mb-2" style="height: 12px; border-radius:6px;">
                                                <div class="progress-bar" role="progressbar" 
                                                     style="width: @(metric.ProgressPercentage > 0 ? Math.Max(metric.ProgressPercentage, 2) : 0)%; background-color: var(--onejax-blue);"
                                                     aria-valuenow="@metric.ProgressPercentage" aria-valuemin="0" aria-valuemax="100"></div>
                                            </div>                                                            <small style="color:var(--onejax-navy);">
                                                                <strong>Target:</strong> @metric.TargetDate.ToString("MMM yyyy") | 
                                                                <span class="badge @(metric.Status == "Active" ? "bg-success" : "bg-secondary")">@metric.Status</span>
                                                            </small>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        }
                                    </div>
                                </div>
                            }
                            
                            <!-- Quarterly Performance Overview Chart -->
                            @if (goal.Name.Contains("Identity") || goal.Name.Contains("Value"))
                            {
                                <div class="mb-4">
                                    <div class="card" style="border-radius: 12px; border: 1px solid var(--onejax-border); box-shadow: 0 2px 8px rgba(0,0,0,0.05);">
                                        <div class="card-header" style="background: linear-gradient(135deg, var(--onejax-navy), var(--onejax-blue)); color: white; border-radius: 12px 12px 0 0;">
                                            <h6 class="mb-0">📅 Quarterly Performance Overview</h6>
                                        </div>
                                        <div class="card-body">
                                            <canvas id="quarterlyChart" width="800" height="280" style="max-height: 280px;"></canvas>
                                        </div>
                                    </div>
                                </div>
                            }

                            
                            <!-- Public Summary Section - For Non-Authenticated Users -->
                            @if (!(User?.Identity?.IsAuthenticated ?? false))
                            {
                                <div class="mb-4">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <h5 style="color:var(--onejax-navy); margin-bottom:0;">🌟 Goal Progress Summary</h5>
                                        <small class="text-muted">
                                            <i class="fas fa-chart-bar"></i> Public progress overview
                                        </small>
                                    </div>
                                    <div class="row">
                                        <div class="col-md-6 col-lg-6 mb-3">
                                            <div class="card" style="border-radius: 12px; border: 1px solid var(--onejax-border); transition: all 0.2s ease;">
                                                <div class="card-body text-center" style="padding: 1.5rem;">
                                                    <h6 style="color: var(--onejax-navy); margin-bottom: 1rem; font-weight: 600;">Overall Progress</h6>
                                                    @{
                                                        var currentGoalProgress = goal.Metrics?.Any() == true ? goal.Metrics.Average(m => m.ProgressPercentage) : 0;
                                                    }
                                                    <div style="font-size: 2rem; font-weight: 700; color: var(--onejax-navy); margin-bottom: 1rem;">@Math.Round(currentGoalProgress, 1)%</div>
                                                    <div class="progress" style="height: 8px; border-radius: 4px; background: rgba(59, 130, 246, 0.1);">
                                                        <div class="progress-bar" style="width: @Math.Min(currentGoalProgress, 100)%; background: var(--gradient-secondary); border-radius: 4px;"></div>
                                                    </div>
                                                    <small class="text-muted mt-2 d-block">Strategic Initiative Progress</small>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6 col-lg-6 mb-3">
                                            <div class="card" style="border-radius: 12px; border: 1px solid var(--onejax-border); transition: all 0.2s ease;">
                                                <div class="card-body text-center" style="padding: 1.5rem;">
                                                    <h6 style="color: var(--onejax-navy); margin-bottom: 1rem; font-weight: 600;">
                                                        <i class="fas fa-calendar-check"></i> Strategic Events
                                                    </h6>
                                                    <div style="font-size: 2rem; font-weight: 700; color: var(--onejax-navy); margin-bottom: 1rem;">@(goal.Events?.Count() ?? 0)</div>
                                                    @{
                                                        var upcomingCount = goal.Events?.Count(e => e.Status == "Planned" || e.Status == "In Progress") ?? 0;
                                                        var completedCount = goal.Events?.Count(e => e.Status == "Completed") ?? 0;
                                                    }
                                                    @if (goal.Events != null && goal.Events.Any())
                                                    {
                                                        <div style="color: var(--onejax-text-muted); font-size: 0.9rem;">
                                                            @upcomingCount upcoming • @completedCount completed
                                                        </div>
                                                        @if (upcomingCount > 0)
                                                        {
                                                            <div style="margin-top: 0.5rem;">
                                                                <span class="badge" style="background: var(--gradient-secondary); color: white; font-size: 0.75rem;">
                                                                    Next: @(goal.Events.Where(e => e.DueDate.HasValue && e.DueDate > DateTime.Now).OrderBy(e => e.DueDate).FirstOrDefault()?.DueDate?.ToString("MMM dd") ?? "TBD")
                                                                </span>
                                                            </div>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <div style="color: var(--onejax-text-muted); font-size: 0.9rem;">No events scheduled yet</div>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                            
                            <!-- Events Section - Enhanced Display -->
                            @if (goal.Events != null && goal.Events.Any())
                            {
                                <div class="mb-4">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <h5 style="color:var(--onejax-navy); margin-bottom:0; font-weight: 600;">
                                            <i class="fas fa-calendar-check"></i> Strategic Events & Activities
                                        </h5>
                                        <span class="badge" style="background: var(--gradient-secondary); color: white;">
                                            @goal.Events.Count() Total Events
                                        </span>
                                    </div>
                                    
                                    <!-- Event Status Summary -->
                                    @{
                                        var upcomingEvents = goal.Events.Count(e => e.Status == "Planned" || e.Status == "In Progress");
                                        var completedEvents = goal.Events.Count(e => e.Status == "Completed");
                                        var activeEvents = goal.Events.Count(e => e.Status == "Active" || e.Status == "In Progress");
                                    }
                                    
                                    <div class="row mb-3">
                                        <div class="col-md-4">
                                            <div class="text-center p-2" style="background: rgba(59, 130, 246, 0.1); border-radius: 8px;">
                                                <div style="font-size: 1.5rem; font-weight: 700; color: var(--onejax-blue);">@upcomingEvents</div>
                                                <small style="color: var(--onejax-text-muted);">Upcoming</small>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="text-center p-2" style="background: rgba(16, 185, 129, 0.1); border-radius: 8px;">
                                                <div style="font-size: 1.5rem; font-weight: 700; color: var(--onejax-green);">@activeEvents</div>
                                                <small style="color: var(--onejax-text-muted);">Active</small>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="text-center p-2" style="background: rgba(34, 197, 94, 0.1); border-radius: 8px;">
                                                <div style="font-size: 1.5rem; font-weight: 700; color: #22c55e;">@completedEvents</div>
                                                <small style="color: var(--onejax-text-muted);">Completed</small>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Event Cards -->
                                    <div class="row">
                                        @foreach (var eventItem in goal.Events
                                            .Where(e => (string.IsNullOrEmpty(selectedStatus) || e.Status == selectedStatus))
                                            .OrderBy(e => e.DueDate ?? DateTime.MaxValue))
                                        {
                                            <div class="col-md-6 col-lg-4 mb-3">
                                                <div class="card event-card" 
                                                     style="background-color:var(--onejax-white); border-radius:12px; border: 1px solid var(--onejax-border); transition: all 0.3s ease; cursor: pointer;"
                                                     data-status="@eventItem.Status"
                                                     data-date="@eventItem.DueDate?.ToString("yyyy-MM-dd")"
                                                     data-quarter="@((eventItem.DueDate?.Month - 1) / 3 + 1)"
                                                     data-year="@eventItem.DueDate?.Year"
                                                     onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 4px 12px rgba(0,0,0,0.15)';"
                                                     onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 2px 8px rgba(0,0,0,0.1)';">
                                                    
                                                    <!-- Event Header -->
                                                    <div class="card-header" style="background: linear-gradient(135deg, @(GetEventHeaderColor(eventItem.Status)), @(GetEventHeaderColorSecondary(eventItem.Status))); color: white; border-radius: 12px 12px 0 0; border: none;">
                                                        <div class="d-flex justify-content-between align-items-center">
                                                            <div>
                                                                <h6 style="margin: 0; font-weight: 600;">@eventItem.Title</h6>
                                                                <small style="opacity: 0.9;">@eventItem.Type Event</small>
                                                            </div>
                                                            <span class="badge" style="background: rgba(255,255,255,0.2);">
                                                                @eventItem.Status
                                                            </span>
                                                        </div>
                                                    </div>
                                                    
                                                    <!-- Event Body -->
                                                    <div class="card-body" style="padding: 1rem;">
                                                        <div class="event-details">
                                                            <div class="mb-2">
                                                                <i class="fas fa-calendar" style="color: var(--onejax-blue); width: 16px;"></i>
                                                                <strong>Date:</strong> 
                                                                <span style="color: var(--onejax-navy);">
                                                                    @(eventItem.DueDate?.ToString("MMM dd, yyyy") ?? eventItem.StartDate?.ToString("MMM dd, yyyy") ?? "TBD")
                                                                </span>
                                                            </div>
                                                            
                                                            <div class="mb-2">
                                                                <i class="fas fa-map-marker-alt" style="color: var(--onejax-orange); width: 16px;"></i>
                                                                <strong>Location:</strong> 
                                                                <span style="color: var(--onejax-navy);">@(eventItem.Location ?? "TBD")</span>
                                                            </div>
                                                            
                                                            @if (eventItem.Attendees > 0)
                                                            {
                                                                <div class="mb-2">
                                                                    <i class="fas fa-users" style="color: var(--onejax-green); width: 16px;"></i>
                                                                    <strong>Expected:</strong> 
                                                                    <span style="color: var(--onejax-navy);">@eventItem.Attendees attendees</span>
                                                                </div>
                                                            }
                                                            
                                                            @if (!string.IsNullOrEmpty(eventItem.Description))
                                                            {
                                                                <div class="mb-3">
                                                                    <small style="color: var(--onejax-text-muted);">
                                                                        @(eventItem.Description.Length > 80 ? eventItem.Description.Substring(0, 80) + "..." : eventItem.Description)
                                                                    </small>
                                                                </div>
                                                            }
                                                            
                                                            @if (!string.IsNullOrEmpty(eventItem.Notes))
                                                            {
                                                                <div class="mb-3">
                                                                    <small style="color: var(--onejax-text-muted); font-style: italic;">
                                                                        📝 @(eventItem.Notes.Length > 60 ? eventItem.Notes.Substring(0, 60) + "..." : eventItem.Notes)
                                                                    </small>
                                                                </div>
                                                            }
                                                        </div>
                                                        
                                                        <!-- Action Buttons -->
                                                        <div class="d-flex justify-content-between align-items-center">
                                                            @if (User?.Identity?.IsAuthenticated ?? false)
                                                            {
                                                                <a href="/Strategy/ViewEvents?goalId=@goal.Id" class="btn btn-sm btn-outline-primary" style="border-radius: 8px;">
                                                                    <i class="fas fa-cog"></i> Manage
                                                                </a>
                                                            }
                                                            else
                                                            {
                                                                <div></div>
                                                            }
                                                            
                                                            @if (eventItem.DueDate.HasValue)
                                                            {
                                                                var daysUntil = (eventItem.DueDate.Value - DateTime.Now).Days;
                                                                @if (daysUntil >= 0)
                                                                {
                                                                    <small style="color: var(--onejax-blue); font-weight: 600;">
                                                                        @if (daysUntil == 0)
                                                                        {
                                                                            <span>📅 Today!</span>
                                                                        }
                                                                        else if (daysUntil == 1)
                                                                        {
                                                                            <span>📅 Tomorrow</span>
                                                                        }
                                                                        else if (daysUntil <= 7)
                                                                        {
                                                                            <span style="color: var(--onejax-orange);">📅 In @daysUntil days</span>
                                                                        }
                                                                        else
                                                                        {
                                                                            <span>📅 In @daysUntil days</span>
                                                                        }
                                                                    </small>
                                                                }
                                                                else
                                                                {
                                                                    <small style="color: #ef4444;">
                                                                        @if (eventItem.Status != "Completed")
