<div class="container mt-4">
    <div class="card p-4"
        style="background-color:var(--onejax-white); box-shadow:0 4px 24px rgba(0,0,0,0.08); border-radius:24px; max-width:2000px;">



        <!-- Modern Navigation Tabs -->
        <partial name="_DashboardTabs" model="Model" view-data='new ViewDataDictionary(ViewData) { ["SelectedGoal"] = selectedGoal }' />

        <!-- Modern Dashboard Controls -->
        <partial name="_DashboardControls" model="Model" view-data='new ViewDataDictionary(ViewData) { ["SelectedFiscalYear"] = selectedFiscalYear }' />

        <!-- Strategic Projects Dashboard: Revenue & Progress Tracking -->
        <div class="row" id="dashboard-content">
            <!-- Summary Section -->
            <partial name="_SummarySection" model="Model" view-data='new ViewDataDictionary(ViewData) { ["SelectedGoal"] = selectedGoal, ["CanManageData"] = canManageData }' />
            
            @if (Model.StrategicGoals != null)
            {
                @foreach (var goal in Model.StrategicGoals)
                {
                    @* Municipal dashboard styling *@
                    var isSelectedGoal = !string.IsNullOrEmpty(selectedGoal) && goal.Name == selectedGoal;
                    var shouldShow = !string.IsNullOrEmpty(selectedGoal) && goal.Name == selectedGoal;
                
                <div class="col-12 mb-4 goal-section" 
                     data-goal="@goal.Name.Replace(" ", "_")" 
                     style="@(shouldShow ? "" : "display: none;")">
                    <div class="card" style="background: var(--onejax-white); border: 1px solid var(--onejax-border); border-radius: 8px; @(isSelectedGoal ? "border-left: 6px solid var(--onejax-orange);" : "border-left: 4px solid var(--onejax-blue);") box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
                        <div class="card-header" style="background: linear-gradient(135deg, var(--onejax-navy), var(--onejax-blue)); border-bottom: 3px solid var(--onejax-orange);">
                            <div class="row align-items-center">
                                <div class="col-md-8">
                                    <h3 style="color: white; margin: 0;">
                                        @goal.Name @(isSelectedGoal ? "★" : "")
                                    </h3>
                                    <p style="color: rgba(255,255,255,0.8); margin: 0; font-size: 0.9em;">Strategic Initiative | Investment Tracking & Progress</p>
                                </div>
                                <div class="col-md-4 text-end">
                                    @{
                                        var goalMetrics = goal.Metrics ?? new List<GoalMetric>();
                                        var goalProgress = LiveGoalProgress(goalMetrics);
                                    }
                                    <div style="color: white;">
                                        <div style="font-size: 2rem; font-weight: 700;">@Math.Round(goalProgress, 1)%</div>
                                        <small>Overall Progress</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="card-body" style="padding: 2rem;">
                            <div class="row mb-4">
                                <div class="col-md-12">
                                    <div class="progress" style="height: 12px; border-radius: 6px;">
                                        <div class="progress-bar" style="width: @Math.Min(goalProgress, 100)%; background: linear-gradient(90deg, var(--onejax-blue), var(--onejax-green)); border-radius: 6px;" role="progressbar"></div>
                                    </div>
                                    <div class="d-flex justify-content-between mt-2">
                                        <small style="color: var(--onejax-text-muted);">Project Start</small>
                                        <small style="color: var(--onejax-navy); font-weight: 600;">@Math.Round(goalProgress, 1)% Complete</small>
                                        <small style="color: var(--onejax-text-muted);">Target Completion</small>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Metrics Section -->
                            @if (goal.Metrics != null && goal.Metrics.Any() && !(goal.Name.Contains("Identity") || goal.Name.Contains("Value")))
                            {
	                                var isFinancialGoal = goal.Name.Contains("Financial") || goal.Name.Contains("Sustainability");
	                                IEnumerable<GoalMetric> orderedMetrics = isFinancialGoal
	                                    ? goal.Metrics
	                                        .OrderBy(m =>
	                                            ((m.Name.Contains("Fee-for-Service") || m.Name.Contains("Service Income")) ? 1 :
	                                            ((m.Name.Contains("Donor") && m.Name.Contains("Communication") && m.Name.Contains("Satisfaction")) ? 2 :
	                                            ((m.Name.Contains("Donor") && m.Name.Contains("Engagement")) ? 3 :
	                                            ((m.Name.Contains("General Income") || m.Name.Contains("Income Streams") || m.Name.Contains("Diversified Income")) ? 4 : 99)))))
	                                        // Prefer showing the metric row that actually has data when duplicates exist.
	                                        .ThenByDescending(m => m.CurrentValue)
	                                        .ThenBy(m => m.Name)
	                                    : goal.Metrics.AsEnumerable();

	                                <div class="mb-4">
	                                    <h5 style="color:var(--onejax-navy); font-weight: 700; margin-bottom:15px;">Key Metrics</h5>
	                                    <div class="row g-3">
	                                        @{
	                                            // If the database has duplicate metric rows (same "type" with zeros),
	                                            // render the enhanced visualization only once per type.
	                                            var renderedFinancialCards = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
	                                        }
	                                        @if (goal.Name.Contains("Community", StringComparison.OrdinalIgnoreCase))
	                                        {
	                                            var mInterfaith = goal.Metrics.FirstOrDefault(m => (m.Name ?? "").Contains("Interfaith", StringComparison.OrdinalIgnoreCase) && (m.Name ?? "").Contains("Events", StringComparison.OrdinalIgnoreCase));
	                                            var mYouth = goal.Metrics.FirstOrDefault(m => (m.Name ?? "").Contains("Youth", StringComparison.OrdinalIgnoreCase) && (m.Name ?? "").Contains("Attendance", StringComparison.OrdinalIgnoreCase));
	                                            var mSatisfaction = goal.Metrics.FirstOrDefault(m => (m.Name ?? "").Contains("Satisfaction", StringComparison.OrdinalIgnoreCase) && (m.Name ?? "").Contains("Event", StringComparison.OrdinalIgnoreCase))
	                                                ?? goal.Metrics.FirstOrDefault(m => (m.Name ?? "").Contains("Satisfaction", StringComparison.OrdinalIgnoreCase));
	                                            var mPartners = goal.Metrics.FirstOrDefault(m => (m.Name ?? "").Contains("Partner", StringComparison.OrdinalIgnoreCase) && (m.Name ?? "").Contains("Touchpoints", StringComparison.OrdinalIgnoreCase))
	                                                ?? goal.Metrics.FirstOrDefault(m => (m.Name ?? "").Contains("Collaboration", StringComparison.OrdinalIgnoreCase));
	                                            var mFaith = goal.Metrics.FirstOrDefault(m => (m.Name ?? "").Contains("Faith", StringComparison.OrdinalIgnoreCase) && (m.Name ?? "").Contains("Representation", StringComparison.OrdinalIgnoreCase));
	                                            var mClergy = goal.Metrics.FirstOrDefault(m => (m.Name ?? "").Contains("Clergy", StringComparison.OrdinalIgnoreCase) && (m.Name ?? "").Contains("Network", StringComparison.OrdinalIgnoreCase));
	                                            var mDiversity = goal.Metrics.FirstOrDefault(m => (m.Name ?? "").Contains("Diversity", StringComparison.OrdinalIgnoreCase) && (m.Name ?? "").Contains("Participant", StringComparison.OrdinalIgnoreCase));
	                                            var mFirstTime = goal.Metrics.FirstOrDefault(m => (m.Name ?? "").Contains("First-Time", StringComparison.OrdinalIgnoreCase) && (m.Name ?? "").Contains("Participants", StringComparison.OrdinalIgnoreCase));

	                                            decimal parseTarget(string? raw)
	                                            {
	                                                if (string.IsNullOrWhiteSpace(raw)) return 0;
	                                                var clean = raw.Replace("$", "", StringComparison.OrdinalIgnoreCase)
	                                                    .Replace(",", "", StringComparison.OrdinalIgnoreCase)
	                                                    .Replace("%", "", StringComparison.OrdinalIgnoreCase)
	                                                    .Trim();
	                                                return decimal.TryParse(clean, out var v) ? v : 0;
	                                            }

	                                            decimal? targetOrNull(GoalMetric? metric)
	                                            {
	                                                var parsed = parseTarget(metric?.Target);
	                                                return parsed > 0 ? parsed : null;
	                                            }

	                                            string metricStatus(bool hasValue, decimal current, decimal? target, string? fallbackStatus)
	                                            {
	                                                if (!hasValue) return "No entries yet";
	                                                if (target.HasValue && target.Value > 0 && current >= target.Value) return "Target met";
	                                                return string.IsNullOrWhiteSpace(fallbackStatus) ? "Tracking" : fallbackStatus!;
	                                            }

	                                            decimal? bagNullable(string key)
	                                            {
	                                                var raw = ViewData[key];
	                                                if (raw == null) return null;
	                                                if (raw is decimal dec) return dec;
	                                                if (raw is double dbl) return Convert.ToDecimal(dbl);
	                                                if (raw is float flt) return Convert.ToDecimal(flt);
	                                                if (raw is int i) return i;
	                                                if (raw is long l) return l;
	                                                if (raw is short s) return s;
	                                                if (raw is string text && decimal.TryParse(text, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var parsed)) return parsed;
	                                                return null;
	                                            }

	                                            decimal bagNumber(string key)
	                                            {
	                                                return bagNullable(key) ?? 0;
	                                            }

	                                            decimal progressValue(decimal current, decimal? target)
	                                            {
	                                                if (!target.HasValue || target.Value <= 0) return 0;
	                                                return Math.Round(current / target.Value * 100, 1);
	                                            }

	                                            string valueLabel(decimal? value, string format = "0.#", string suffix = "", bool signed = false)
	                                            {
	                                                if (!value.HasValue) return "No data";
	                                                var rendered = value.Value.ToString(format, System.Globalization.CultureInfo.InvariantCulture);
	                                                if (signed && value.Value > 0) rendered = $"+{rendered}";
	                                                return $"{rendered}{suffix}";
	                                            }

	                                            string targetLabel(decimal? target, string format = "0.#", string prefix = "", string suffix = "")
	                                            {
	                                                if (!target.HasValue) return "No target set";
	                                                return $"{prefix}{target.Value.ToString(format, System.Globalization.CultureInfo.InvariantCulture)}{suffix}";
	                                            }

	                                            var youthTarget = targetOrNull(mYouth);
	                                            var partnersTarget = targetOrNull(mPartners);
	                                            var interfaithTarget = targetOrNull(mInterfaith);
	                                            var faithTarget = targetOrNull(mFaith);
	                                            var clergyTarget = targetOrNull(mClergy);
	                                            var diversityTarget = targetOrNull(mDiversity);
	                                            var firstTimeTarget = targetOrNull(mFirstTime);
	                                            var satisfactionTarget = targetOrNull(mSatisfaction);
	                                            var youthValueRaw = bagNullable("CommunityYouthGrowthPercent");
	                                            var satisfactionValueRaw = bagNullable("CommunityEventSatisfactionAvg");
	                                            var firstTimeValueRaw = bagNullable("CommunityFirstTimeRateAvg");
	                                            var faithValueRaw = bagNullable("CommunityFaithPercentMeetingGoal");
	                                            var interfaithValueRaw = bagNullable("CommunityInterfaithEventsCount");
	                                            var partnersValueRaw = bagNullable("CommunityPartnersCurrentCount");
	                                            var clergyValueRaw = bagNullable("CommunityClergyGrowthPercent");
	                                            var diversityValueRaw = bagNullable("CommunityDiversityGrowthPercent");
	                                            var youthValue = youthValueRaw ?? 0;
	                                            var satisfactionValue = satisfactionValueRaw ?? 0;
	                                            var firstTimeValue = firstTimeValueRaw ?? 0;
	                                            var faithValue = faithValueRaw ?? 0;
	                                            var interfaithValue = interfaithValueRaw ?? 0;
	                                            var partnersValue = partnersValueRaw ?? 0;
	                                            var clergyValue = clergyValueRaw ?? 0;
	                                            var diversityValue = diversityValueRaw ?? 0;
	                                            var youthHasValue = youthValueRaw.HasValue;
	                                            var satisfactionHasValue = satisfactionValueRaw.HasValue;
	                                            var firstTimeHasValue = firstTimeValueRaw.HasValue;
	                                            var faithHasValue = faithValueRaw.HasValue;
	                                            var interfaithEntryCount = bagNumber("CommunityInterfaithEntryCount");
	                                            var partnerEntryCount = bagNumber("CommunityPartnerEntryCount");
	                                            var interfaithHasValue = interfaithEntryCount > 0;
	                                            var partnersHasValue = partnerEntryCount > 0;
	                                            var faithEventsMeetingGoal = bagNumber("CommunityFaithEventsMeetingGoal");
	                                            var faithTotalEvents = bagNumber("CommunityFaithTotalEvents");
	                                            var clergyLatestTotal = bagNumber("CommunityClergyLatestTotal");
	                                            var diversityLatestCount = bagNumber("CommunityDiversityLatestCount");
	                                            var firstTimeTotalParticipants = bagNumber("CommunityFirstTimeTotalParticipants");
	                                            var youthProgress = progressValue(youthValue, youthTarget);
	                                            var partnersProgress = progressValue(partnersValue, partnersTarget);
	                                            var interfaithProgress = progressValue(interfaithValue, interfaithTarget);
	                                            var faithProgress = progressValue(faithValue, faithTarget);
	                                            var satisfactionProgress = progressValue(satisfactionValue, satisfactionTarget);
	                                            var diversityProgress = progressValue(diversityValue, diversityTarget);
	                                            var firstTimeProgress = progressValue(firstTimeValue, firstTimeTarget);
	                                            var youthStatusText = metricStatus(youthHasValue, youthValue, youthTarget, mYouth?.Status);
	                                            var partnersStatusText = metricStatus(partnersHasValue, partnersValue, partnersTarget, mPartners?.Status);
	                                            var faithStatusText = metricStatus(faithHasValue, faithValue, faithTarget, mFaith?.Status);
	                                            var satisfactionStatusText = metricStatus(satisfactionHasValue, satisfactionValue, satisfactionTarget, mSatisfaction?.Status);
	                                            var diversityStatusText = metricStatus(diversityValueRaw.HasValue, diversityValue, diversityTarget, mDiversity?.Status);
	                                            var firstTimeStatusText = metricStatus(firstTimeHasValue, firstTimeValue, firstTimeTarget, mFirstTime?.Status);

	                                            var latestPartners = ViewBag.CommunityPartnersLatest as IEnumerable<dynamic>;
	                                            var anyLatestPartners = latestPartners != null && latestPartners.Any();

	                                            <style>
	                                                .community-pulse-shell {
	                                                    --community-ink: #17324d;
	                                                    --community-teal: #17838c;
	                                                    --community-sea: #2aa6a4;
	                                                    --community-coral: #ef7d57;
	                                                    --community-sand: #f4c98a;
	                                                    --community-foam: #edf8f6;
	                                                    --community-mist: #f7fbfd;
	                                                    --community-stroke: rgba(23, 50, 77, 0.10);
	                                                    --community-soft-shadow: 0 18px 40px rgba(23, 50, 77, 0.10);
	                                                }

	                                                .community-pulse-shell .community-panel {
	                                                    background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(247,251,253,0.98));
	                                                    border: 1px solid var(--community-stroke);
	                                                    border-radius: 24px;
	                                                    box-shadow: var(--community-soft-shadow);
	                                                    padding: 1.4rem;
	                                                    display: flex;
	                                                    flex-direction: column;
	                                                    gap: 1rem;
	                                                    min-height: 100%;
	                                                    overflow: hidden;
	                                                }

	                                                .community-pulse-shell .community-hero {
	                                                    background:
	                                                        radial-gradient(circle at top left, rgba(42, 166, 164, 0.16), transparent 34%),
	                                                        radial-gradient(circle at right center, rgba(239, 125, 87, 0.10), transparent 30%),
	                                                        linear-gradient(180deg, #fbfeff, #eef8f6);
	                                                }

	                                                .community-pulse-shell .community-relationships {
	                                                    background:
	                                                        radial-gradient(circle at top right, rgba(23, 131, 140, 0.18), transparent 32%),
	                                                        linear-gradient(180deg, #17324d, #214d62);
	                                                    color: white;
	                                                }

	                                                .community-pulse-shell .community-representation {
	                                                    background:
	                                                        radial-gradient(circle at top left, rgba(244, 201, 138, 0.26), transparent 34%),
	                                                        linear-gradient(180deg, #fffaf3, #fffdf8);
	                                                }

	                                                .community-pulse-shell .community-network {
	                                                    background:
	                                                        radial-gradient(circle at bottom right, rgba(42, 166, 164, 0.14), transparent 36%),
	                                                        linear-gradient(180deg, #ffffff, #f8fcfb);
	                                                }

	                                                .community-pulse-shell .community-panel-header {
	                                                    display: flex;
	                                                    justify-content: space-between;
	                                                    gap: 1rem;
	                                                    align-items: flex-start;
	                                                    flex-wrap: wrap;
	                                                }

	                                                .community-pulse-shell .community-kicker {
	                                                    display: inline-flex;
	                                                    align-items: center;
	                                                    gap: 0.4rem;
	                                                    padding: 0.35rem 0.75rem;
	                                                    border-radius: 999px;
	                                                    background: rgba(23, 131, 140, 0.12);
	                                                    color: var(--community-teal);
	                                                    font-size: 0.75rem;
	                                                    font-weight: 800;
