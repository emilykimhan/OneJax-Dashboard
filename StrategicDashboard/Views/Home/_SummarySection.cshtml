@model DashboardViewModel
@using OneJaxDashboard.Models
@{
    var selectedGoal = ViewData["SelectedGoal"]?.ToString() ?? string.Empty;
    var canManageData = ViewData["CanManageData"] as bool? ?? false;

    decimal LiveGoalProgress(IEnumerable<GoalMetric>? metrics)
    {
        var liveMetrics = (metrics ?? Enumerable.Empty<GoalMetric>())
            .Where(m => !string.Equals(m.Status, "Planning", StringComparison.OrdinalIgnoreCase))
            .Where(m => !string.IsNullOrWhiteSpace(m.Target))
            .Where(m =>
            {
                var clean = (m.Target ?? string.Empty).Replace("$", "").Replace(",", "").Replace("%", "").Trim();
                return decimal.TryParse(clean, out var target) && target > 0;
            })
            .Select(m =>
            {
                var clean = (m.Target ?? string.Empty).Replace("$", "").Replace(",", "").Replace("%", "").Trim();
                decimal.TryParse(clean, out var target);
                return target > 0 ? Math.Min((m.CurrentValue / target) * 100, 100) : 0;
            })
            .ToList();

        return liveMetrics.Any() ? Math.Round(liveMetrics.Average(), 1) : 0;
    }

    var overallProgress = Model.StrategicGoals?.SelectMany(g => g.Metrics ?? new List<GoalMetric>()).Any() == true
        ? Model.StrategicGoals.Average(g => LiveGoalProgress(g.Metrics))
        : 0;
    var totalEvents = Model.StrategicGoals?.SelectMany(g => g.Events ?? new List<Event>()).Count() ?? 0;
    var avgProgress = Model.StrategicGoals?.Any() == true ? Model.StrategicGoals.Average(g => LiveGoalProgress(g.Metrics)) : 0;
    var publicEventsCount = totalEvents;
    var overallDashboardProgress =
        (Model.Charts.GoalProgress.OrganizationalProgress +
         Model.Charts.GoalProgress.FinancialProgress +
         Model.Charts.GoalProgress.IdentityProgress +
         Model.Charts.GoalProgress.CommunityProgress) / 4m;
}

<div class="col-12 mb-4 goal-section" data-goal="summary" style="@(string.IsNullOrEmpty(selectedGoal) ? "" : "display: none;")">
    <div class="card" style="background: var(--onejax-white); border: 1px solid var(--onejax-border); border-radius: 8px; border-left: 4px solid var(--onejax-blue); box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
        <div class="card-header" style="background: linear-gradient(135deg, var(--onejax-navy), var(--onejax-blue)); border-bottom: 3px solid var(--onejax-orange);">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h3 style="color: white; margin: 0;">
                        Strategic Overview Summary
                    </h3>
                    <p style="color: rgba(255,255,255,0.8); margin: 0; font-size: 0.9em;">All Strategic Goals | Consolidated Progress View</p>
                </div>
                <div class="col-md-4 text-end">
                    <div style="color: white;">
                        <div style="font-size: 2rem; font-weight: 700;">@Math.Round(overallProgress, 1)%</div>
                        <small>Total Progress</small>
                    </div>
                </div>
            </div>
        </div>
        <div class="card-body" style="padding: 2rem;">
            <div class="row mb-4">
                <div class="col-12 text-center">
                    <h4 style="color: var(--onejax-navy); font-weight: 600; margin-bottom: 0.5rem;">Dashboard Analytics</h4>
                    <p style="color: var(--onejax-text-muted); margin-bottom: 2rem;">Visual overview of your organizational progress</p>
                </div>
            </div>

            <div class="row mb-5">
                @if (Model.StrategicGoals != null)
                {
                    @foreach (var summaryGoal in Model.StrategicGoals)
                    {
                        var goalProgress = LiveGoalProgress(summaryGoal.Metrics);
                        <div class="col-md-6 col-lg-3 mb-3">
                            <div class="card hover-card" style="background: var(--onejax-white); border: 1px solid var(--onejax-border); border-radius: 12px; cursor: pointer; transition: all 0.3s ease;" onclick="switchTab('@summaryGoal.Name.Replace(" ", "_")', null, event)">
                                <div class="card-body text-center" style="padding: 1.5rem;">
                                    <h6 style="color: var(--onejax-navy); margin-bottom: 1rem; font-weight: 600;">@summaryGoal.Name</h6>
                                    <div style="font-size: 1.8rem; font-weight: 700; color: var(--onejax-navy); margin-bottom: 1rem;">@Math.Round(goalProgress, 1)%</div>
                                    <div class="progress" style="height: 8px; border-radius: 4px; background: rgba(59, 130, 246, 0.1);">
                                        <div class="progress-bar" style="width: @Math.Min(goalProgress, 100)%; background: var(--gradient-secondary); border-radius: 4px;"></div>
                                    </div>
                                    <small style="color: var(--onejax-text-muted); margin-top: 0.5rem; display: block;">
                                        @(summaryGoal.Metrics?.Count() ?? 0) Metrics • @(summaryGoal.Events?.Count() ?? 0) Events
                                    </small>
                                    <div style="margin-top: 0.5rem; font-size: 0.8rem; color: var(--onejax-blue);">
                                        Click to view details →
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>

            <div class="row">
                <div class="col-md-6 mb-4">
                    <div class="card" style="border-radius: 12px; border: 1px solid var(--onejax-border); box-shadow: 0 2px 8px rgba(0,0,0,0.05);">
                        <div class="card-header" style="background: linear-gradient(135deg, var(--onejax-navy), var(--onejax-blue)); color: white; border-radius: 12px 12px 0 0;">
                            <h6 class="mb-0">Strategic Goal Progress</h6>
                        </div>
                        <div class="card-body">
                            <canvas id="progressChart" width="400" height="250"></canvas>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 mb-4">
                    <div class="card" style="border-radius: 12px; border: 1px solid var(--onejax-border); box-shadow: 0 2px 8px rgba(0,0,0,0.05);">
                        <div class="card-header" style="background: linear-gradient(135deg, var(--onejax-green), var(--onejax-blue)); color: white; border-radius: 12px 12px 0 0;">
                            <h6 class="mb-0">Data Activity Summary</h6>
                        </div>
                        <div class="card-body">
                            <canvas id="activityChart" width="400" height="250"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-8 mb-4">
                    <div class="card" style="border-radius: 12px; border: 1px solid var(--onejax-border); box-shadow: 0 2px 8px rgba(0,0,0,0.05);">
                        <div class="card-header" style="background: linear-gradient(135deg, var(--onejax-orange), #ea580c); color: white; border-radius: 12px 12px 0 0;">
                            <h6 class="mb-0">📈 Monthly Progress Trends</h6>
                        </div>
                        <div class="card-body">
                            <canvas id="trendsChart" width="600" height="300"></canvas>
                        </div>
                    </div>
                </div>

                <div class="col-md-4 mb-4">
                    <div class="card" style="border-radius: 12px; border: 1px solid var(--onejax-border); box-shadow: 0 2px 8px rgba(0,0,0,0.05);">
                        <div class="card-header" style="background: linear-gradient(135deg, #8B5CF6, #7C3AED); color: white; border-radius: 12px 12px 0 0;">
                            <h6 class="mb-0">📊 Metrics Distribution</h6>
                        </div>
                        <div class="card-body">
                            <canvas id="metricsTypeChart" width="300" height="300"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-12 mb-4">
                    <div class="card" style="border-radius: 12px; border: 1px solid var(--onejax-border); box-shadow: 0 2px 8px rgba(0,0,0,0.05);">
                        <div class="card-header" style="background: linear-gradient(135deg, #10B981, #059669); color: white; border-radius: 12px 12px 0 0;">
                            <h6 class="mb-0">🎯 Goal Performance Radar</h6>
                        </div>
                        <div class="card-body">
                            <canvas id="radarChart" width="400" height="300"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mb-4">
                <style>
                    .summary-static-card {
                        cursor: default !important;
                    }

                    .summary-static-card:hover {
                        transform: none !important;
                        box-shadow: inherit !important;
                    }

                    .summary-static-card .card-body {
                        min-height: 210px;
                    }

                    .summary-link-card {
                        cursor: pointer;
                    }

                    .summary-link-card:hover {
                        transform: translateY(-2px);
                        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.12);
                    }

                    .summary-link-card .card-body {
                        min-height: 210px;
                    }

                    .onejax-overall-gauge-wrap {
                        position: relative;
                        width: 140px;
                        height: 140px;
                        margin: 0 auto;
                    }

                    .onejax-overall-gauge-wrap canvas {
                        width: 100% !important;
                        height: 100% !important;
                        display: block;
                    }

                    .onejax-overall-gauge-text {
                        position: absolute;
                        left: 50%;
                        top: 50%;
                        transform: translate(-50%, -50%);
                        font-weight: 800;
                        font-size: 2rem;
                        letter-spacing: -0.02em;
                        color: var(--onejax-navy);
                    }
                </style>
                <div class="col-12 mb-3">
                    <h5 style="color: var(--onejax-navy); font-weight: 600; margin-bottom: 1rem;">
                        <i class="fas fa-rocket"></i> Quick Access & KPIs
                    </h5>
                </div>

                <div class="col-md-3 mb-3">
                    <div class="card hover-card metric-card-creative" style="border-radius: 12px; border: 1px solid var(--onejax-border); cursor: pointer; transition: all 0.3s ease; background: linear-gradient(135deg, var(--onejax-blue), var(--onejax-navy));" onclick="switchTab('Community_Engagement', null, event)">
                        <div class="card-body text-center" style="padding: 1.5rem; color: white;">
                            <div class="mb-3">
                                <i class="fas fa-users" style="font-size: 2.5rem;"></i>
                            </div>
                            <h6 class="card-title" style="font-weight: 600; margin-bottom: 0.5rem;">Community Events</h6>
                            <div style="font-size: 2rem; font-weight: 700; margin-bottom: 0.5rem;">@totalEvents</div>
                            <small style="opacity: 0.8;">Total Strategic Events</small>
                        </div>
                    </div>
                </div>

                <div class="col-md-3 mb-3">
                    <div class="card hover-card metric-card-creative" style="border-radius: 12px; border: 1px solid var(--onejax-border); cursor: pointer; transition: all 0.3s ease; background: linear-gradient(135deg, var(--onejax-green), #059669);" onclick="window.location.href='@(canManageData ? "/MediaPlacements" : "/Account/Login")'">
                        <div class="card-body text-center" style="padding: 1.5rem; color: white;">
                            <div class="mb-3">
                                <i class="fas fa-newspaper" style="font-size: 2.5rem;"></i>
                            </div>
                            <h6 class="card-title" style="font-weight: 600; margin-bottom: 0.5rem;">Media Coverage</h6>
                            <div style="font-size: 2rem; font-weight: 700; margin-bottom: 0.5rem;">@Model.Summary.TotalMediaPlacements</div>
                            <small style="opacity: 0.8;">Media Placements</small>
                        </div>
                    </div>
                </div>

                <div class="col-md-3 mb-3">
                    <div class="card hover-card metric-card-creative" style="border-radius: 12px; border: 1px solid var(--onejax-border); cursor: pointer; transition: all 0.3s ease; background: linear-gradient(135deg, var(--onejax-orange), #ea580c);" onclick="switchTab('Financial_Sustainability', null, event)">
                        <div class="card-body text-center" style="padding: 1.5rem; color: white;">
                            <div class="mb-3">
                                <i class="fas fa-dollar-sign" style="font-size: 2.5rem;"></i>
                            </div>
                            <h6 class="card-title" style="font-weight: 600; margin-bottom: 0.5rem;">Staff Surveys</h6>
                            <div style="font-size: 2rem; font-weight: 700; margin-bottom: 0.5rem;">@Model.Summary.TotalStaffSurveys</div>
                            <small style="opacity: 0.8;">Survey Responses</small>
                        </div>
                    </div>
                </div>

                <div class="col-md-3 mb-3">
                    <div class="card hover-card metric-card-creative" style="border-radius: 12px; border: 1px solid var(--onejax-border); cursor: pointer; transition: all 0.3s ease; background: linear-gradient(135deg, #8B5CF6, #7C3AED);" onclick="switchTab('Organizational_Building', null, event)">
                        <div class="card-body text-center" style="padding: 1.5rem; color: white;">
                            <div class="mb-3">
                                <i class="fas fa-chart-line" style="font-size: 2.5rem;"></i>
                            </div>
                            <h6 class="card-title" style="font-weight: 600; margin-bottom: 0.5rem;">Growth Metrics</h6>
                            <div style="font-size: 2rem; font-weight: 700; margin-bottom: 0.5rem;">@Math.Round(avgProgress, 0)%</div>
                            <small style="opacity: 0.8;">Avg Progress Rate</small>
                        </div>
                    </div>
                </div>

                <div class="col-md-4 mb-3">
                    <div class="card metric-card-creative summary-link-card h-100" style="border-radius: 12px; border: 1px solid var(--onejax-border); transition: all 0.3s ease;">
                        <div class="card-body text-center d-flex flex-column justify-content-center h-100" style="padding: 1.5rem;">
                            <div class="mb-3">
                                <i class="fas fa-calendar-alt" style="font-size: 2.5rem; color: var(--onejax-blue);"></i>
                            </div>
                            <h6 class="card-title" style="color: var(--onejax-navy); font-weight: 600; margin-bottom: 0.5rem;">Public Events</h6>
                            <p class="card-text text-muted" style="font-size: 0.9rem; margin-bottom: 1rem;">View upcoming initiatives across the four strategic goals</p>
                            <div class="d-flex justify-content-center align-items-center">
                                <span class="badge" style="background: linear-gradient(135deg, var(--onejax-blue), var(--onejax-navy)); color: white; font-size: 0.75rem;">
                                    @publicEventsCount Events
                                </span>
                            </div>
                            <a href="/Public/Events" class="stretched-link" aria-label="View public events"></a>
                        </div>
                    </div>
                </div>

                <div class="col-md-4 mb-3">
                    <div class="card metric-card-creative summary-static-card h-100" style="border-radius: 12px; border: 1px solid var(--onejax-border); transition: all 0.3s ease;">
                        <div class="card-body text-center d-flex flex-column justify-content-center h-100" style="padding: 1.5rem; gap: 0.65rem;">
                            <h6 class="card-title" style="color: var(--onejax-navy); font-weight: 700; margin: 0;">Overall Progress</h6>
                            <div class="onejax-overall-gauge-wrap">
                                <canvas id="performanceGauge"></canvas>
                                <div class="onejax-overall-gauge-text">@Math.Round(overallDashboardProgress, 1)%</div>
                            </div>
                            <p class="card-text text-muted" style="font-size: 0.95rem; margin: 0;">Average progress across all strategic goals</p>
                        </div>
                    </div>
                </div>

                <div class="col-md-4 mb-3">
                    <div class="card metric-card-creative summary-link-card h-100" style="border-radius: 12px; border: 1px solid var(--onejax-border); transition: all 0.3s ease;">
                        <div class="card-body text-center d-flex flex-column justify-content-center h-100" style="padding: 1.5rem;">
                            <div class="mb-3">
                                <i class="fas fa-globe" style="font-size: 2.5rem; color: var(--onejax-orange);"></i>
                            </div>
                            <h6 class="card-title" style="color: var(--onejax-navy); font-weight: 600; margin-bottom: 0.5rem;">OneJax Website</h6>
                            <p class="card-text text-muted" style="font-size: 0.9rem; margin-bottom: 1rem;">Visit our main organization website</p>
                            <div class="d-flex justify-content-center align-items-center">
                                <span class="badge" style="background: linear-gradient(135deg, var(--onejax-orange), var(--onejax-navy)); color: white; font-size: 0.75rem;">
                                    <i class="fas fa-external-link-alt"></i> Visit Site
                                </span>
                            </div>
                            <a href="https://onejax.org" target="_blank" rel="noopener noreferrer" class="stretched-link" aria-label="Visit OneJax website"></a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mt-3">
                <div class="col-12 text-center">
                    <button onclick="exportDashboard()" class="btn btn-outline-primary">
                        <i class="fas fa-download"></i> Export Dashboard Data
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
