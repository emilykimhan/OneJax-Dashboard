@model DashboardViewModel
@using OneJaxDashboard.Models
@{
    var selectedGoal = ViewData["SelectedGoal"]?.ToString() ?? string.Empty;
    var canManageData = ViewData["CanManageData"] as bool? ?? false;
    var activeFiscalYear = ViewBag.ActiveFiscalYearLabel?.ToString() ?? string.Empty;
    var fiscalYearLabel = string.IsNullOrWhiteSpace(activeFiscalYear) ? "this view" : activeFiscalYear;

    IEnumerable<GoalMetric> ReportingMetrics(IEnumerable<GoalMetric>? metrics)
    {
        return DashboardMetricRules.ReportingMetrics(metrics, activeFiscalYear);
    }

    IEnumerable<GoalMetric> ScheduledMetrics(IEnumerable<GoalMetric>? metrics)
    {
        return DashboardMetricRules.ScheduledMetrics(metrics, activeFiscalYear);
    }

    decimal ViewBagNumber(string key)
    {
        var raw = ViewData[key];
        if (raw == null) return 0;
        if (raw is decimal dec) return dec;
        if (raw is double dbl) return Convert.ToDecimal(dbl);
        if (raw is float flt) return Convert.ToDecimal(flt);
        if (raw is int i) return i;
        if (raw is long l) return l;
        if (raw is short s) return s;
        if (raw is string text && decimal.TryParse(text, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var parsed)) return parsed;
        return 0;
    }

    bool HasEarlyCommunityData(GoalMetric metric)
    {
        var name = metric.Name ?? string.Empty;
        if (MetricTrackingSchedule.IsScheduledForFiscalYear(name, activeFiscalYear)) return false;

        return (name.Contains("Diversity", StringComparison.OrdinalIgnoreCase) && ViewBagNumber("CommunityDiversityEntryCount") > 0)
            || (name.Contains("First-Time", StringComparison.OrdinalIgnoreCase) && ViewBagNumber("CommunityFirstTimeEntryCount") > 0);
    }

    bool CountsTowardTopSummary(GoalMetric metric)
    {
        return DashboardMetricRules.CountsTowardOverallProgress(metric);
    }

    decimal LiveGoalProgress(IEnumerable<GoalMetric>? metrics)
    {
        return DashboardMetricRules.CalculateGoalProgress(metrics, activeFiscalYear);
    }

    bool MetricMeetsGoal(GoalMetric metric)
    {
        return DashboardMetricRules.IsMetricAtTarget(metric);
    }

    var goalSummaries = (Model.StrategicGoals ?? new List<StrategicGoal>())
        .Select(g => new
            {
                Goal = g,
                ScheduledMetricCount = ScheduledMetrics(g.Metrics).Count(),
                ReportingMetricCount = ReportingMetrics(g.Metrics).Count(),
                EarlyDataMetricCount = (g.Metrics ?? new List<GoalMetric>()).Count(HasEarlyCommunityData),
                Progress = LiveGoalProgress(g.Metrics)
            })
        .ToList();

    var goalsWithReporting = goalSummaries.Where(g => g.ReportingMetricCount > 0).ToList();
    var totalMetrics = goalSummaries.Sum(g => g.ScheduledMetricCount);
    var totalReportingMetrics = goalSummaries.Sum(g => g.ReportingMetricCount);
    var summaryEligibleMetrics = (Model.StrategicGoals ?? new List<StrategicGoal>())
        .SelectMany(g => ReportingMetrics(g.Metrics))
        .Where(CountsTowardTopSummary)
        .ToList();
    var totalMetricsMeetingGoal = summaryEligibleMetrics
        .Count(MetricMeetsGoal);
    var totalEligibleMetrics = summaryEligibleMetrics.Count;
    var overallProgress = totalEligibleMetrics > 0
        ? Math.Round((decimal)totalMetricsMeetingGoal / totalEligibleMetrics * 100, 1)
        : 0;
    var totalEvents = Model.StrategicGoals?.SelectMany(g => g.Events ?? new List<Event>()).Count() ?? 0;
    var publicEventsCount = totalEvents;
    var overallDashboardProgress = goalsWithReporting.Any()
        ? Math.Round(goalsWithReporting.Average(g => g.Progress), 1)
        : 0;
}

<div class="col-12 mb-4 goal-section" data-goal="summary" style="@(string.IsNullOrEmpty(selectedGoal) ? "" : "display: none;")">
    <div class="card" style="background: var(--onejax-white); border: 1px solid var(--onejax-border); border-radius: 8px; border-left: 4px solid var(--onejax-blue); box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
        <div class="card-header" style="background: linear-gradient(135deg, var(--onejax-navy), var(--onejax-blue)); border-bottom: 3px solid var(--onejax-orange);">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h3 style="color: white; margin: 0;">
                        Strategic Overview Summary
                    </h3>
                    <p style="color: rgba(255,255,255,0.8); margin: 0; font-size: 0.9em;">All Strategic Goals | Consolidated Progress View</p>
                </div>
                <div class="col-md-4 text-end">
                    <div style="color: white;">
                        <div style="font-size: 2rem; font-weight: 700;">@Math.Round(overallProgress, 1)%</div>
                        <small>Metrics Meeting Goal</small>
                        <div style="font-size: 0.8rem; opacity: 0.85;">
                            @if (totalEligibleMetrics > 0)
                            {
                                @:@totalMetricsMeetingGoal of @totalEligibleMetrics eligible metrics met goal in @fiscalYearLabel
                            }
                            else if (totalMetrics > 0)
                            {
                                @:No reporting metrics yet in @fiscalYearLabel
                            }
                            else
                            {
                                @:No scheduled metrics in @fiscalYearLabel
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="card-body" style="padding: 2rem;">
            <div class="row mb-4">
                <div class="col-12 text-center">
                    <h4 style="color: var(--onejax-navy); font-weight: 600; margin-bottom: 0.5rem;">Dashboard Analytics</h4>
                    <p style="color: var(--onejax-text-muted); margin-bottom: 1rem;">Visual overview of your organizational progress</p>
                    <details style="display: inline-block; text-align: left; max-width: 760px;">
                        <summary style="list-style: none; cursor: pointer; display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.55rem 0.9rem; border-radius: 999px; border: 1px solid rgba(15, 61, 87, 0.14); background: linear-gradient(135deg, rgba(15, 61, 87, 0.05), rgba(54, 163, 189, 0.08)); color: var(--onejax-navy); font-weight: 700; box-shadow: 0 8px 18px rgba(15, 61, 87, 0.08);">
                            <span style="display: inline-flex; width: 1.5rem; height: 1.5rem; border-radius: 999px; align-items: center; justify-content: center; background: var(--onejax-navy); color: white; font-size: 0.85rem;">?</span>
                            <span>How percentages work</span>
                        </summary>
                        <div style="margin-top: 0.85rem; background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(246,250,252,0.98)); border: 1px solid rgba(15, 61, 87, 0.1); border-radius: 16px; padding: 1rem 1.15rem; box-shadow: 0 16px 28px rgba(15, 61, 87, 0.08);">
                            <div style="font-weight: 700; color: var(--onejax-navy); margin-bottom: 0.45rem;">Goal Progress</div>
                            <div style="color: var(--onejax-text-muted); font-size: 0.95rem; line-height: 1.55;">
                                Each goal percentage uses the metrics scheduled for @fiscalYearLabel. If the same metric continues across multiple fiscal years, this summary uses only the data entered for @fiscalYearLabel, so prior-year results are not combined into this year's percentage.
                            </div>
                            <div style="font-weight: 700; color: var(--onejax-navy); margin: 0.85rem 0 0.45rem;">Metrics Meeting Goal</div>
                            <div style="color: var(--onejax-text-muted); font-size: 0.95rem; line-height: 1.55;">
                                The top-right <strong>Metrics Meeting Goal</strong> number is different: it shows how many reporting metrics have already met their target in @fiscalYearLabel.
                            </div>
                            <div style="font-weight: 700; color: var(--onejax-navy); margin: 0.85rem 0 0.45rem;">Year-to-Year Tracking</div>
                            <div style="color: var(--onejax-text-muted); font-size: 0.95rem; line-height: 1.55;">
                                A metric can stay on the dashboard year after year, but each fiscal year should have its own entry or filtered source data. This keeps the public percentages tied to the year selected above instead of building cumulatively over time.
                            </div>
                        </div>
                    </details>
                </div>
            </div>

            <div class="row mb-5">
                @if (goalSummaries.Any())
                {
                    @foreach (var summaryGoal in goalSummaries)
                    {
                            var goalProgress = summaryGoal.Progress;
                            var hasReportingMetrics = summaryGoal.ReportingMetricCount > 0;
                            var hasScheduledMetrics = summaryGoal.ScheduledMetricCount > 0;
                            var hasEarlyData = summaryGoal.EarlyDataMetricCount > 0;
                            var summaryValueText = hasReportingMetrics
                                ? $"{Math.Round(goalProgress, 1)}%"
                                : hasEarlyData ? "0%" : hasScheduledMetrics ? "Awaiting data" : "No metrics";
                            var reportingText = hasReportingMetrics
                                ? $"{summaryGoal.ReportingMetricCount} of {summaryGoal.ScheduledMetricCount} metrics reporting"
                                : hasEarlyData
                                    ? $"0 of {summaryGoal.ScheduledMetricCount} reporting; {summaryGoal.EarlyDataMetricCount} future metric{(summaryGoal.EarlyDataMetricCount == 1 ? "" : "s")} logged"
                                : hasScheduledMetrics
                                    ? $"0 of {summaryGoal.ScheduledMetricCount} metrics reporting"
                                    : $"No metrics scheduled in {fiscalYearLabel}";
                            <div class="col-md-6 col-lg-3 mb-3">
                            <div class="card hover-card" style="background: var(--onejax-white); border: 1px solid var(--onejax-border); border-radius: 12px; cursor: pointer; transition: all 0.3s ease;" onclick="switchTab('@summaryGoal.Goal.Name.Replace(" ", "_")', null, event)">
                                <div class="card-body text-center" style="padding: 1.5rem;">
                                    <h6 style="color: var(--onejax-navy); margin-bottom: 1rem; font-weight: 600;">@summaryGoal.Goal.Name</h6>
                                    <div style="font-size: 1.8rem; font-weight: 700; color: var(--onejax-navy); margin-bottom: 1rem;">@summaryValueText</div>
                                    <div class="progress" style="height: 8px; border-radius: 4px; background: rgba(59, 130, 246, 0.1);">
                                        <div class="progress-bar" style="width: @Math.Min(goalProgress, 100)%; background: var(--gradient-secondary); border-radius: 4px;"></div>
                                    </div>
                                    <small style="color: var(--onejax-text-muted); margin-top: 0.5rem; display: block;">
                                        @reportingText
                                    </small>
                                    <small style="color: var(--onejax-text-muted); margin-top: 0.15rem; display: block;">
                                        @(summaryGoal.Goal.Events?.Count() ?? 0) Events
                                    </small>
                                    <div style="margin-top: 0.5rem; font-size: 0.8rem; color: var(--onejax-blue);">
                                        Click to view details →
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>

            <div class="row">
                <div class="col-md-6 mb-4">
                    <div class="card" style="border-radius: 12px; border: 1px solid var(--onejax-border); box-shadow: 0 2px 8px rgba(0,0,0,0.05);">
                        <div class="card-header" style="background: linear-gradient(135deg, var(--onejax-navy), var(--onejax-blue)); color: white; border-radius: 12px 12px 0 0;">
                            <h6 class="mb-0">Strategic Goal Progress</h6>
                        </div>
                        <div class="card-body">
                            <canvas id="progressChart" width="400" height="250"></canvas>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 mb-4">
                    <div class="card" style="border-radius: 12px; border: 1px solid var(--onejax-border); box-shadow: 0 2px 8px rgba(0,0,0,0.05);">
                        <div class="card-header" style="background: linear-gradient(135deg, var(--onejax-green), var(--onejax-blue)); color: white; border-radius: 12px 12px 0 0;">
                            <h6 class="mb-0">Data Activity Summary</h6>
                        </div>
                        <div class="card-body">
                            <canvas id="activityChart" width="400" height="250"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-8 mb-4">
                    <div class="card" style="border-radius: 12px; border: 1px solid var(--onejax-border); box-shadow: 0 2px 8px rgba(0,0,0,0.05);">
                        <div class="card-header" style="background: linear-gradient(135deg, var(--onejax-orange), #ea580c); color: white; border-radius: 12px 12px 0 0;">
                            <h6 class="mb-0">📈 Monthly Progress Trends</h6>
                        </div>
                        <div class="card-body">
                            <canvas id="trendsChart" width="600" height="300"></canvas>
                        </div>
                    </div>
                </div>

                <div class="col-md-4 mb-4">
                    <div class="card" style="border-radius: 12px; border: 1px solid var(--onejax-border); box-shadow: 0 2px 8px rgba(0,0,0,0.05);">
                        <div class="card-header" style="background: linear-gradient(135deg, #8B5CF6, #7C3AED); color: white; border-radius: 12px 12px 0 0;">
                            <h6 class="mb-0">📊 Metrics Distribution</h6>
                        </div>
                        <div class="card-body">
                            <canvas id="metricsTypeChart" width="300" height="300"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-12 mb-4">
                    <div class="card" style="border-radius: 12px; border: 1px solid var(--onejax-border); box-shadow: 0 2px 8px rgba(0,0,0,0.05);">
                        <div class="card-header" style="background: linear-gradient(135deg, #10B981, #059669); color: white; border-radius: 12px 12px 0 0;">
                            <h6 class="mb-0">🎯 Goal Performance Radar</h6>
                        </div>
                        <div class="card-body">
                            <canvas id="radarChart" width="400" height="300"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mb-4">
                <style>
                    .summary-static-card {
                        cursor: default !important;
                    }

                    .summary-static-card:hover {
                        transform: none !important;
                        box-shadow: inherit !important;
                    }

                    .summary-static-card .card-body {
                        min-height: 210px;
                    }

                    .summary-link-card {
                        cursor: pointer;
                    }

                    .summary-link-card:hover {
                        transform: translateY(-2px);
                        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.12);
                    }

                    .summary-link-card .card-body {
                        min-height: 210px;
                    }

                    .onejax-overall-gauge-wrap {
                        position: relative;
                        width: 140px;
                        height: 140px;
                        margin: 0 auto;
                    }

                    .onejax-overall-gauge-wrap canvas {
                        width: 100% !important;
                        height: 100% !important;
                        display: block;
                    }

                    .onejax-overall-gauge-text {
                        position: absolute;
                        left: 50%;
                        top: 50%;
                        transform: translate(-50%, -50%);
                        font-weight: 800;
                        font-size: 2rem;
                        letter-spacing: -0.02em;
                        color: var(--onejax-navy);
                    }
                </style>
                <div class="col-md-4 mb-3">
                    <div class="card metric-card-creative summary-link-card h-100" style="border-radius: 12px; border: 1px solid var(--onejax-border); transition: all 0.3s ease;">
                        <div class="card-body text-center d-flex flex-column justify-content-center h-100" style="padding: 1.5rem;">
                            <div class="mb-3">
                                <i class="fas fa-calendar-alt" style="font-size: 2.5rem; color: var(--onejax-blue);"></i>
                            </div>
                            <h6 class="card-title" style="color: var(--onejax-navy); font-weight: 600; margin-bottom: 0.5rem;">@(canManageData ? "View Events" : "Public Events")</h6>
                            <p class="card-text text-muted" style="font-size: 0.9rem; margin-bottom: 1rem;">@(canManageData ? "Open the full events view for strategic planning and tracking" : "View upcoming initiatives across the four strategic goals")</p>
                            <div class="d-flex justify-content-center align-items-center">
                                <span class="badge" style="background: linear-gradient(135deg, var(--onejax-blue), var(--onejax-navy)); color: white; font-size: 0.75rem;">
                                    @publicEventsCount Events
                                </span>
                            </div>
                            <a href="@(canManageData ? "/Strategy/ViewEvents" : "/Public/Events")"
                               class="stretched-link"
                               aria-label="@(canManageData ? "View events" : "View public events")"></a>
                        </div>
                    </div>
                </div>

                <div class="col-md-4 mb-3">
                    <div class="card metric-card-creative summary-static-card h-100" style="border-radius: 12px; border: 1px solid var(--onejax-border); transition: all 0.3s ease;">
                        <div class="card-body text-center d-flex flex-column justify-content-center h-100" style="padding: 1.5rem; gap: 0.65rem;">
                            <h6 class="card-title" style="color: var(--onejax-navy); font-weight: 700; margin: 0;">Overall Progress</h6>
                            <div class="onejax-overall-gauge-wrap">
                                <canvas id="performanceGauge"></canvas>
                                <div class="onejax-overall-gauge-text">@Math.Round(overallDashboardProgress, 1)%</div>
                            </div>
                            <p class="card-text text-muted" style="font-size: 0.95rem; margin: 0;">Average progress across all strategic goals</p>
                        </div>
                    </div>
                </div>

                <div class="col-md-4 mb-3">
                    <div class="card metric-card-creative summary-link-card h-100" style="border-radius: 12px; border: 1px solid var(--onejax-border); transition: all 0.3s ease;">
                        <div class="card-body text-center d-flex flex-column justify-content-center h-100" style="padding: 1.5rem;">
                            <div class="mb-3">
                                <i class="fas fa-globe" style="font-size: 2.5rem; color: var(--onejax-orange);"></i>
                            </div>
                            <h6 class="card-title" style="color: var(--onejax-navy); font-weight: 600; margin-bottom: 0.5rem;">OneJax Website</h6>
                            <p class="card-text text-muted" style="font-size: 0.9rem; margin-bottom: 1rem;">Visit our main organization website</p>
                            <div class="d-flex justify-content-center align-items-center">
                                <span class="badge" style="background: linear-gradient(135deg, var(--onejax-orange), var(--onejax-navy)); color: white; font-size: 0.75rem;">
                                    <i class="fas fa-external-link-alt"></i> Visit Site
                                </span>
                            </div>
                            <a href="https://onejax.org" target="_blank" rel="noopener noreferrer" class="stretched-link" aria-label="Visit OneJax website"></a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mt-3">
                <div class="col-12 text-center">
                    <button onclick="exportDashboard()" class="btn btn-outline-primary">
                        <i class="fas fa-download"></i> Export Dashboard Data
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
