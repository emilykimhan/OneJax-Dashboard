        background-color: #fbe4d5;
    }

    .goal-identity-value-proposition {
        background-color: #f1d7f5;
    }

    .goal-financial-sustainability {
        background-color: #c9f5d3;
    }

    .goal-community-engagement {
        background-color: #cfe9f6;
    }
    .badge-type { color: #fff; }
    .type-youth { background-color: #a0ce3f; }
    .type-humanitarian { background-color: #ad3385; }
    .type-interfaith { background-color: #8d478a; }
    .type-community { background-color: #b48a78; }
    .type-default { background-color: var(--onejax-teal); color: #fff; }

    .event-datetime {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: var(--onejax-blue);
        font-weight: 600;
        font-size: 0.85rem;
        white-space: nowrap;
    }

    .event-datetime-row {
        margin-top: 0.25rem;
        margin-bottom: 0.65rem;
    }

    .event-card-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        margin-top: 0.25rem;
    }

    .empty-state {
        text-align: center; 
        padding: 3rem 0;
        color: #6c757d;
    }

    .empty-state i {
        font-size: 2.5rem;
        display: block;
        margin-bottom: 0.75rem;
    }

    /* ===== Events Table (match Index) ===== */
    .events-table-wrap {
    background: #fff;
    border: 1px solid rgba(16, 40, 64, 0.08);
    border-radius: 14px;
    overflow: visible !important;   /* ✅ allow dropdown to escape */
    position: relative;
    box-shadow: 0 8px 18px rgba(16, 40, 64, 0.06);
    }
    .events-table-wrap .dropdown-menu {
        z-index: 9999;
    }

    .events-table-scroll {
        max-height: 540px;
        overflow-y: auto;
        border-radius: 14px;
    }

    .events-table-scroll thead th {
        position: sticky;
        top: 0;
        z-index: 2;
    }

    .events-table-wrap .action-dropdown-menu {
        margin-top: 0.25rem;
    }

    .events-table-wrap td,
    .events-table-wrap th {
        overflow: visible;
    }

    table.events-table {
        width: 100%;
        border-collapse: collapse;
        margin: 0;
    }

    table.events-table thead th {
        background: var(--onejax-blue);
        color: #fff;
        font-weight: 800;
        font-size: 0.85rem;
        letter-spacing: 0.4px;
        text-transform: uppercase;
        padding: 14px 16px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.25);
        white-space: nowrap;
    }

    /* Rounded header corners to match screenshot */
    table.events-table thead th:first-child { border-top-left-radius: 14px; }
    table.events-table thead th:last-child { border-top-right-radius: 14px; }

    table.events-table tbody td {
        padding: 14px 16px;
        border-bottom: 1px solid rgba(16, 40, 64, 0.06);
        vertical-align: middle;
        color: #213547;
        font-weight: 500;
    }

    table.events-table tbody tr:hover {
        background: rgba(0, 112, 173, 0.04);
    }

    table.events-table tbody tr:nth-child(even) {
        background: rgba(16, 40, 64, 0.015);
    }

    .cell-muted {
        color: #6c757d;
        font-weight: 600;
        font-size: 0.95rem;
    }

    .cell-title {
        font-weight: 800;
        color: var(--onejax-navy);
        font-size: 1.05rem;
    }

    .cell-subtitle {
        margin-top: 3px;
        color: #546678;
        font-weight: 600;
        font-size: 0.95rem;
    }

    .type-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 0.25rem 0.6rem;
        border-radius: 999px;
        font-weight: 800;
        font-size: 0.85rem;
        white-space: nowrap;
        color: #fff;
        background-color: var(--onejax-teal); 
    }

    /* Event type chip colors (override fallback) */
    .type-chip.type-youth { background-color: #a0ce3f; }
    .type-chip.type-humanitarian { background-color: #ad3385; }
    .type-chip.type-interfaith { background-color: #8d478a; }
    .type-chip.type-community { background-color: #b48a78; }
    .type-chip.type-default { background-color: var(--onejax-teal); }

    .fy-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 0.25rem 0.6rem;
        border-radius: 999px;
        background: rgba(0, 112, 173, 0.10);
        color: var(--onejax-navy);
        font-weight: 700;
        font-size: 0.85rem;
        white-space: nowrap;
    }

    .actions-cell {
        white-space: nowrap;
        text-align: right;
    }

    .time-cell-text {
        white-space: nowrap;
        display: inline-block;
    }

    .quick-action-btn {
        min-width: 185px;
        text-align: center;
    }

    .quick-action-row {
        display: flex;
        justify-content: center;
        gap: 10px;
        margin-top: 10px;
        flex-wrap: wrap;
    }

    .archive-action-btn {
        background-color: transparent;
        color: #7a7f82;
        border: 1px solid #7a7f82;
        padding: 10px 22px;
        border-radius: 25px;
        font-weight: 600;
        box-shadow: 0 3px 8px rgba(0,0,0,0.15);
        transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    }

    .archive-action-btn:hover,
    .archive-action-btn:focus {
        background-color: #7a7f82;
        color: #fff;
        border-color: #7a7f82;
    }

    .page-head-divider {
        height: 1px;
        max-width: 980px;
        margin: 1rem auto 0;
        background: linear-gradient(90deg, rgba(16, 40, 64, 0.05), rgba(0, 112, 173, 0.2), rgba(16, 40, 64, 0.05));
    }

    .desc-text {
        display: inline-block;
        max-width: 320px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .success-text {
        color: #00A676;
        font-weight: 600;
        font-size: 1rem;
        letter-spacing: 0.5px;
        animation: fadeInOut 4s ease-in-out forwards;
    }

    @@keyframes fadeInOut {
        0% { opacity: 0; transform: translateY(-8px); }
        10% { opacity: 1; transform: translateY(0); }
        90% { opacity: 1; transform: translateY(0); }
        100% { opacity: 0; transform: translateY(-8px); }
    }

    @@media (max-width: 992px) {
        table.events-table thead { display: none; }
        table.events-table, table.events-table tbody, table.events-table tr, table.events-table td { display: block; width: 100%; }
        table.events-table tr { border-bottom: 1px solid rgba(16, 40, 64, 0.08); }
        table.events-table tbody td { border: none; padding: 10px 14px; }
        table.events-table tbody td::before {
            content: attr(data-label);
            display: block;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            font-size: 0.75rem;
            color: #6c757d;
            margin-bottom: 4px;
        }
        .actions-cell { text-align: left; }
    }
</style>

<!-- End of removed extra Fiscal Year Tab Content UI -->
<div class="container my-5 view-events-shell">

    <div class="text-center mb-3 page-header-card">
        <h2 class="fw-bold text-uppercase" style="color: var(--onejax-blue);">View Events</h2>
        <p class="text-secondary mb-3">
            Browse all events and manage them by strategic goal. Use the tabs below to filter.
        </p>

        <div class="quick-action-row">
            <a href="/Programs/Index" class="btn quick-action-btn"
               style="background-color: var(--onejax-blue); color: #fff; padding: 10px 22px; border-radius: 25px; font-weight: 600; box-shadow: 0 3px 8px rgba(0,0,0,0.15);">
                Create Programs +
            </a>
            <a href="/Strategy/Index" class="btn quick-action-btn"
               style="background-color: var(--onejax-blue); color: #fff; padding: 10px 22px; border-radius: 25px; font-weight: 600; box-shadow: 0 3px 8px rgba(0,0,0,0.15);">
                Create Events +
            </a>
            <a href="/Programs/Archive" class="btn quick-action-btn archive-action-btn">
                View Archive
            </a>
        </div>
        <div class="page-head-divider"></div>
    </div>

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="text-center mb-3">
            <span class="success-text">@successMessage</span>
        </div>
    }

    <!-- Fiscal Year Tabs (server-side filter via query string) -->
    <ul class="nav nav-pills justify-content-center mb-4" id="fyTabs" role="tablist">
        @foreach (var fy in fiscalYears)
        {
            var isActive = (fy == selectedFY) || (fy == selectedFYAlt);
            <li class="nav-item" role="presentation">
                <a class="nav-link @(isActive ? "active" : "")" href="@Url.Action("ViewEvents", "Strategy", new { fy = fy })">
                    @fy
                </a>
            </li>
        }
    </ul>

    <!-- Tabs -->
   <ul class="nav nav-pills justify-content-center mb-4" id="eventTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="all-events-tab" data-bs-toggle="tab" data-bs-target="#all-events"
                type="button" role="tab">
                All Events
            </button>
        </li>
        
        @if (goalTabs != null && goalTabs.Any())
        {
            foreach (var goal in goalTabs)
            {
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="goal-@goal.Value-tab" data-bs-toggle="tab" data-bs-target="#goal-@goal.Value"
                            type="button" role="tab" aria-controls="goal-@goal.Value" aria-selected="false">
                        @goal.Text
                    </button>
                </li>
            }
        }
    </ul>

    <!-- Tab Content -->
    <div class="tab-content" id="eventTabsContent">
        <!-- All Events -->
        <div class="tab-pane fade show active" id="all-events" role="tabpanel" aria-labelledby="all-events-tab">
            @if (!filteredEvents.Any())
            {
                <div class="empty-state">
                    <i class="bi bi-inbox"></i>
                    <p class="mb-0">No events have been created for fiscal year @(selectedFYAlt ?? selectedFY) yet.</p>
                </div>
            }
            else
            {
                <div class="events-table-wrap">
                    <div class="events-table-scroll">
                    <div class="table-responsive">
                    <table class="events-table">
                        <thead>
                            <tr>
                                <th>Program Name</th>
                                <th>Program Type</th>
                                <th>Event</th>
                                <th>Description</th>
                                <th>Cross-Collabs</th>
                                <th>Partners</th>
                                <th>Date</th>
                                <th>Time</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var e in filteredEvents.OrderByDescending(x => x.Id))
                            {
                                var programNameDisplay = !string.IsNullOrWhiteSpace(e.ProgramName) ? e.ProgramName : "—";
                                var programTypeDisplay = !string.IsNullOrWhiteSpace(e.ProgramType) ? e.ProgramType : "—";
                                var eventName = e.Name;

                                var dateDisplay = e.Date;
                                if (!string.IsNullOrWhiteSpace(e.Date) && DateTime.TryParse(e.Date, out var parsedDate))
                                {
                                    dateDisplay = parsedDate.ToString("MM/dd/yyyy");
                                }

                                var timeDisplay = e.Time;
                                if (!string.IsNullOrWhiteSpace(e.Time) && DateTime.TryParse(e.Time, out var parsedTime))
                                {
                                    timeDisplay = parsedTime.ToString("h:mm tt");
                                }

                                <tr>
                                    <td data-label="Program Name">
                                        <div class="cell-title">@programNameDisplay</div>
                                    </td>

                                    <td data-label="Program Type">
                                        @if (programTypeDisplay == "—")
                                        {
                                            <span class="cell-muted">—</span>
                                        }
                                        else
                                        {
                                            <div class="cell-title">@programTypeDisplay</div>
                                        }
                                    </td>

                                    <td data-label="Event">
                                        @if (!string.IsNullOrWhiteSpace(eventName))
                                        {
                                            <div class="cell-subtitle">@eventName</div>
                                        }
                                        else
                                        {
                                            <div class="cell-muted">—</div>
                                        }
                                    </td>

                                    <td data-label="Description">
                                        @if (!string.IsNullOrWhiteSpace(e.Description))
                                        {
                                            <span class="desc-text" title="@e.Description">@e.Description</span>
                                        }
                                        else
                                        {
                                            <span class="cell-muted">—</span>
                                        }
                                    </td>

                                    <td data-label="Cross Collaboration">
                                        @if (!string.IsNullOrWhiteSpace(e.CrossCollaboration))
                                        {
                                            <span class="type-chip"><i class="bi bi-people"></i> @e.CrossCollaboration</span>
                                        }
                                        else
                                        {
                                            <span class="cell-muted">—</span>
                                        }
                                    </td>

                                    <td data-label="Partners">
                                        @if (!string.IsNullOrWhiteSpace(e.Partners))
                                        {
                                            <span>@e.Partners</span>
                                        }
                                        else
                                        {
                                            <span class="cell-muted">—</span>
                                        }
                                    </td>

                                    <td data-label="Date">
                                        @if (!string.IsNullOrWhiteSpace(dateDisplay))
                                        {
                                            <span>@dateDisplay</span>
                                        }
                                        else
                                        {
                                            <span class="cell-muted">—</span>
                                        }
                                    </td>

                                    <td data-label="Time">
                                        @if (!string.IsNullOrWhiteSpace(timeDisplay))
                                        {
                                            <span class="time-cell-text">@timeDisplay</span>
                                        }
                                        else
                                        {
                                            <span class="cell-muted">—</span>
                                        }
                                    </td>

                                    <td class="actions-cell" data-label="Actions">
                                        <div class="dropdown">
                                            <button class="btn btn-light btn-sm border-0" type="button" data-bs-toggle="dropdown">
                                                <i class="bi bi-three-dots fs-5 text-dark"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end action-dropdown-menu">
                                                <li>
                                                    <a class="dropdown-item text-primary" asp-controller="Strategy"
                                                       asp-action="Edit" asp-route-id="@e.Id">
                                                        Edit
                                                    </a>
                                                </li>
                                                <li>
                                                    <button type="button" class="dropdown-item text-danger" data-bs-toggle="modal"
                                                            data-bs-target="#deleteConfirmModal" data-event-id="@e.Id">
                                                        Delete
                                                    </button>
                                                </li>
                                                <li>
                                                    <form asp-controller="Strategy" asp-action="Archive" method="post" class="m-0">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@e.Id" />
                                                        <button type="submit" class="dropdown-item text-secondary">
                                                            Archive
                                                        </button>
                                                    </form>
                                                </li>
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    </div>
                    </div>
                </div>
            }
        </div>

        <!-- Events by Goal -->
        @if (goalTabs != null && goalTabs.Any())
        {
            foreach (var goal in goalTabs)
            {
                var goalId = int.Parse(goal.Value);
                var eventsForGoal = filteredEvents.Where(e => e.StrategicGoalId == goalId).ToList();

                <div class="tab-pane fade" id="goal-@goal.Value" role="tabpanel" aria-labelledby="goal-@goal.Value-tab">
                    @if (!eventsForGoal.Any())
                    {
                        <div class="empty-state">
                            <i class="bi bi-inbox"></i>
                            <p class="mb-0">No events for this goal yet.</p>
                        </div>
                    }
                    else
                    {
                        <div class="events-table-wrap">
                            <div class="events-table-scroll">
                            <div class="table-responsive">
                            <table class="events-table">
                                <thead>
                                    <tr>
                                        <th>Program Name</th>
                                        <th>Program Type</th>
                                        <th>Event</th>
                                        <th>Description</th>
                                        <th>Cross Collaboration</th>
                                        <th>Partners</th>
                                        <th>Date</th>
                                        <th>Time</th>
                                        <th class="text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var e in eventsForGoal.OrderByDescending(x => x.Id))
                                    {
                                        var programNameDisplay = !string.IsNullOrWhiteSpace(e.ProgramName) ? e.ProgramName : "—";
                                        var programTypeDisplay = !string.IsNullOrWhiteSpace(e.ProgramType) ? e.ProgramType : "—";
                                        var eventName = e.Name;

                                        var dateDisplay = e.Date;
                                        if (!string.IsNullOrWhiteSpace(e.Date) && DateTime.TryParse(e.Date, out var parsedDate))
                                        {
                                            dateDisplay = parsedDate.ToString("MM/dd/yyyy");
                                        }

                                        var timeDisplay = e.Time;
                                        if (!string.IsNullOrWhiteSpace(e.Time) && DateTime.TryParse(e.Time, out var parsedTime))
                                        {
                                            timeDisplay = parsedTime.ToString("h:mm tt");
                                        }

                                        <tr>
                                            <td data-label="Program Name">
                                                <div class="cell-title">@programNameDisplay</div>
                                            </td>

                                            <td data-label="Program Type">
                                                @if (programTypeDisplay == "—")
                                                {
                                                    <span class="cell-muted">—</span>
                                                }
                                                else
                                                {
                                                    <div class="cell-title">@programTypeDisplay</div>
                                                }
                                            </td>

                                            <td data-label="Event">
                                                @if (!string.IsNullOrWhiteSpace(eventName))
                                                {
                                                    <div class="cell-subtitle">@eventName</div>
                                                }
                                                else
                                                {
                                                    <div class="cell-muted">—</div>
                                                }
                                            </td>

                                            <td data-label="Description">
                                                @if (!string.IsNullOrWhiteSpace(e.Description))
                                                {
                                                    <span class="desc-text" title="@e.Description">@e.Description</span>
                                                }
                                                else
                                                {
                                                    <span class="cell-muted">—</span>
                                                }
                                            </td>

                                            <td data-label="Cross Collaboration">
                                                @if (!string.IsNullOrWhiteSpace(e.CrossCollaboration))
                                                {
                                                    <span class="type-chip"><i class="bi bi-people"></i> @e.CrossCollaboration</span>
                                                }
                                                else
                                                {
                                                    <span class="cell-muted">—</span>
                                                }
                                            </td>

                                            <td data-label="Partners">
                                                @if (!string.IsNullOrWhiteSpace(e.Partners))
                                                {
                                                    <span>@e.Partners</span>
                                                }
                                                else
                                                {
                                                    <span class="cell-muted">—</span>
                                                }
                                            </td>

                                            <td data-label="Date">
                                                @if (!string.IsNullOrWhiteSpace(dateDisplay))
                                                {
                                                    <span>@dateDisplay</span>
                                                }
                                                else
                                                {
                                                    <span class="cell-muted">—</span>
                                                }
                                            </td>

                                            <td data-label="Time">
                                                @if (!string.IsNullOrWhiteSpace(timeDisplay))
                                                {
                                                    <span class="time-cell-text">@timeDisplay</span>
                                                }
                                                else
                                                {
                                                    <span class="cell-muted">—</span>
                                                }
                                            </td>

                                            <td class="actions-cell" data-label="Actions">
                                                <div class="dropdown">
                                                    <button class="btn btn-light btn-sm border-0" type="button" data-bs-toggle="dropdown">
                                                        <i class="bi bi-three-dots fs-5 text-dark"></i>
                                                    </button>
                                                    <ul class="dropdown-menu dropdown-menu-end action-dropdown-menu">
                                                        <li>
                                                            <a class="dropdown-item text-primary" asp-controller="Strategy"
                                                               asp-action="Edit" asp-route-id="@e.Id">
                                                                Edit
                                                            </a>
                                                        </li>
                                                        <li>
                                                            <button type="button" class="dropdown-item text-danger" data-bs-toggle="modal"
                                                                    data-bs-target="#deleteConfirmModal" data-event-id="@e.Id">
                                                                Delete
                                                            </button>
                                                        </li>
                                                        <li>
                                                            <form asp-controller="Strategy" asp-action="Archive" method="post" class="m-0">
                                                                @Html.AntiForgeryToken()
                                                                <input type="hidden" name="id" value="@e.Id" />
                                                                <button type="submit" class="dropdown-item text-secondary">
                                                                    Archive
                                                                </button>
                                                            </form>
                                                        </li>
                                                    </ul>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            </div>
                            </div>
                        </div>
                    }
                </div>
            }
        }
    </div>
</div>
<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-labelledby="deleteConfirmLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-semibold" id="deleteConfirmLabel">
                    Delete Event?
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <p class="mb-2">
                    You’re about to permanently delete this Event. This action cannot be undone.
                </p>
                <p class="mb-3">
                    Type <strong>delete</strong> in lowercase to confirm.
                </p>

                <form id="deleteConfirmForm" asp-action="Delete" asp-controller="Strategy" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="deleteEventId" name="id" />

                    <input type="text" id="deleteConfirmInput" class="form-control mb-3"
                        placeholder='Type "delete" to continue' />

                    <div class="d-flex justify-content-end gap-2">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                            Cancel
                        </button>
                        <button type="submit" class="btn btn-danger" id="deleteConfirmButton" disabled>
                            Delete
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var deleteModal = document.getElementById('deleteConfirmModal');
        var input = document.getElementById('deleteConfirmInput');
        var button = document.getElementById('deleteConfirmButton');
        var hiddenId = document.getElementById('deleteEventId');

        if (!deleteModal) return;

        deleteModal.addEventListener('show.bs.modal', function (event) {
            var triggerButton = event.relatedTarget;
            var eventId = triggerButton.getAttribute('data-event-id');

            hiddenId.value = eventId;
            input.value = '';
            button.disabled = true;
        });

        input.addEventListener('input', function () {
            if (input.value === 'delete') {
                button.disabled = false;
            } else {
                button.disabled = true;
            }
        });
    });
</script>
