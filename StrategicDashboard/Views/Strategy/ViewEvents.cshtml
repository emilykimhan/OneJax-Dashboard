@using System.Linq
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "View Events";

    // Prefer Goals provided by the controller (best: comes from a Goals table)
    var goals = ViewBag.Goals as List<SelectListItem>;

    // Fiscal years shown as tabs (client requirement)
    var fiscalYears = ViewBag.FiscalYears as List<string> ?? new List<string> { "2025/2026", "2026/2027", "2027/2028" };

    // Events source (do NOT rely on @model typing). Prefer ViewBag.Events; fallback to runtime Model.
    var allEvents = (ViewBag.Events as IEnumerable<OneJaxDashboard.Models.Strategy>)?.ToList()
        ?? (Model as IEnumerable<OneJaxDashboard.Models.Strategy>)?.ToList()
        ?? new List<OneJaxDashboard.Models.Strategy>();

    // Fallback: if Goals are missing, build tabs from the events in allEvents so tabs still appear
    var goalTabs = (goals != null && goals.Any())
        ? goals
        : (allEvents)
            .Select(e => e.StrategicGoalId)
            .Distinct()
            .OrderBy(id => id)
            .Select(id => new SelectListItem { Value = id.ToString(), Text = $"Goal {id}" })
            .ToList();

    // Fiscal year filter (via query string) — default to first fiscal year
    var selectedFY = Context?.Request?.Query["fy"].FirstOrDefault();
    if (string.IsNullOrWhiteSpace(selectedFY))
    {
        selectedFY = fiscalYears.FirstOrDefault();
    }

    // Normalize FY formats (supports "2025/2026" <-> "25/26")
    Func<string?, string?> NormalizeFY = (fy) =>
    {
        if (string.IsNullOrWhiteSpace(fy)) return fy;
        fy = fy.Trim();

        // Convert 2025/2026 -> 25/26
        if (fy.Length >= 9 && fy.Contains("/"))
        {
            var parts = fy.Split('/');
            if (parts.Length == 2 && parts[0].Length == 4 && parts[1].Length == 4)
            {
                return parts[0].Substring(2, 2) + "/" + parts[1].Substring(2, 2);
            }
        }

        // Convert 25/26 -> 2025/2026 (assumes 20xx)
        if (fy.Length == 5 && fy[2] == '/')
        {
            var parts = fy.Split('/');
            if (parts.Length == 2 && parts[0].Length == 2 && parts[1].Length == 2)
            {
                return "20" + parts[0] + "/20" + parts[1];
            }
        }

        return fy;
    };

    var selectedFYAlt = NormalizeFY(selectedFY);

    // Filter events by fiscal year (falls back to all if no FY is available)
    var filteredEvents = allEvents.AsEnumerable();
    if (!string.IsNullOrWhiteSpace(selectedFY))
    {
        filteredEvents = filteredEvents.Where(e =>
            e != null &&
            (!string.IsNullOrWhiteSpace(e.EventFYear)) &&
            (e.EventFYear == selectedFY || e.EventFYear == selectedFYAlt || NormalizeFY(e.EventFYear) == selectedFY || NormalizeFY(e.EventFYear) == selectedFYAlt)
        );
    }
}

<!-- OneJax Color Theme (reuse from Add Event for consistency) -->
<style>
    :root {
        --onejax-blue: #0070AD;
        --onejax-teal: #00A3AD;
        --onejax-navy: #102840;
        --onejax-gold: #93d2de;
        --onejax-light: #F7F9FB;
    }

    body {
        background-color: var(--onejax-light);
        font-family: 'Poppins', sans-serif;
        color: var(--onejax-navy);
    }

    h1,
    h2,
    h3,
    h4,
    h5 {
        color: var(--onejax-navy);
        font-weight: 700;
    }

    .card {
        background-color: #fff;
        border-radius: 20px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
        border: none;
    }

    .event-card-title {
        font-weight: 600;
        color: var(--onejax-navy);
    }

    .event-card-meta {
        font-size: 0.9rem;
        color: #6c757d;
    }

    .nav-pills {
        border-bottom: none;
    }

    .nav-pills .nav-link {
        color: var(--onejax-navy);
        border-radius: 25px;
        background-color: #fff;
        border: 1px solid transparent;
        transition: all 0.3s ease-in-out;
        padding: 8px 16px;
        margin: 0 4px;
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.05);
    }

    .nav-pills .nav-link.active {
        background-color: var(--onejax-blue);
        color: #fff;
        box-shadow: 0 4px 10px rgba(0, 112, 173, 0.3);
    }

    .nav-pills .nav-link:hover {
        background-color: var(--onejax-teal);
        color: #fff;
        transform: scale(1.02);
    }

    .event-card-title {
        font-weight: 700;
        color: var(--onejax-navy);
        margin: 0;
    }

    .event-card-desc {
        color: #6c757d;
        margin: 0.35rem 0 0.75rem 0;
        line-height: 1.35;
    }

    .event-meta-row {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        align-items: center;
        margin-top: 0.25rem;
    }

    .badge-pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 0.28rem 0.65rem;
        border-radius: 999px;
        font-size: 0.78rem;
        font-weight: 600;
        white-space: nowrap;
    }

    /* Goal badge base */
    .badge-goal {
        color: var(--onejax-navy);
        font-weight: 600;
    }

    /* Goal-specific colors (match your legend) */
    .goal-organizational-building {
        background-color: #fbe4d5;
    }

    .goal-identity-value-proposition {
        background-color: #f1d7f5;
    }

    .goal-financial-sustainability {
        background-color: #c9f5d3;
    }

    .goal-community-engagement {
        background-color: #cfe9f6;
    }
    .badge-type { color: #fff; }
    .type-youth { background-color: #a0ce3f; }
    .type-humanitarian { background-color: #ad3385; }
    .type-interfaith { background-color: #8d478a; }
    .type-community { background-color: #b48a78; }
    .type-default { background-color: var(--onejax-teal); color: #fff; }

    .event-datetime {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: var(--onejax-blue);
        font-weight: 600;
        font-size: 0.85rem;
        white-space: nowrap;
    }

    .event-datetime-row {
        margin-top: 0.25rem;
        margin-bottom: 0.65rem;
    }

    .event-card-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        margin-top: 0.25rem;
    }

    .empty-state {
        text-align: center; 
        padding: 3rem 0;
        color: #6c757d;
    }

    .empty-state i {
        font-size: 2.5rem;
        display: block;
        margin-bottom: 0.75rem;
    }

    /* ===== Events Table (match Index) ===== */
    .events-table-wrap {
    background: #fff;
    border: 1px solid rgba(16, 40, 64, 0.08);
    border-radius: 14px;
    overflow: visible !important;   /* ✅ allow dropdown to escape */
    position: relative;   
    }
    .events-table-wrap .dropdown-menu {
        z-index: 9999;
    }

    .events-table-wrap td,
    .events-table-wrap th {
        overflow: visible;
    }

    table.events-table {
        width: 100%;
        border-collapse: collapse;
        margin: 0;
    }

    table.events-table thead th {
        background: var(--onejax-blue);
        color: #fff;
        font-weight: 800;
        font-size: 0.85rem;
        letter-spacing: 0.4px;
        text-transform: uppercase;
        padding: 14px 16px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.25);
        white-space: nowrap;
    }

    /* Rounded header corners to match screenshot */
    table.events-table thead th:first-child { border-top-left-radius: 14px; }
    table.events-table thead th:last-child { border-top-right-radius: 14px; }

    table.events-table tbody td {
        padding: 14px 16px;
        border-bottom: 1px solid rgba(16, 40, 64, 0.06);
        vertical-align: middle;
        color: #213547;
        font-weight: 500;
    }

    table.events-table tbody tr:hover {
        background: rgba(0, 112, 173, 0.04);
    }

    .cell-muted {
        color: #6c757d;
        font-weight: 600;
        font-size: 0.95rem;
    }

    .cell-title {
        font-weight: 800;
        color: var(--onejax-navy);
        font-size: 1.05rem;
    }

    .cell-subtitle {
        margin-top: 3px;
        color: #546678;
        font-weight: 600;
        font-size: 0.95rem;
    }

    .type-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 0.25rem 0.6rem;
        border-radius: 999px;
        font-weight: 800;
        font-size: 0.85rem;
        white-space: nowrap;
        color: #fff;
        background-color: var(--onejax-teal); 
    }

    /* Event type chip colors (override fallback) */
    .type-chip.type-youth { background-color: #a0ce3f; }
    .type-chip.type-humanitarian { background-color: #ad3385; }
    .type-chip.type-interfaith { background-color: #8d478a; }
    .type-chip.type-community { background-color: #b48a78; }
    .type-chip.type-default { background-color: var(--onejax-teal); }

    .fy-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 0.25rem 0.6rem;
        border-radius: 999px;
        background: rgba(0, 112, 173, 0.10);
        color: var(--onejax-navy);
        font-weight: 700;
        font-size: 0.85rem;
        white-space: nowrap;
    }

    .actions-cell {
        white-space: nowrap;
        text-align: right;
    }

    @@media (max-width: 992px) {
        table.events-table thead { display: none; }
        table.events-table, table.events-table tbody, table.events-table tr, table.events-table td { display: block; width: 100%; }
        table.events-table tr { border-bottom: 1px solid rgba(16, 40, 64, 0.08); }
        table.events-table tbody td { border: none; padding: 10px 14px; }
        table.events-table tbody td::before {
            content: attr(data-label);
            display: block;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            font-size: 0.75rem;
            color: #6c757d;
            margin-bottom: 4px;
        }
        .actions-cell { text-align: left; }
    }
</style>

<!-- End of removed extra Fiscal Year Tab Content UI -->
<div class="container my-5">

    <div class="text-center mb-3">
        <h2 class="fw-bold text-uppercase" style="color: var(--onejax-blue);">View Programs</h2>
        <p class="text-secondary mb-3">
            Browse all programs and manage them by strategic goal. Use the tabs below to filter.
        </p>

        <a href="/Strategy/Index" class="btn"
           style="background-color: var(--onejax-blue); color: #fff; padding: 10px 22px; border-radius: 25px; font-weight: 600; box-shadow: 0 3px 8px rgba(0,0,0,0.15);">
            Create Program +
        </a>
    </div>

    <!-- Fiscal Year Tabs (server-side filter via query string) -->
    <ul class="nav nav-pills justify-content-center mb-4" id="fyTabs" role="tablist">
        @foreach (var fy in fiscalYears)
        {
            var isActive = (fy == selectedFY) || (fy == selectedFYAlt);
            <li class="nav-item" role="presentation">
                <a class="nav-link @(isActive ? "active" : "")" href="@Url.Action("ViewEvents", "Strategy", new { fy = fy })">
                    @fy
                </a>
            </li>
        }
    </ul>

    <!-- Tabs -->
   <ul class="nav nav-pills justify-content-center mb-4" id="eventTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="all-events-tab" data-bs-toggle="tab" data-bs-target="#all-events"
                type="button" role="tab">
                All Programs
            </button>
        </li>
        
        @if (goalTabs != null && goalTabs.Any())
        {
            foreach (var goal in goalTabs)
            {
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="goal-@goal.Value-tab" data-bs-toggle="tab" data-bs-target="#goal-@goal.Value"
                            type="button" role="tab" aria-controls="goal-@goal.Value" aria-selected="false">
                        @goal.Text
                    </button>
                </li>
            }
        }
    </ul>

    <!-- Tab Content -->
    <div class="tab-content" id="eventTabsContent">
        <!-- All Events -->
        <div class="tab-pane fade show active" id="all-events" role="tabpanel" aria-labelledby="all-events-tab">
            @if (!filteredEvents.Any())
            {
                <div class="empty-state">
                    <i class="bi bi-inbox"></i>
                    <p class="mb-0">No programs have been created for fiscal year @(selectedFYAlt ?? selectedFY) yet.</p>
                </div>
            }
            else
            {
                <div class="events-table-wrap">
                    <table class="events-table">
                        <thead>
                            <tr>
                                <th>Program</th>
                                <th>Event</th>
                                <th>Cross Collaboration</th>
                                <th>FY</th>
                                <th>Date</th>
                                <th>Time</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var e in filteredEvents.OrderByDescending(x => x.Id))
                            {
                                var program = string.IsNullOrWhiteSpace(e.ProgramName) ? "(No Program)" : e.ProgramName;
                                var eventName = e.Name;

                                var dateDisplay = e.Date;
                                if (!string.IsNullOrWhiteSpace(e.Date) && DateTime.TryParse(e.Date, out var parsedDate))
                                {
                                    dateDisplay = parsedDate.ToString("MM/dd/yyyy");
                                }

                                var timeDisplay = e.Time;
                                if (!string.IsNullOrWhiteSpace(e.Time) && DateTime.TryParse(e.Time, out var parsedTime))
                                {
                                    timeDisplay = parsedTime.ToString("h:mm tt");
                                }

                                <tr>
                                    <td data-label="Program">
                                        <div class="cell-title">@program</div>
                                    </td>

                                    <td data-label="Event">
                                        @if (!string.IsNullOrWhiteSpace(eventName) && eventName != program)
                                        {
                                            <div class="cell-subtitle">@eventName</div>
                                        }
                                        else
                                        {
                                            <div class="cell-muted">—</div>
                                        }
                                    </td>

                                    <td data-label="Cross Collaboration">
                                        @if (!string.IsNullOrWhiteSpace(e.CrossCollaboration))
                                        {
                                            <span class="type-chip"><i class="bi bi-people"></i> @e.CrossCollaboration</span>
                                        }
                                        else
                                        {
                                            <span class="cell-muted">—</span>
                                        }
                                    </td>

                                    <td data-label="FY">
                                        @if (!string.IsNullOrWhiteSpace(e.EventFYear))
                                        {
                                            <span class="fy-chip"><i class="bi bi-calendar2-range"></i> @e.EventFYear</span>
                                        }
                                        else
                                        {
                                            <span class="cell-muted">—</span>
                                        }
                                    </td>

                                    <td data-label="Date">
                                        @if (!string.IsNullOrWhiteSpace(dateDisplay))
                                        {
                                            <span>@dateDisplay</span>
                                        }
                                        else
                                        {
                                            <span class="cell-muted">—</span>
                                        }
                                    </td>

                                    <td data-label="Time">
                                        @if (!string.IsNullOrWhiteSpace(timeDisplay))
                                        {
                                            <span>@timeDisplay</span>
                                        }
                                        else
                                        {
                                            <span class="cell-muted">—</span>
                                        }
                                    </td>

                                    <td class="actions-cell" data-label="Actions">
                                        <div class="dropdown">
                                            <button class="btn btn-light btn-sm border-0" type="button" data-bs-toggle="dropdown">
                                                <i class="bi bi-three-dots fs-5 text-dark"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end">
                                                <li>
                                                    <a class="dropdown-item text-primary" asp-controller="Strategy"
                                                       asp-action="Edit" asp-route-id="@e.Id">
                                                        Edit
                                                    </a>
                                                </li>
                                                <li>
                                                    <button type="button" class="dropdown-item text-danger" data-bs-toggle="modal"
                                                            data-bs-target="#deleteConfirmModal" data-event-id="@e.Id">
                                                        Delete
                                                    </button>
                                                </li>
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <!-- Events by Goal -->
        @if (goalTabs != null && goalTabs.Any())
        {
            foreach (var goal in goalTabs)
            {
                var goalId = int.Parse(goal.Value);
                var eventsForGoal = filteredEvents.Where(e => e.StrategicGoalId == goalId).ToList();

                <div class="tab-pane fade" id="goal-@goal.Value" role="tabpanel" aria-labelledby="goal-@goal.Value-tab">
                    @if (!eventsForGoal.Any())
                    {
                        <div class="empty-state">
                            <i class="bi bi-inbox"></i>
                            <p class="mb-0">No programs for this goal yet.</p>
                        </div>
                    }
                    else
                    {
                        <div class="events-table-wrap">
                            <table class="events-table">
                                <thead>
                                    <tr>
                                        <th>Program</th>
                                        <th>Event</th>
                                        <th>Cross Collaboration</th>
                                        <th>FY</th>
                                        <th>Date</th>
                                        <th>Time</th>
                                        <th class="text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var e in eventsForGoal.OrderByDescending(x => x.Id))
                                    {
                                        var program = string.IsNullOrWhiteSpace(e.ProgramName) ? "(No Program)" : e.ProgramName;
                                        var eventName = e.Name;

                                        var dateDisplay = e.Date;
                                        if (!string.IsNullOrWhiteSpace(e.Date) && DateTime.TryParse(e.Date, out var parsedDate))
                                        {
                                            dateDisplay = parsedDate.ToString("MM/dd/yyyy");
                                        }

                                        var timeDisplay = e.Time;
                                        if (!string.IsNullOrWhiteSpace(e.Time) && DateTime.TryParse(e.Time, out var parsedTime))
                                        {
                                            timeDisplay = parsedTime.ToString("h:mm tt");
                                        }

                                        <tr>
                                            <td data-label="Program">
                                                <div class="cell-title">@program</div>
                                            </td>

                                            <td data-label="Event">
                                                @if (!string.IsNullOrWhiteSpace(eventName) && eventName != program)
                                                {
                                                    <div class="cell-subtitle">@eventName</div>
                                                }
                                                else
                                                {
                                                    <div class="cell-muted">—</div>
                                                }
                                            </td>

                                            <td data-label="Cross Collaboration">
                                                @if (!string.IsNullOrWhiteSpace(e.CrossCollaboration))
                                                {
                                                    <span class="type-chip"><i class="bi bi-people"></i> @e.CrossCollaboration</span>
                                                }
                                                else
                                                {
                                                    <span class="cell-muted">—</span>
                                                }
                                            </td>

                                            <td data-label="FY">
                                                @if (!string.IsNullOrWhiteSpace(e.EventFYear))
                                                {
                                                    <span class="fy-chip"><i class="bi bi-calendar2-range"></i> @e.EventFYear</span>
                                                }
                                                else
                                                {
                                                    <span class="cell-muted">—</span>
                                                }
                                            </td>

                                            <td data-label="Date">
                                                @if (!string.IsNullOrWhiteSpace(dateDisplay))
                                                {
                                                    <span>@dateDisplay</span>
                                                }
                                                else
                                                {
                                                    <span class="cell-muted">—</span>
                                                }
                                            </td>

                                            <td data-label="Time">
                                                @if (!string.IsNullOrWhiteSpace(timeDisplay))
                                                {
                                                    <span>@timeDisplay</span>
                                                }
                                                else
                                                {
                                                    <span class="cell-muted">—</span>
                                                }
                                            </td>

                                            <td class="actions-cell" data-label="Actions">
                                                <div class="dropdown">
                                                    <button class="btn btn-light btn-sm border-0" type="button" data-bs-toggle="dropdown">
                                                        <i class="bi bi-three-dots fs-5 text-dark"></i>
                                                    </button>
                                                    <ul class="dropdown-menu dropdown-menu-end">
                                                        <li>
                                                            <a class="dropdown-item text-primary" asp-controller="Strategy"
                                                               asp-action="Edit" asp-route-id="@e.Id">
                                                                Edit
                                                            </a>
                                                        </li>
                                                        <li>
                                                            <button type="button" class="dropdown-item text-danger" data-bs-toggle="modal"
                                                                    data-bs-target="#deleteConfirmModal" data-event-id="@e.Id">
                                                                Delete
                                                            </button>
                                                        </li>
                                                    </ul>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            }
        }
    </div>
</div>
<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-labelledby="deleteConfirmLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-semibold" id="deleteConfirmLabel">
                    Delete Program?
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <p class="mb-2">
                    You’re about to permanently delete this Program. This action cannot be undone.
                </p>
                <p class="mb-3">
                    Type <strong>delete</strong> in lowercase to confirm.
                </p>

                <form id="deleteConfirmForm" asp-action="Delete" asp-controller="Strategy" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="deleteEventId" name="id" />

                    <input type="text" id="deleteConfirmInput" class="form-control mb-3"
                        placeholder='Type "delete" to continue' />

                    <div class="d-flex justify-content-end gap-2">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                            Cancel
                        </button>
                        <button type="submit" class="btn btn-danger" id="deleteConfirmButton" disabled>
                            Delete
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var deleteModal = document.getElementById('deleteConfirmModal');
        var input = document.getElementById('deleteConfirmInput');
        var button = document.getElementById('deleteConfirmButton');
        var hiddenId = document.getElementById('deleteEventId');

        if (!deleteModal) return;

        deleteModal.addEventListener('show.bs.modal', function (event) {
            var triggerButton = event.relatedTarget;
            var eventId = triggerButton.getAttribute('data-event-id');

            hiddenId.value = eventId;
            input.value = '';
            button.disabled = true;
        });

        input.addEventListener('input', function () {
            if (input.value === 'delete') {
                button.disabled = false;
            } else {
                button.disabled = true;
            }
        });
    });
</script>
