@using System.Linq
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "View Events";
    var successMessage = TempData["SuccessMessage"] as string;

    // Prefer Goals provided by the controller (best: comes from a Goals table)
    var goals = ViewBag.Goals as List<SelectListItem>;

    // Fiscal years shown as tabs (client requirement)
    var fiscalYears = ViewBag.FiscalYears as List<string> ?? new List<string> { "2025/2026", "2026/2027", "2027/2028" };

    // Events source (do NOT rely on @model typing). Prefer ViewBag.Events; fallback to runtime Model.
    var allEvents = (ViewBag.Events as IEnumerable<OneJaxDashboard.Models.Strategy>)?.ToList()
        ?? (Model as IEnumerable<OneJaxDashboard.Models.Strategy>)?.ToList()
        ?? new List<OneJaxDashboard.Models.Strategy>();

    // Fallback: if Goals are missing, build tabs from the events in allEvents so tabs still appear
    var goalTabs = (goals != null && goals.Any())
        ? goals
        : (allEvents)
            .Select(e => e.StrategicGoalId)
            .Distinct()
            .OrderBy(id => id)
            .Select(id => new SelectListItem { Value = id.ToString(), Text = $"Goal {id}" })
            .ToList();

    // Fiscal year filter is resolved in the controller so it stays in sync with the dashboard.
    var selectedFY = ViewBag.SelectedFY as string;
    if (string.IsNullOrWhiteSpace(selectedFY))
    {
        selectedFY = fiscalYears.FirstOrDefault();
    }

    // Normalize FY formats (supports "2025/2026" <-> "25/26")
    Func<string?, string?> NormalizeFY = (fy) =>
    {
        if (string.IsNullOrWhiteSpace(fy)) return fy;
        fy = fy.Trim();

        // Convert 2025/2026 -> 25/26
        if (fy.Length >= 9 && fy.Contains("/"))
        {
            var parts = fy.Split('/');
            if (parts.Length == 2 && parts[0].Length == 4 && parts[1].Length == 4)
            {
                return parts[0].Substring(2, 2) + "/" + parts[1].Substring(2, 2);
            }
        }

        // Convert 25/26 -> 2025/2026 (assumes 20xx)
        if (fy.Length == 5 && fy[2] == '/')
        {
            var parts = fy.Split('/');
            if (parts.Length == 2 && parts[0].Length == 2 && parts[1].Length == 2)
            {
                return "20" + parts[0] + "/20" + parts[1];
            }
        }

        return fy;
    };

    var selectedFYAlt = NormalizeFY(selectedFY);

    // Filter events by fiscal year (falls back to all if no FY is available)
    var filteredEvents = allEvents.AsEnumerable();
    if (!string.IsNullOrWhiteSpace(selectedFY))
    {
        filteredEvents = filteredEvents.Where(e =>
            e != null &&
            (!string.IsNullOrWhiteSpace(e.EventFYear)) &&
            (e.EventFYear == selectedFY || e.EventFYear == selectedFYAlt || NormalizeFY(e.EventFYear) == selectedFY || NormalizeFY(e.EventFYear) == selectedFYAlt)
        );
    }
}

<!-- OneJax Color Theme (reuse from Add Event for consistency) -->
