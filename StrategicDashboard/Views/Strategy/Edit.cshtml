@model OneJaxDashboard.Models.Strategy
@using System.Collections.Generic
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    var successMessage = TempData["SuccessMessage"] as string;
    var errorMessage = TempData["ErrorMessage"] as string;
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success alert-dismissible fade show text-center mt-3" role="alert"
        style="max-width: 600px; margin: 0 auto;">
        @successMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show text-center mt-3" role="alert"
        style="max-width: 600px; margin: 0 auto;">
        @errorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var programOptions = ViewBag.Programs as List<OneJaxDashboard.Models.Programs> ?? new List<OneJaxDashboard.Models.Programs>();
    var programTypeOptions = ViewBag.ProgramTypes as List<string> ?? new List<string>();
    var goals = ViewBag.Goals as List<SelectListItem> ?? new List<SelectListItem>();
}

<style>
    :root {
        --onejax-blue: #0070AD;
        --onejax-teal: #00A3AD;
        --onejax-navy: #102840;
        --onejax-gold: #E6B500;
        --onejax-light: #F7F9FB;
    }

    body {
        background-color: var(--onejax-light);
        font-family: 'Poppins', sans-serif;
        color: var(--onejax-navy);
    }

    h1,
    h2,
    h3,
    h4,
    h5 {
        color: var(--onejax-navy);
        font-weight: 700;
    }

    .card {
        background-color: #fff;
        border-radius: 20px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
        border: none;
    }

    .form-control,
    .form-select {
        border-radius: 12px;
        border: 1px solid #d0d7de;
        padding: 0.7rem 0.9rem;
        background-color: #ffffff;
        box-shadow: 0 1px 0 rgba(16, 40, 64, 0.03);
    }

    .form-control:focus,
    .form-select:focus {
        border-color: rgba(0, 112, 173, 0.55);
        box-shadow: 0 0 0 0.2rem rgba(0, 112, 173, 0.15);
    }

    .form-label {
        font-weight: 700;
        color: var(--onejax-navy);
        letter-spacing: 0.2px;
    }

    .btn-primary {
        background-color: var(--onejax-blue);
        border-color: var(--onejax-blue);
        border-radius: 50px;
        font-weight: 500;
        transition: all 0.3s ease-in-out;
    }

    .btn-primary:hover {
        background-color: var(--onejax-teal);
        border-color: var(--onejax-teal);
        transform: scale(1.02);
    }
</style>

<div class="container my-5">
    <!-- Header (matches other pages) -->
    <div class="text-center mb-5">
        <h1 class="fw-bold text-uppercase" style="color: var(--onejax-blue);">
            OneJax Strategic Dashboard
        </h1>
        <p class="text-secondary fs-5">
            Track and manage events by strategic goals
        </p>
    </div>

    <!-- Edit Event Card -->
    <div class="card shadow-lg border-0 rounded-4 mb-5">
        <div class="card-body p-4">
            <h3 class="fw-bold text-uppercase mb-4" style="color: var(--onejax-blue);">
                Edit Events
            </h3>

            <form asp-action="Edit" asp-controller="Strategy" method="post" class="row g-3">
                <input type="hidden" name="id" value="@Model?.Id" />

                <div class="col-12">
                    <label class="form-label fw-semibold">Program Name</label>
                    <select name="programId" id="programId" class="form-select">
                        <option value="">Select Program Name</option>
                        @foreach (var p in programOptions)
                        {
                            var selected = (Model?.ProgramId == p.Id) || ((Model?.ProgramId == null) && Model?.ProgramName == p.ProgramName);
                            if (selected)
                            {
                                <option value="@p.Id" selected data-program-type="@p.ProgramType">@p.ProgramName</option>
                            }
                            else
                            {
                                <option value="@p.Id" data-program-type="@p.ProgramType">@p.ProgramName</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-12">
                    <label class="form-label fw-semibold">Program Type</label>
                    <select name="programType" id="programType" class="form-select">
                        <option value="">Select Program Type</option>
                        @foreach (var type in programTypeOptions)
                        {
                            if (Model?.ProgramType == type)
                            {
                                <option value="@type" selected>@type</option>
                            }
                            else
                            {
                                <option value="@type">@type</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Event Name <span class="text-danger">*</span></label>
                    <input type="text" name="eventName" class="form-control" value="@Model?.Name" required />
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Cross Collaboration</label>
                    <div class="form-check mt-2">
                        @if (Model?.CrossCollaboration == "Yes")
                        {
                            <input class="form-check-input" type="checkbox" id="isCrossCollaboration" name="isCrossCollaboration" value="true" checked />
                        }
                        else
                        {
                            <input class="form-check-input" type="checkbox" id="isCrossCollaboration" name="isCrossCollaboration" value="true" />
                        }
                        <label class="form-check-label fw-semibold" for="isCrossCollaboration">
                            Yes, this is a cross collaboration
                        </label>
                    </div>
                    <small class="text-muted">Unchecked means No.</small>
                </div>

                @if (Model?.CrossCollaboration == "Yes")
                {
                    <div class="col-md-6" id="partnersField">
                        <label class="form-label fw-semibold">Partners</label>
                        <input type="text" name="partners" id="partnersInput" class="form-control" value="@Model?.Partners" />
                    </div>
                }
                else
                {
                    <div class="col-md-6 d-none" id="partnersField">
                        <label class="form-label fw-semibold">Partners</label>
                        <input type="text" name="partners" id="partnersInput" class="form-control" value="@Model?.Partners" />
                    </div>
                }

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Assign to Goal <span class="text-danger">*</span></label>
                    <select name="goalId" class="form-select" required>
                        <option value="">Select a Goal</option>
                        @foreach (var goal in goals)
                        {
                            if (goal.Value == Model?.StrategicGoalId.ToString())
                            {
                                <option value="@goal.Value" selected>@goal.Text</option>
                            }
                            else
                            {
                                <option value="@goal.Value">@goal.Text</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Event Date <span class="text-danger">*</span></label>
                    <input type="date" name="eventDate" class="form-control" value="@Model?.Date" min="2020-01-01"
                        max="2030-12-31" required />
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Event Time</label>
                    <input type="time" name="eventTime" class="form-control" value="@Model?.Time" />
                </div>

                <div class="col-12">
                    <label class="form-label fw-semibold">Event Description</label>
                    <textarea name="eventDescription" class="form-control" rows="3">@Model?.Description</textarea>
                </div>

                <div class="col-12">
                    <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-semibold">Save
                        Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var crossCollabCheckbox = document.getElementById('isCrossCollaboration');
        var partnersField = document.getElementById('partnersField');
        var partnersInput = document.getElementById('partnersInput');
        var programSelect = document.getElementById('programId');
        var programTypeSelect = document.getElementById('programType');

        if (crossCollabCheckbox && partnersField && partnersInput) {
            var togglePartners = function () {
                var isChecked = crossCollabCheckbox.checked;
                partnersField.classList.toggle('d-none', !isChecked);
                partnersInput.required = isChecked;
                if (!isChecked) {
                    partnersInput.value = '';
                }
            };

            crossCollabCheckbox.addEventListener('change', togglePartners);
            togglePartners();
        }

        if (programSelect && programTypeSelect) {
            var syncProgramType = function () {
                var selectedOption = programSelect.options[programSelect.selectedIndex];
                if (!selectedOption) return;

                var selectedType = selectedOption.getAttribute('data-program-type');
                if (selectedType) {
                    programTypeSelect.value = selectedType;
                }
            };

            programSelect.addEventListener('change', syncProgramType);
        }
    });
</script>
