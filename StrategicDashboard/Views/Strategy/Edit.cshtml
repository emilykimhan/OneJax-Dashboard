@model OneJaxDashboard.Models.Strategy
@using System.Collections.Generic

@{
    var successMessage = TempData["SuccessMessage"] as string;

    // Normalize FY formats (supports "2025/2026" <-> "25/26")
    Func<string?, string?> ToShortFY = (fy) =>
    {
        if (string.IsNullOrWhiteSpace(fy)) return null;
        fy = fy.Trim();

        // 2025/2026 -> 25/26
        if (fy.Length >= 9 && fy.Contains("/"))
        {
            var parts = fy.Split('/');
            if (parts.Length == 2 && parts[0].Length == 4 && parts[1].Length == 4)
            {
                return parts[0].Substring(2, 2) + "/" + parts[1].Substring(2, 2);
            }
        }

        // already short
        if (fy.Length == 5 && fy[2] == '/')
        {
            return fy;
        }

        return fy;
    };

    Func<string?, string?> ToLongFY = (fy) =>
    {
        if (string.IsNullOrWhiteSpace(fy)) return null;
        fy = fy.Trim();

        // 25/26 -> 2025/2026 (assumes 20xx)
        if (fy.Length == 5 && fy[2] == '/')
        {
            var parts = fy.Split('/');
            if (parts.Length == 2)
            {
                return "20" + parts[0] + "/20" + parts[1];
            }
        }

        // already long
        if (fy.Length >= 9 && fy.Contains("/"))
        {
            return fy;
        }

        return fy;
    };

    var existingFYShort = ToShortFY(Model?.EventFYear);
    var existingFYLong = ToLongFY(Model?.EventFYear);
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success alert-dismissible fade show text-center mt-3" role="alert"
        style="max-width: 600px; margin: 0 auto;">
        @successMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    // same goals list as Index.cshtml
    var goals = new List<dynamic>
{
new { Id = 1, Name = "Organizational Building" },
new { Id = 2, Name = "Financial Sustainability" },
new { Id = 3, Name = "Identity/Value Proposition" },
new { Id = 4, Name = "Community Engagement" }
};
}

<style>
    :root {
        --onejax-blue: #0070AD;
        --onejax-teal: #00A3AD;
        --onejax-navy: #102840;
        --onejax-gold: #E6B500;
        --onejax-light: #F7F9FB;
    }

    body {
        background-color: var(--onejax-light);
        font-family: 'Poppins', sans-serif;
        color: var(--onejax-navy);
    }

    h1,
    h2,
    h3,
    h4,
    h5 {
        color: var(--onejax-navy);
        font-weight: 700;
    }

    .card {
        background-color: #fff;
        border-radius: 20px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
        border: none;
    }

    .form-control,
    .form-select {
        border-radius: 12px;
        border: 1px solid #d0d7de;
        padding: 0.7rem 0.9rem;
        background-color: #ffffff;
        box-shadow: 0 1px 0 rgba(16, 40, 64, 0.03);
    }

    .form-control:focus,
    .form-select:focus {
        border-color: rgba(0, 112, 173, 0.55);
        box-shadow: 0 0 0 0.2rem rgba(0, 112, 173, 0.15);
    }

    .form-label {
        font-weight: 700;
        color: var(--onejax-navy);
        letter-spacing: 0.2px;
    }

    .btn-primary {
        background-color: var(--onejax-blue);
        border-color: var(--onejax-blue);
        border-radius: 50px;
        font-weight: 500;
        transition: all 0.3s ease-in-out;
    }

    .btn-primary:hover {
        background-color: var(--onejax-teal);
        border-color: var(--onejax-teal);
        transform: scale(1.02);
    }
</style>

<div class="container my-5">
    <!-- Header (matches other pages) -->
    <div class="text-center mb-5">
        <h1 class="fw-bold text-uppercase" style="color: var(--onejax-blue);">
            OneJax Strategic Dashboard
        </h1>
        <p class="text-secondary fs-5">
            Track and manage programs by strategic goals
        </p>
    </div>

    <!-- Edit Event Card -->
    <div class="card shadow-lg border-0 rounded-4 mb-5">
        <div class="card-body p-4">
            <h3 class="fw-bold text-uppercase mb-4" style="color: var(--onejax-blue);">
                Edit Program
            </h3>

            <form asp-action="Edit" asp-controller="Strategy" method="post" class="row g-3">
                <input type="hidden" name="id" value="@Model?.Id" />

                <div class="col-12">
                    <label class="form-label fw-semibold">Program Name</label>
                    <input type="text" name="programName" class="form-control" value="@Model?.ProgramName" required />
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Event Name</label>
                    <input type="text" name="eventName" class="form-control" value="@Model?.Name" />
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Program Type</label>
                    <select name="eventType" class="form-select" required>
                        @if (string.IsNullOrWhiteSpace(Model?.EventType))
                        {
                            <option value="" disabled selected>Select Program Type</option>
                        }
                        else
                        {
                            <option value="" disabled>Select Program Type</option>
                        }

                        @if (Model?.EventType == "Youth")
                        {
                            <option value="Youth" selected>Youth</option>
                        }
                        else
                        {
                            <option value="Youth">Youth</option>
                        }

                        @if (Model?.EventType == "Humanitarian")
                        {
                            <option value="Humanitarian" selected>Humanitarian</option>
                        }
                        else
                        {
                            <option value="Humanitarian">Humanitarian</option>
                        }

                        @if (Model?.EventType == "Interfaith")
                        {
                            <option value="Interfaith" selected>Interfaith</option>
                        }
                        else
                        {
                            <option value="Interfaith">Interfaith</option>
                        }

                        @if (Model?.EventType == "Community")
                        {
                            <option value="Community" selected>Community</option>
                        }
                        else
                        {
                            <option value="Community">Community</option>
                        }
                    </select>
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Assign to Goal</label>
                    <select name="goalId" class="form-select" required>
                        <option value="">Select a Goal</option>
                        @foreach (var goal in goals)
                        {
                            if (goal.Id == Model?.StrategicGoalId)
                            {
                                <option value="@goal.Id" selected>@goal.Name</option>
                            }
                            else
                            {
                                <option value="@goal.Id">@goal.Name</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Fiscal Year</label>
                    <select name="fiscalYear" class="form-select" required>
                        @if (string.IsNullOrWhiteSpace(existingFYShort) && string.IsNullOrWhiteSpace(existingFYLong))
                        {
                            <option value="" disabled selected>Select Fiscal Year</option>
                        }
                        else
                        {
                            <option value="" disabled>Select Fiscal Year</option>
                        }

                        @if (existingFYShort == "25/26" || existingFYLong == "2025/2026")
                        {
                            <option value="25/26" selected>2025/2026</option>
                        }
                        else
                        {
                            <option value="25/26">2025/2026</option>
                        }

                        @if (existingFYShort == "26/27" || existingFYLong == "2026/2027")
                        {
                            <option value="26/27" selected>2026/2027</option>
                        }
                        else
                        {
                            <option value="26/27">2026/2027</option>
                        }

                        @if (existingFYShort == "27/28" || existingFYLong == "2027/2028")
                        {
                            <option value="27/28" selected>2027/2028</option>
                        }
                        else
                        {
                            <option value="27/28">2027/2028</option>
                        }
                    </select>
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Event Date</label>
                    <input type="date" name="eventDate" class="form-control" value="@Model?.Date" min="2020-01-01"
                        max="9999-12-31" />
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-semibold">Event Time</label>
                    <input type="time" name="eventTime" class="form-control" value="@Model?.Time" />
                </div>

                <div class="col-12">
                    <label class="form-label fw-semibold">Event Description</label>
                    <textarea name="eventDescription" class="form-control" rows="3"
                        required>@Model?.Description</textarea>
                </div>

                <div class="col-12">
                    <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-semibold">Save
                        Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>