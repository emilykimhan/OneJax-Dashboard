@model List<Strategy>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var successMessage = TempData["SuccessMessage"] as string;

    var goals = new List<dynamic>
{
new { Id = 1, Name = "Organizational Building" },
new { Id = 2, Name = "Financial Sustainability" },
new { Id = 3, Name = "Identity/Value Proposition" },
new { Id = 4, Name = "Community Engagement" }
};
}

<!-- OneJax Color Theme -->
<style>
 :root {
        --onejax-blue: #0070AD;
        --onejax-teal: #00A3AD;
        --onejax-navy: #102840;
        --onejax-gold: #93d2de;
        --onejax-light: #F7F9FB;
    }

    body {
        background-color: var(--onejax-light);
        font-family: 'Poppins', sans-serif;
        color: var(--onejax-navy);
    }

    h1,
    h2,
    h3,
    h4,
    h5 {
        color: var(--onejax-navy);
        font-weight: 700;
    }

    .btn-primary {
        background-color: var(--onejax-blue);
        border-color: var(--onejax-blue);
        border-radius: 50px;
        font-weight: 500;
        transition: all 0.3s ease-in-out;
    }

    .btn-primary:hover {
        background-color: var(--onejax-teal);
        border-color: var(--onejax-teal);
        transform: scale(1.02);
    }

    .card {
        background-color: #fff;
        border-radius: 20px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
        border: none;
    }

    .event-card-title {
        font-weight: 700;
        color: var(--onejax-navy);
        margin: 0;
    }

    .event-card-desc {
        color: #6c757d;
        margin: 0.35rem 0 0.75rem 0;
        line-height: 1.35;
    }
    .event-meta-row {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        align-items: center;
        margin-top: 0.25rem;
    }

    .badge-pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 0.28rem 0.65rem;
        border-radius: 999px;
        font-size: 0.78rem;
        font-weight: 600;
        white-space: nowrap;
    }

    .badge-goal {
        background-color: var(--onejax-gold);
        color: var(--onejax-navy);
    }

    .badge-type {
        background-color: var(--onejax-teal);
        color: #fff;
    }

    .event-datetime {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: var(--onejax-blue);
        font-weight: 600;
        font-size: 0.85rem;
    }

    .event-card-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        margin-top: 0.25rem;
    }

    .nav-pills .nav-link {
        color: var(--onejax-navy);
        border-radius: 25px;
        background-color: #fff;
        border: 1px solid transparent;
        transition: all 0.3s ease-in-out;
        padding: 8px 16px;
    }

    .nav-pills .nav-link.active {
        background-color: var(--onejax-blue);
        color: #fff;
        box-shadow: 0 4px 10px rgba(0, 112, 173, 0.3);
    }

    .nav-pills .nav-link:hover {
        background-color: var(--onejax-teal);
        color: #fff;
        transform: scale(1.03);
    }

    .form-control,
    .form-select {
        border-radius: 12px;
        border: 1px solid #d0d7de;
        padding: 0.7rem 0.9rem;
        background-color: #ffffff;
        box-shadow: 0 1px 0 rgba(16, 40, 64, 0.03);
    }

    .form-control:focus,
    .form-select:focus {
        border-color: rgba(0, 112, 173, 0.55);
        box-shadow: 0 0 0 0.2rem rgba(0, 112, 173, 0.15);
    }

    .form-label {
        font-weight: 700;
        color: var(--onejax-navy);
        letter-spacing: 0.2px;
    }

    .toast-success {
        background-color: var(--onejax-teal);
        color: #fff;
        border-radius: 10px;
        font-weight: 500;
    }

    .toast-success::before {
        content: "✅ ";
    }

    .event-card-date {
        color: var(--onejax-blue);
        font-weight: 500;
    }

    .event-card-goal {
        color: var(--onejax-navy);
        font-size: 0.9rem;
    }

    .success-text {
        color: #00A676;
        font-weight: 600;
        font-size: 1rem;
        letter-spacing: 0.5px;
        animation: fadeInOut 4s ease-in-out forwards;
    }

    .create-event-btn {
        background-color: #0d6efd;
        /* your current blue */
        color: #fff;
        border: none;
        transition: background-color 0.25s ease, transform 0.15s ease;
    }

    .create-event-btn:hover {
        background-color: #19b88f;
        /* green */
        color: #fff;
        transform: translateY(-1px);
        /* subtle lift, optional */
    }

    .btn-primary:hover {
        background-color: #19b88f !important;
        border-color: #19b88f !important;
    }

    @@keyframes fadeInOut {
        0% {
            opacity: 0;
            transform: translateY(-10px);
        }

        10% {
            opacity: 1;
            transform: translateY(0);
        }

        90% {
            opacity: 1;
            transform: translateY(0);
        }

        100% {
            opacity: 0;
            transform: translateY(-10px);
        }
    }

    /* ===== Row/List Event Layout (new) ===== */
    .event-row {
        display: flex;
        gap: 14px;
        padding: 16px;
        border-radius: 18px;
        border: 1px solid rgba(16, 40, 64, 0.08);
        background: #fff;
        box-shadow: 0 4px 18px rgba(0, 0, 0, 0.04);
        align-items: stretch;
    }

    .event-row-left {
        flex: 1;
        min-width: 0;
    }

    .event-row-title {
        font-weight: 800;
        color: var(--onejax-navy);
        font-size: 1.05rem;
        margin: 0;
        line-height: 1.15;
        word-break: break-word;
    }

    .event-row-subtitle {
        margin-top: 4px;
        font-size: 0.9rem;
        color: #516273;
        font-weight: 600;
        word-break: break-word;
    }

    .event-row-desc {
        margin-top: 8px;
        color: #6c757d;
        line-height: 1.35;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .event-row-right {
        width: 240px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        align-items: flex-end;
        gap: 10px;
    }

    .event-row-top {
        width: 100%;
        display: flex;
        justify-content: flex-end;
        align-items: flex-start;
        gap: 10px;
    }

    .event-row-datetime {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 4px;
        align-items: flex-end;
        color: var(--onejax-blue);
        font-weight: 700;
        font-size: 0.9rem;
    }

    .event-row-datetime small {
        color: #6c757d;
        font-weight: 600;
    }

    .event-row-badges {
        margin-top: 10px;
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
    }

    /* Color strip by Program Type */
    .event-row.type-youth { border-left: 7px solid #a0ce3f; }
    .event-row.type-humanitarian { border-left: 7px solid #ad3385; }
    .event-row.type-interfaith { border-left: 7px solid #8d478a; }
    .event-row.type-community { border-left: 7px solid #b48a78; }

    (max-width: 992px) {
        .event-row { flex-direction: column; }
        .event-row-right { width: 100%; align-items: flex-start; }
        .event-row-datetime { align-items: flex-start; }
        .event-row-top { justify-content: space-between; }
    }

    /* ===== Events Table (basic + organized) ===== */
    .events-table-wrap {
        background: #fff;
        border: 1px solid rgba(16, 40, 64, 0.08);
        border-radius: 14px;
        overflow: visible !important;   /* ✅ allow dropdown to escape */
        position: relative;
    }
    .events-table-wrap .dropdown-menu {
        z-index: 9999;
    }

    .events-table-wrap td,
    .events-table-wrap th {
        overflow: visible;
    }
    table.events-table {
        width: 100%;
        border-collapse: collapse;
        margin: 0;
    }

    table.events-table thead th {
        background: var(--onejax-blue);
        color: #fff;
        font-weight: 800;
        font-size: 0.85rem;
        letter-spacing: 0.4px;
        text-transform: uppercase;
        padding: 12px 14px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.25);
        white-space: nowrap;
    }

    table.events-table tbody td {
        padding: 12px 14px;
        border-bottom: 1px solid rgba(16, 40, 64, 0.06);
        vertical-align: top;
        color: #213547;
        font-weight: 500;
    }

    table.events-table tbody tr:hover {
        background: rgba(0, 112, 173, 0.04);
    }

    .cell-muted {
        color: #6c757d;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .cell-title {
        font-weight: 800;
        color: var(--onejax-navy);
    }

    .cell-subtitle {
        margin-top: 3px;
        color: #546678;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .type-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 0.25rem 0.6rem;
        border-radius: 999px;
        background: transparent;
        color: #fff;
        font-weight: 800;
        font-size: 0.85rem;
        white-space: nowrap;
    }

    .fy-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 0.25rem 0.6rem;
        border-radius: 999px;
        background: rgba(0, 112, 173, 0.10);
        color: var(--onejax-navy);
        font-weight: 700;
        font-size: 0.85rem;
        white-space: nowrap;
    }

    .actions-cell {
        white-space: nowrap;
        text-align: right;
    }

    (max-width: 992px) {
        table.events-table thead { display: none; }
        table.events-table, table.events-table tbody, table.events-table tr, table.events-table td { display: block; width: 100%; }
        table.events-table tr { border-bottom: 1px solid rgba(16, 40, 64, 0.08); }
        table.events-table tbody td { border: none; padding: 10px 14px; }
        table.events-table tbody td::before {
            content: attr(data-label);
            display: block;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            font-size: 0.75rem;
            color: #6c757d;
            margin-bottom: 4px;
        }
        .actions-cell { text-align: left; }
    }
</style>

<style>
    /* Goal badge colors */
    .goal-youth { background-color: #a0ce3f; color: #fff; }
    .goal-humanitarian { background-color: #ad3385; color: #fff; }
    .goal-interfaith { background-color: #8d478a; color: #fff; }
    .goal-community { background-color: #b48a78; color: #fff; }

    /* Event type badge colors */
    .type-youth { background-color: #a0ce3f; color: #fff; }
    .type-humanitarian { background-color: #ad3385; color: #fff; }
    .type-interfaith { background-color: #8d478a; color: #fff; }
    .type-community { background-color: #b48a78; color: #fff; }
</style>


<div class="container my-5">
    <!-- Header -->
    <div class="text-center mb-5">
        <h1 class="fw-bold text-uppercase" style="color: var(--onejax-blue);">OneJax Strategic Dashboard</h1>
        <p class="text-secondary fs-5">Track and manage programs by strategic goals</p>
    </div>

    <!-- View Events Button -->
    <div class="text-center mb-4">
        <a href="/Strategy/ViewEvents" class="btn" style="background-color: var(--onejax-blue); color: #fff; padding: 10px 22px; border-radius: 25px; 
                  font-weight: 600; box-shadow: 0 3px 8px rgba(0,0,0,0.15);">
            View Programs
        </a>
    </div>

    @if (ViewBag.SuccessMessage != null)
    {
        <div class="text-center mb-3">
            <span class="success-text">@ViewBag.SuccessMessage</span>
        </div>
    }
    <!-- Add New Event -->
    <div class="card shadow-lg border-0 rounded-4 mb-5">
        <div class="card-body p-4">
            <h3 class="fw-bold text-uppercase mb-4" style="color: var(--onejax-blue);">Add a New Program</h3>

<form asp-action="Add" method="post" class="row g-3">
<div class="col-12">
    <label class="form-label fw-semibold">Program Name</label>
    <input type="text" name="programName" class="form-control" placeholder="Enter program name" required />
</div>

<div class="col-md-6">
    <label class="form-label fw-semibold">Event Name </label>
    <input type="text" name="eventName" class="form-control" placeholder="Enter event name" />
</div>

<div class="col-md-6">
    <label class="form-label fw-semibold">Program Type</label>
    <select name="eventType" class="form-select" required>
        <option value="" selected disabled>Select Program Type</option>
        <option value="Youth">Youth</option>
        <option value="Interfaith">Interfaith</option>
        <option value="Humanitarian">Humanitarian</option>
        <option value="Community">Community</option>
    </select>
</div>

<div class="col-md-6">
    <label class="form-label fw-semibold">Assign to a Goal</label>
    <select name="goalId" class="form-select" required>
        <option value="" selected disabled>Select a Goal</option>
        @foreach (var goal in goals)
        {
            <option value="@goal.Id">@goal.Name</option>
        }
    </select>
</div>

<div class="col-md-6">
    <label class="form-label fw-semibold">Fiscal Year</label>
    <select name="fiscalYear" class="form-select" required>
        <option value="" selected disabled>Select Fiscal Year</option>
        <option value="25/26">25/26</option>
        <option value="26/27">26/27</option>
        <option value="27/28">27/28</option>
    </select>
</div>

<div class="col-md-6">
    <label class="form-label fw-semibold">Event Date</label>
    <input type="date" name="eventDate" class="form-control" min="2020-01-01" max="9999-12-31"/>
</div>

<div class="col-md-6">
    <label class="form-label fw-semibold">Event Time</label>
    <input type="time" name="eventTime" class="form-control" />
</div>

<div class="col-12">
    <label class="form-label fw-semibold">Description</label>
    <textarea name="eventDescription"
              class="form-control"
              rows="3"
              placeholder="Enter description"
              required></textarea>
</div>

<div class="col-12">
    <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-semibold">Add Program</button>
</div>
            </form>
        </div>
    </div>

    <!-- Tabs -->
    <ul class="nav nav-tabs mb-4 justify-content-center border-0" id="goalTabs" role="tablist">
        @foreach (var goal in goals)
        {
            <li class="nav-item" role="presentation">
                <button class="nav-link px-4 py-2 mx-1 @(goal == goals.First() ? "active" : "")" id="goal-@goal.Id-tab"
                    data-bs-toggle="tab" data-bs-target="#goal-@goal.Id" type="button" role="tab">
                    @goal.Name
                </button>
            </li>
        }
    </ul>

    <!-- Tab Content -->
    <div class="tab-content" id="goalTabsContent">
        @foreach (var goal in goals)
        {
            var goalEvents = Model.Where(e => e.StrategicGoalId == goal.Id).OrderByDescending(e => e.Id).ToList();

            <div class="tab-pane fade @(goal == goals.First() ? "show active" : "")" id="goal-@goal.Id" role="tabpanel">
                @if (goalEvents.Any())
                {
                    <div class="events-table-wrap">
                        <table class="events-table">
                            <thead>
                                <tr>
                                    <th>Program</th>
                                    <th>Event</th>
                                    <th>Type</th>
                                    <th>FY</th>
                                    <th>Date</th>
                                    <th>Time</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var e in goalEvents)
                                {
                                    // Display strings
                                    var program = string.IsNullOrWhiteSpace(e.ProgramName) ? "(No Program)" : e.ProgramName;
                                    var eventName = e.Name;

                                    // Format date/time
                                    var dateDisplay = e.Date;
                                    if (!string.IsNullOrWhiteSpace(e.Date) && DateTime.TryParse(e.Date, out var parsedDate))
                                    {
                                        dateDisplay = parsedDate.ToString("MM/dd/yyyy");
                                    }

                                    var timeDisplay = e.Time;
                                    if (!string.IsNullOrWhiteSpace(e.Time) && DateTime.TryParse(e.Time, out var parsedTime))
                                    {
                                        timeDisplay = parsedTime.ToString("h:mm tt");
                                    }

                                    <tr>
                                        <td data-label="Program">
                                            <div class="cell-title">@program</div>
                                        </td>

                                        <td data-label="Event">
                                            @if (!string.IsNullOrWhiteSpace(eventName) && eventName != program)
                                            {
                                                <div class="cell-subtitle">@eventName</div>
                                            }
                                            else
                                            {
                                                <div class="cell-muted">—</div>
                                            }
                                        </td>

                                        <td data-label="Type">
                                            @if (!string.IsNullOrWhiteSpace(e.EventType))
                                            {
                                                <span class="type-chip type-@e.EventType.ToLower()"><i class="bi bi-tag"></i> @e.EventType</span>
                                            }
                                            else
                                            {
                                                <span class="cell-muted">—</span>
                                            }
                                        </td>

                                        <td data-label="FY">
                                            @if (!string.IsNullOrWhiteSpace(e.EventFYear))
                                            {
                                                <span class="fy-chip"><i class="bi bi-calendar2-range"></i> @e.EventFYear</span>
                                            }
                                            else
                                            {
                                                <span class="cell-muted">—</span>
                                            }
                                        </td>

                                        <td data-label="Date">
                                            @if (!string.IsNullOrWhiteSpace(dateDisplay))
                                            {
                                                <span>@dateDisplay</span>
                                            }
                                            else
                                            {
                                                <span class="cell-muted">—</span>
                                            }
                                        </td>

                                        <td data-label="Time">
                                            @if (!string.IsNullOrWhiteSpace(timeDisplay))
                                            {
                                                <span>@timeDisplay</span>
                                            }
                                            else
                                            {
                                                <span class="cell-muted">—</span>
                                            }
                                        </td>

                                        <td class="actions-cell" data-label="Actions">
                                            <div class="dropdown">
                                                <button class="btn btn-light btn-sm border-0" type="button" data-bs-toggle="dropdown">
                                                    <i class="bi bi-three-dots fs-5 text-dark"></i>
                                                </button>
                                                <ul class="dropdown-menu dropdown-menu-end">
                                                    <li>
                                                        <a class="dropdown-item text-primary" asp-controller="Strategy"
                                                           asp-action="Edit" asp-route-id="@e.Id">
                                                            Edit
                                                        </a>
                                                    </li>
                                                    <li>
                                                        <button type="button" class="dropdown-item text-danger" data-bs-toggle="modal"
                                                                data-bs-target="#deleteConfirmModal" data-event-id="@e.Id">
                                                            Delete
                                                        </button>
                                                    </li>
                                                </ul>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-5">
                        <i class="bi bi-inbox fs-1"></i>
                        <p class="mt-3">No programs yet for this goal. Add one above!</p>
                    </div>
                }
            </div>
        }
    </div>
</div>
<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-labelledby="deleteConfirmLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-semibold" id="deleteConfirmLabel">
                    Delete Program?
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <p class="mb-2">
                    You’re about to permanently delete this Program. This action cannot be undone.
                </p>
                <p class="mb-3">
                    Type <strong>delete</strong> in lowercase to confirm.
                </p>

                <form id="deleteConfirmForm" asp-action="Delete" asp-controller="Strategy" method="post">
                    <!-- This will be filled dynamically when the modal opens -->
                    <input type="hidden" id="deleteEventId" name="id" />

                    <input type="text" id="deleteConfirmInput" class="form-control mb-3"
                        placeholder='Type "delete" to continue' />

                    <div class="d-flex justify-content-end gap-2">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                            Cancel
                        </button>
                        <button type="submit" class="btn btn-danger" id="deleteConfirmButton" disabled>
                            Delete
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var deleteModal = document.getElementById('deleteConfirmModal');
        var input = document.getElementById('deleteConfirmInput');
        var button = document.getElementById('deleteConfirmButton');
        var hiddenId = document.getElementById('deleteEventId');

        if (!deleteModal) return;

        // When the modal is about to be shown, get the event id from the button that opened it
        deleteModal.addEventListener('show.bs.modal', function (event) {
            var triggerButton = event.relatedTarget;
            var eventId = triggerButton.getAttribute('data-event-id');

            hiddenId.value = eventId;
            input.value = '';
            button.disabled = true;
        });

        // Enable Delete only when user typed "delete" in lowercase
        input.addEventListener('input', function () {
            if (input.value === 'delete') {
                button.disabled = false;
            } else {
                button.disabled = true;
            }
        });
    });
</script>

<script>
    const toastEl = document.querySelector('.toast');
    if (toastEl) {
        const toast = new bootstrap.Toast(toastEl, { delay: 4000 });
        toast.show();
    }
</script>