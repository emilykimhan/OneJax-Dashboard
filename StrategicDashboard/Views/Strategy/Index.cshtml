@model List<Strategy>
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var successMessage = TempData["SuccessMessage"] as string;
    var errorMessage = TempData["ErrorMessage"] as string;
    var programOptions = ViewBag.Programs as List<OneJaxDashboard.Models.Programs> ?? new List<OneJaxDashboard.Models.Programs>();
    var programTypeOptions = ViewBag.ProgramTypes as List<string> ?? new List<string>();
    var goals = ViewBag.Goals as List<SelectListItem> ?? new List<SelectListItem>();
    var formValues = ViewBag.FormValues as Dictionary<string, string> ?? new Dictionary<string, string>();
    var formErrors = ViewBag.FormErrors as Dictionary<string, string> ?? new Dictionary<string, string>();
    var pageErrorMessage = ViewBag.PageErrorMessage as string;
}

<!-- OneJax Color Theme -->
<style>
 :root {
        --onejax-blue: #0070AD;
        --onejax-teal: #00A3AD;
        --onejax-navy: #102840;
        --onejax-gold: #93d2de;
        --onejax-light: #F7F9FB;
    }

    body {
        background-color: var(--onejax-light);
        font-family: 'Poppins', sans-serif;
        color: var(--onejax-navy);
    }

    h1,
    h2,
    h3,
    h4,
    h5 {
        color: var(--onejax-navy);
        font-weight: 700;
    }

    .btn-primary {
        background-color: var(--onejax-blue);
        border-color: var(--onejax-blue);
        border-radius: 50px;
        font-weight: 500;
        transition: all 0.3s ease-in-out;
    }

    .btn-primary:hover {
        background-color: var(--onejax-teal);
        border-color: var(--onejax-teal);
        transform: scale(1.02);
    }

    .card {
        background-color: #fff;
        border-radius: 20px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
        border: none;
    }

    .event-card-title {
        font-weight: 700;
        color: var(--onejax-navy);
        margin: 0;
    }

    .event-card-desc {
        color: #6c757d;
        margin: 0.35rem 0 0.75rem 0;
        line-height: 1.35;
    }
    .event-meta-row {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        align-items: center;
        margin-top: 0.25rem;
    }

    .badge-pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 0.28rem 0.65rem;
        border-radius: 999px;
        font-size: 0.78rem;
        font-weight: 600;
        white-space: nowrap;
    }

    .badge-goal {
        background-color: var(--onejax-gold);
        color: var(--onejax-navy);
    }

    .badge-type {
        background-color: var(--onejax-teal);
        color: #fff;
    }

    .event-datetime {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: var(--onejax-blue);
        font-weight: 600;
        font-size: 0.85rem;
    }

    .event-card-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        margin-top: 0.25rem;
    }

    .nav-pills .nav-link {
        color: var(--onejax-navy);
        border-radius: 25px;
        background-color: #fff;
        border: 1px solid transparent;
        transition: all 0.3s ease-in-out;
        padding: 8px 16px;
    }

    .nav-pills .nav-link.active {
        background-color: var(--onejax-blue);
        color: #fff;
        box-shadow: 0 4px 10px rgba(0, 112, 173, 0.3);
    }

    .nav-pills .nav-link:hover {
        background-color: var(--onejax-teal);
        color: #fff;
        transform: scale(1.03);
    }

    .form-control,
    .form-select {
        border-radius: 12px;
        border: 1px solid #d0d7de;
        padding: 0.7rem 0.9rem;
        background-color: #ffffff;
        box-shadow: 0 1px 0 rgba(16, 40, 64, 0.03);
    }

    .form-control:focus,
    .form-select:focus {
        border-color: rgba(0, 112, 173, 0.55);
        box-shadow: 0 0 0 0.2rem rgba(0, 112, 173, 0.15);
    }

    .form-label {
        font-weight: 700;
        color: var(--onejax-navy);
        letter-spacing: 0.2px;
    }

    .toast-success {
        background-color: var(--onejax-teal);
        color: #fff;
        border-radius: 10px;
        font-weight: 500;
    }

    .toast-success::before {
        content: "✅ ";
    }

    .event-card-date {
        color: var(--onejax-blue);
        font-weight: 500;
    }

    .event-card-goal {
        color: var(--onejax-navy);
        font-size: 0.9rem;
    }

    .success-text {
        color: #00A676;
        font-weight: 600;
        font-size: 1rem;
        letter-spacing: 0.5px;
        animation: fadeInOut 4s ease-in-out forwards;
    }

    .field-error {
        color: #b42318;
        display: block;
        font-size: 0.875rem;
        font-weight: 600;
        margin-top: 0.35rem;
    }

    .create-event-btn {
        background-color: #0d6efd;
        /* your current blue */
        color: #fff;
        border: none;
        transition: background-color 0.25s ease, transform 0.15s ease;
    }

    .create-event-btn:hover {
        background-color: #19b88f;
        /* green */
        color: #fff;
        transform: translateY(-1px);
        /* subtle lift, optional */
    }

    .btn-primary:hover {
        background-color: #19b88f !important;
        border-color: #19b88f !important;
    }

    @@keyframes fadeInOut {
        0% {
            opacity: 0;
            transform: translateY(-10px);
        }

        10% {
            opacity: 1;
            transform: translateY(0);
        }

        90% {
            opacity: 1;
            transform: translateY(0);
        }

        100% {
            opacity: 0;
            transform: translateY(-10px);
        }
    }

    /* ===== Row/List Event Layout (new) ===== */
    .event-row {
        display: flex;
        gap: 14px;
        padding: 16px;
        border-radius: 18px;
        border: 1px solid rgba(16, 40, 64, 0.08);
        background: #fff;
        box-shadow: 0 4px 18px rgba(0, 0, 0, 0.04);
        align-items: stretch;
    }

    .event-row-left {
        flex: 1;
        min-width: 0;
    }

    .event-row-title {
        font-weight: 800;
        color: var(--onejax-navy);
        font-size: 1.05rem;
        margin: 0;
        line-height: 1.15;
        word-break: break-word;
    }

    .event-row-subtitle {
        margin-top: 4px;
        font-size: 0.9rem;
        color: #516273;
        font-weight: 600;
        word-break: break-word;
    }

    .event-row-desc {
        margin-top: 8px;
        color: #6c757d;
        line-height: 1.35;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .event-row-right {
        width: 240px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        align-items: flex-end;
        gap: 10px;
    }

    .event-row-top {
        width: 100%;
        display: flex;
        justify-content: flex-end;
        align-items: flex-start;
        gap: 10px;
    }

    .event-row-datetime {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 4px;
        align-items: flex-end;
        color: var(--onejax-blue);
        font-weight: 700;
        font-size: 0.9rem;
    }

    .event-row-datetime small {
        color: #6c757d;
        font-weight: 600;
    }

    .event-row-badges {
        margin-top: 10px;
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
    }

    /* Color strip by Program Type */
    .event-row.type-youth { border-left: 7px solid #a0ce3f; }
    .event-row.type-humanitarian { border-left: 7px solid #ad3385; }
    .event-row.type-interfaith { border-left: 7px solid #8d478a; }
    .event-row.type-community { border-left: 7px solid #b48a78; }

    (max-width: 992px) {
        .event-row { flex-direction: column; }
        .event-row-right { width: 100%; align-items: flex-start; }
        .event-row-datetime { align-items: flex-start; }
        .event-row-top { justify-content: space-between; }
    }

    /* ===== Events Table (basic + organized) ===== */
    .events-table-wrap {
        background: #fff;
        border: 1px solid rgba(16, 40, 64, 0.08);
        border-radius: 14px;
        overflow: visible !important;   /* ✅ allow dropdown to escape */
        position: relative;
    }
    .events-table-wrap .dropdown-menu {
        z-index: 9999;
    }

    .events-table-wrap td,
    .events-table-wrap th {
        overflow: visible;
    }
    table.events-table {
        width: 100%;
        border-collapse: collapse;
        margin: 0;
    }

    table.events-table thead th {
        background: var(--onejax-blue);
        color: #fff;
        font-weight: 800;
        font-size: 0.85rem;
        letter-spacing: 0.4px;
        text-transform: uppercase;
        padding: 12px 14px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.25);
        white-space: nowrap;
    }

    table.events-table tbody td {
        padding: 12px 14px;
        border-bottom: 1px solid rgba(16, 40, 64, 0.06);
        vertical-align: top;
        color: #213547;
        font-weight: 500;
    }

    table.events-table tbody tr:hover {
        background: rgba(0, 112, 173, 0.04);
    }

    .cell-muted {
        color: #6c757d;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .cell-title {
        font-weight: 800;
        color: var(--onejax-navy);
    }

    .cell-subtitle {
        margin-top: 3px;
        color: #546678;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .type-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 0.25rem 0.6rem;
        border-radius: 999px;
        background: transparent;
        color: #fff;
        font-weight: 800;
        font-size: 0.85rem;
        white-space: nowrap;
    }

    .fy-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 0.25rem 0.6rem;
        border-radius: 999px;
        background: rgba(0, 112, 173, 0.10);
        color: var(--onejax-navy);
        font-weight: 700;
        font-size: 0.85rem;
        white-space: nowrap;
    }

    .actions-cell {
        white-space: nowrap;
        text-align: right;
    }

    (max-width: 992px) {
        table.events-table thead { display: none; }
        table.events-table, table.events-table tbody, table.events-table tr, table.events-table td { display: block; width: 100%; }
        table.events-table tr { border-bottom: 1px solid rgba(16, 40, 64, 0.08); }
        table.events-table tbody td { border: none; padding: 10px 14px; }
        table.events-table tbody td::before {
            content: attr(data-label);
            display: block;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            font-size: 0.75rem;
            color: #6c757d;
            margin-bottom: 4px;
        }
        .actions-cell { text-align: left; }
    }
</style>

<style>
    /* Goal badge colors */
    .goal-youth { background-color: #a0ce3f; color: #fff; }
    .goal-humanitarian { background-color: #ad3385; color: #fff; }
    .goal-interfaith { background-color: #8d478a; color: #fff; }
    .goal-community { background-color: #b48a78; color: #fff; }

    /* Event type badge colors */
    .type-youth { background-color: #a0ce3f; color: #fff; }
    .type-humanitarian { background-color: #ad3385; color: #fff; }
    .type-interfaith { background-color: #8d478a; color: #fff; }
    .type-community { background-color: #b48a78; color: #fff; }
</style>


<div class="container my-5">
    <!-- Header -->
    <div class="text-center mb-3">
        <h1 class="fw-bold text-uppercase" style="color: var(--onejax-blue);">OneJax Strategic Dashboard</h1>
        <p class="text-secondary fs-5">Track and manage events by strategic goals</p> 
    </div>

    <!-- View Events Button -->
    <div class="text-center mb-3">
        <a href="/Strategy/ViewEvents" class="btn" style="background-color: var(--onejax-blue); color: #fff; padding: 10px 22px; border-radius: 25px; 
                  font-weight: 600; box-shadow: 0 3px 8px rgba(0,0,0,0.15);">
            View Events
        </a>
    </div>

    @if (ViewBag.SuccessMessage != null) 
    {
        <div class="text-center mb-3">
            <span class="success-text">@ViewBag.SuccessMessage</span>
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger text-center mb-3">@errorMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(pageErrorMessage))
    {
        <div class="alert alert-warning text-center mb-3">@pageErrorMessage</div>
    }
    @if (formErrors.TryGetValue("general", out var generalError))
    {
        <div class="alert alert-danger text-center mb-3">@generalError</div>
    }
    <!-- Add New Event -->
    <div class="card shadow-lg border-0 rounded-4 mb-5">
        <div class="card-body p-4">
            <h3 class="fw-bold text-uppercase mb-4" style="color: var(--onejax-blue);">Add Event</h3>

<form asp-action="Add" method="post" class="row g-3">
<div class="col-12">
    <label class="form-label fw-semibold">Program Name</label>
    <select name="programId" id="programId" class="form-select">
        <option value="" selected="@(formValues.TryGetValue("programId", out var selectedProgramIdValue) && !string.IsNullOrWhiteSpace(selectedProgramIdValue) ? null : "selected")">Select Program Name</option>
        @foreach (var p in programOptions)
        {
            if (formValues.TryGetValue("programId", out var selectedProgramId) && selectedProgramId == p.Id.ToString())
            {
                <option value="@p.Id" data-program-type="@p.ProgramType" selected>@p.ProgramName</option>
            }
            else
            {
                <option value="@p.Id" data-program-type="@p.ProgramType">@p.ProgramName</option>
            }
        }
    </select>
</div>

<div class="col-12">
    <label class="form-label fw-semibold">Program Type</label>
    <select name="programType" id="programType" class="form-select">
        <option value="" selected="@(formValues.TryGetValue("programType", out var selectedProgramTypeValue) && !string.IsNullOrWhiteSpace(selectedProgramTypeValue) ? null : "selected")">Select Program Type</option>
        @foreach (var type in programTypeOptions)
        {
            if (formValues.TryGetValue("programType", out var selectedProgramType) && selectedProgramType == type)
            {
                <option value="@type" selected>@type</option>
            }
            else
            {
                <option value="@type">@type</option>
            }
        }
    </select>
</div>

<div class="col-md-6">
    <label class="form-label fw-semibold">Event Name <span class="text-danger">*</span></label>
    <input type="text" name="eventName" class="form-control" placeholder="Enter event name" value="@(formValues.TryGetValue("eventName", out var eventNameValue) ? eventNameValue : string.Empty)" required />
    @if (formErrors.TryGetValue("eventName", out var eventNameError))
    {
        <span class="field-error">@eventNameError</span>
    }
</div>

<div class="col-md-6">
    <label class="form-label fw-semibold">Cross Collaboration</label>
    <div class="form-check mt-2">
        <input class="form-check-input" type="checkbox" id="isCrossCollaboration" name="isCrossCollaboration" value="true" @(formValues.TryGetValue("isCrossCollaboration", out var isCrossCollaborationValue) && isCrossCollaborationValue == "true" ? "checked" : null) />
        <label class="form-check-label fw-semibold" for="isCrossCollaboration">
            Yes, this is a cross collaboration
        </label>
    </div>
    <small class="text-muted">Unchecked means No.</small>
</div>

<div class="col-md-6 d-none" id="partnersField">
    <label class="form-label fw-semibold">Partners</label>
    <input type="text" name="partners" id="partnersInput" class="form-control" placeholder="Enter partner organizations" value="@(formValues.TryGetValue("partners", out var partnersValue) ? partnersValue : string.Empty)" />
</div>

<div class="col-md-6">
    <label class="form-label fw-semibold">Assign to a Goal <span class="text-danger">*</span></label>
    <select name="goalId" class="form-select" required>
        <option value="" selected="@(formValues.TryGetValue("goalId", out var selectedGoalIdValue) && !string.IsNullOrWhiteSpace(selectedGoalIdValue) ? null : "selected")" disabled>Select a Goal</option>
        @foreach (var goal in goals)
        {
            if (formValues.TryGetValue("goalId", out var selectedGoalId) && selectedGoalId == goal.Value)
            {
                <option value="@goal.Value" selected>@goal.Text</option>
            }
            else
            {
                <option value="@goal.Value">@goal.Text</option>
            }
        }
    </select>
    @if (formErrors.TryGetValue("goalId", out var goalError))
    {
        <span class="field-error">@goalError</span>
    }
</div>

<div class="col-md-6">
    <label class="form-label fw-semibold">Event Date <span class="text-danger">*</span></label>
    <input type="date" name="eventDate" class="form-control" min="2020-01-01" max="2030-12-31" value="@(formValues.TryGetValue("eventDate", out var eventDateValue) ? eventDateValue : string.Empty)" required />
    @if (formErrors.TryGetValue("eventDate", out var eventDateError))
    {
        <span class="field-error">@eventDateError</span>
    }
</div>

<div class="col-md-6">
    <label class="form-label fw-semibold">Event Time</label>
    <input type="time" name="eventTime" class="form-control" value="@(formValues.TryGetValue("eventTime", out var eventTimeValue) ? eventTimeValue : string.Empty)" />
</div>

<div class="col-12">
    <label class="form-label fw-semibold">Description</label>
    <textarea name="eventDescription"
              class="form-control"
              rows="3"
              placeholder="Enter description">@(formValues.TryGetValue("eventDescription", out var eventDescriptionValue) ? eventDescriptionValue : string.Empty)</textarea>
</div>

<div class="col-12">
    <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-semibold">Add Event</button>
</div>
            </form>
        </div>
    </div>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        var crossCollabCheckbox = document.getElementById('isCrossCollaboration');
        var partnersField = document.getElementById('partnersField');
        var partnersInput = document.getElementById('partnersInput');
        var programSelect = document.getElementById('programId');
        var programTypeSelect = document.getElementById('programType');

        if (crossCollabCheckbox && partnersField && partnersInput) {
            var togglePartners = function () {
                var isChecked = crossCollabCheckbox.checked;
                partnersField.classList.toggle('d-none', !isChecked);
                if (!isChecked) {
                    partnersInput.value = '';
                }
            };

            crossCollabCheckbox.addEventListener('change', togglePartners);
            togglePartners();
        }

        if (programSelect && programTypeSelect) {
            var syncProgramType = function () {
                var selectedOption = programSelect.options[programSelect.selectedIndex];
                if (!selectedOption) return;

                var selectedType = selectedOption.getAttribute('data-program-type');
                if (selectedType) {
                    programTypeSelect.value = selectedType;
                }
            };

            programSelect.addEventListener('change', syncProgramType);
        }
    });
</script>

<script>
    const toastEl = document.querySelector('.toast');
    if (toastEl) {
        const toast = new bootstrap.Toast(toastEl, { delay: 4000 });
        toast.show();
    }
</script>
