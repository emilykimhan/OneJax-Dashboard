@model OneJaxDashboard.Models.FirstTime_38D
@{
    ViewData["Title"] = "First-Time Participants";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card p-4"
                 style="background-color:var(--onejax-white);
                        box-shadow:0 4px 24px rgba(0,0,0,0.08);
                        border-radius:24px;">

                <!-- Header -->
                <div class="d-flex align-items-center mb-4">
                    <a href="/CommunityEngagement"
                       class="btn btn-outline-secondary me-3"
                       style="border-radius:8px;">
                        ← Back
                    </a>
                    <h2 class="mb-0" style="color:var(--onejax-navy);">First-Time Participants</h2>
                </div>

                <p class="text-center mb-4" style="color:var(--onejax-gray);">
                    Track first-time participants — Goal: Ensure 25% of attendees are first-time participants across programs.
                </p>

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success text-center" style="border-radius:12px;">
                        @TempData["Success"]
                    </div>

                    @if (ViewBag.ShowNewEntryButton == true)
                    {
                        <div class="text-center mb-4">
                            <a href="/CommFirst38D/Index" class="btn btn-primary btn-lg"
                               style="background-color:var(--onejax-navy); border-color:var(--onejax-navy); border-radius:12px;">
                                Add New Entry
                            </a>
                        </div>
                    }
                }

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger text-center" style="border-radius:12px;">
                        @TempData["Error"]
                    </div>
                }

                <!-- Entry Form -->
                @if (ViewBag.ShowNewEntryButton != true)
                {
                    <div class="survey-form">
                        <h4 class="mb-4 text-center" style="color:var(--onejax-navy);">New First-Time Participant Entry</h4>

                        <form asp-controller="CommFirst38D" asp-action="Index" method="post" novalidate>
                            @Html.AntiForgeryToken()

                            <div class="row">
                                <!-- Fiscal Year -->
                                <div class="col-md-4 mb-3">
                                    <label asp-for="FiscalYear" class="form-label fw-bold">Fiscal Year</label>
                                    <select asp-for="FiscalYear" class="form-select" required>
                                        <option value="">-- Select Fiscal Year --</option>
                                        <option value="FY2025-2026">FY2025-2026</option>
                                        <option value="FY2026-2027">FY2026-2027</option>
                                        <option value="FY2027-2028">FY2027-2028</option>
                                        <option value="FY2028-2029">FY2028-2029</option>
                                        <option value="FY2029-2030">FY2029-2030</option>
                                    </select>
                                    <span asp-validation-for="FiscalYear" class="text-danger"></span>
                                </div>

                                <!-- Event (Strategy dropdown) -->
                                <div class="col-md-8 mb-3">
                                    <label asp-for="StrategyId" class="form-label fw-bold">Event</label>
                                    <select asp-for="StrategyId" class="form-select" asp-items="ViewBag.Strategies" required>
                                        <option value="">-- Select Event --</option>
                                    </select>
                                    <span asp-validation-for="StrategyId" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="row">
                                <!-- Total Attendees -->
                                <div class="col-md-6 mb-3">
                                    <label asp-for="TotalAttendees" class="form-label fw-bold">Total Number of Attendees</label>
                                    <input asp-for="TotalAttendees" type="number" class="form-control"
                                           placeholder="e.g. 200" min="1" max="100000" required />
                                    <span asp-validation-for="TotalAttendees" class="text-danger"></span>
                                </div>

                                <!-- Number of First-Time Participants -->
                                <div class="col-md-6 mb-3">
                                    <label asp-for="NumberOfFirstTimeParticipants" class="form-label fw-bold">Number of First-Time Participants</label>
                                    <input asp-for="NumberOfFirstTimeParticipants" type="number" class="form-control"
                                           placeholder="e.g. 50" min="0" max="100000" required />
                                    <span asp-validation-for="NumberOfFirstTimeParticipants" class="text-danger"></span>
                                    <small class="form-text text-muted">Target: 25% or more of total attendees</small>
                                </div>
                            </div>

                            <!-- Submit -->
                            <div class="text-center mt-4">
                                <button type="submit" class="btn btn-primary btn-lg px-5 py-3"
                                        style="background-color:var(--onejax-navy); border-color:var(--onejax-navy); border-radius:12px; font-weight:600;">
                                    Submit Record
                                </button>
                            </div>
                        </form>
                    </div>
                }

            </div>
        </div>
    </div>
</div>

<style>
    .survey-form {
        padding: 1.5rem;
        background: #f8f9fa;
        border-radius: 12px;
        margin-top: 1rem;
    }

    .form-label {
        color: var(--onejax-navy);
        margin-bottom: 0.4rem;
    }

    .form-control:focus,
    .form-select:focus {
        border-color: var(--onejax-navy);
        box-shadow: 0 0 0 0.2rem rgba(0, 123, 191, 0.25);
    }

    .card { border: none; }

    .text-danger {
        font-size: 0.875rem;
        margin-top: 0.25rem;
        display: block;
    }

    .btn-outline-secondary {
        border-color: var(--onejax-navy);
        color: var(--onejax-navy);
    }

    .btn-outline-secondary:hover {
        background-color: var(--onejax-navy);
        border-color: var(--onejax-navy);
        color: white;
    }

    input[type="number"]::-webkit-inner-spin-button,
    input[type="number"]::-webkit-outer-spin-button {
        opacity: 1;
    }
</style>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
