                    <a href="/Interfaith11D" class="btn btn-primary btn-lg px-5 py-3"
                       style="background-color:var(--onejax-navy); border-color:var(--onejax-navy); 
                              border-radius: 12px; font-weight: 600;">
                        Enter Interfaith Events
                    </a>
                </div>
            </div>
    </div>

    <div class="col-md-6">
            <div class="card p-4"
                 style="background-color:var(--onejax-white);
