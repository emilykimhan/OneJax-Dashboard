@{
    ViewData["Title"] = "Community Engagement";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container mt-4">
    <!-- Back Button -->
    <div class="mb-3">
        <a href="/DataEntry" 
           class="btn btn-outline-secondary"
           style="border-radius: 8px;">
            ← Back to the Goals
        </a>
    </div>
    
    <div class="row">
    <div class="col-md-6">
            <div class="card p-4"
                 style="background-color:var(--onejax-white);
