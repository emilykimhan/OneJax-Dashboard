@model IEnumerable<OneJaxDashboard.Models.ActivityLogEntry>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "My Activity Log";
    var fullName = (ViewData["FullName"] as string) ?? string.Empty;
    var displayName = string.IsNullOrWhiteSpace(fullName) ? (User.Identity?.Name ?? "") : fullName;
    var easternTimeZone = Context.RequestServices.GetRequiredService<TimeZoneInfo>();

    DateTime ToEastern(DateTime timestamp)
    {
        var utcTimestamp = timestamp.Kind == DateTimeKind.Utc
            ? timestamp
            : DateTime.SpecifyKind(timestamp, DateTimeKind.Utc);
        return TimeZoneInfo.ConvertTimeFromUtc(utcTimestamp, easternTimeZone);
    }
}

<div class="row mb-4">
    <div class="col-md-12">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2 class="fw-bold mb-1" style="color:var(--onejax-navy);">My Activity Log</h2>
                <p class="text-muted mb-0">All activity recorded for @displayName</p>
            </div>
            <a class="btn btn-outline-secondary" href="/StaffPortal/Index">
                <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
            </a>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th class="py-3 px-4">Timestamp</th>
                            <th class="py-3">User</th>
                            <th class="py-3">Action</th>
                            <th class="py-3">Entity</th>
                            <th class="py-3 pe-4">Details</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var activity in Model)
                        {
                            <tr>
                                <td class="py-3 px-4">
                                    <small>@ToEastern(activity.Timestamp).ToString("MM/dd/yyyy hh:mm:ss tt")</small>
                                </td>
                                <td class="py-3">
                                    <span class="badge bg-secondary">@activity.Username</span>
                                </td>
                                <td class="py-3">
                                    <strong>@activity.Action</strong>
                                </td>
                                <td class="py-3">
                                    @if (!string.IsNullOrEmpty(activity.EntityType))
                                    {
                                        <span class="badge bg-info">@activity.EntityType @(activity.EntityId.HasValue ? $"#{activity.EntityId}" : "")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td class="py-3 pe-4">
                                    <small class="text-muted">@(activity.Notes ?? "—")</small>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-clock-history display-1 text-muted"></i>
                <p class="text-muted mt-3 mb-0">No activity recorded yet</p>
            </div>
        }
    </div>
</div>
