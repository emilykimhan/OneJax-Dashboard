@model OneJaxDashboard.Models.demographics_8D
@{
    ViewData["Title"] = "Program Demographics";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card p-4"
                 style="background-color:var(--onejax-white);
                        box-shadow:0 4px 24px rgba(0,0,0,0.08);
                        border-radius:24px;">
                
                <!-- Header -->
                <div class="d-flex align-items-center mb-4">
                          <a href="/ValueProposition" 
                       class="btn btn-outline-secondary me-3"
                       style="border-radius: 8px;">
                        ← Back
                    </a>
                    <h2 class="mb-0" style="color:var(--onejax-navy);">Program Demographics</h2>
                </div>
                
                <p class="text-center mb-4" style="color:var(--onejax-gray);">
                    Track participant demographics - Goal: 20% increase in representation from underrepresented ZIP codes by end of 2025
                </p>

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success text-center" style="border-radius: 12px;">
                        @TempData["Success"]
                    </div>
                    
                    @if (ViewBag.ShowNewEntryButton == true)
                    {
                        <div class="text-center mb-4">
                            <a href="/identityDemo_8D/Index" class="btn btn-primary btn-lg"
                               style="background-color:var(--onejax-navy); border-color:var(--onejax-navy); border-radius: 12px;">
                                Add New Entry
                            </a>
                        </div>
                    }
                }

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger text-center" style="border-radius: 12px;">
                        @TempData["Error"]
                    </div>
                }

                <!-- Input Form -->
                @if (ViewBag.ShowNewEntryButton != true)
                {
                    <form asp-controller="identityDemo_8D" asp-action="Index" method="post" id="programDemographicsForm">
                        <div class="row">
                            <!-- Event Dropdown -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="StrategyId" class="form-label fw-bold">Event</label>
                                <select asp-for="StrategyId" class="form-select" asp-items="ViewBag.Strategies" required>
                                    <option value="">-- Select Event --</option>
                                </select>
                                <span asp-validation-for="StrategyId" class="text-danger"></span>
                            </div>

                            <!-- Year -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="Year" class="form-label fw-bold">Year</label>
                                <input asp-for="Year" type="number" class="form-control" 
                                       placeholder="Enter year (e.g., 2025)" min="2020" max="2100" required />
                                <span asp-validation-for="Year" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-12 mb-3">
                                <label asp-for="ZipCodes" class="form-label fw-bold">Zip Codes</label>
                                <input asp-for="ZipCodes" type="hidden" id="ZipCodes" maxlength="1000" />
                                <div class="zip-entry-panel">
                                    <div class="row g-2 align-items-end">
                                        <div class="col-md-7">
                                            <label for="zipCodeInput" class="form-label small fw-bold">ZIP code</label>
                                            <input id="zipCodeInput" type="text" class="form-control" inputmode="numeric" maxlength="5" placeholder="e.g., 32211" />
                                        </div>
                                        <div class="col-md-3">
                                            <label for="zipCountInput" class="form-label small fw-bold">Times recorded</label>
                                            <input id="zipCountInput" type="number" class="form-control" min="1" max="999" value="1" />
                                        </div>
                                        <div class="col-md-2 d-grid">
                                            <button type="button" class="btn btn-outline-primary" id="addZipCountButton">Add</button>
                                        </div>
                                    </div>
                                    <div class="zip-count-list mt-3" id="zipCountList">
                                        <div class="zip-empty-state">No ZIP codes added yet.</div>
                                    </div>
                                </div>
                                <span asp-validation-for="ZipCodes" class="text-danger"></span>
                                <small class="form-text text-muted">Add each ZIP code once, then enter how many times it was recorded.</small>
                            </div>
                        </div>

                        <div class="row">
                            <!-- Notes -->
                            <div class="col-12 mb-3">
                                <label asp-for="Notes" class="form-label fw-bold">Notes (Optional)</label>
                                <textarea asp-for="Notes" class="form-control" rows="3" 
                                          placeholder="Add any additional notes or context about demographics" 
                                          maxlength="500"></textarea>
                                <span asp-validation-for="Notes" class="text-danger"></span>
                                <small class="form-text text-muted">Maximum 500 characters</small>
                            </div>
                        </div>

                        <!-- Submit Button -->
                        <div class="text-center mt-4">
                            <button type="submit" class="btn btn-primary btn-lg px-5 py-3"
                                    style="background-color:var(--onejax-navy); border-color:var(--onejax-navy); border-radius: 12px; font-weight: 600;">
                                Submit Demographics Data
                            </button>
                        </div>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .form-control:focus,
    .form-select:focus {
        border-color: var(--onejax-navy);
        box-shadow: 0 0 0 0.2rem rgba(0, 123, 191, 0.25);
    }
    
    .form-label {
        color: var(--onejax-navy);
        margin-bottom: 0.5rem;
    }
    
    .card {
        border: none;
    }
    
    input[type="number"]::-webkit-inner-spin-button,
    input[type="number"]::-webkit-outer-spin-button {
        opacity: 1;
    }

    textarea.form-control {
        resize: vertical;
    }

    .form-select {
        cursor: pointer;
    }

    .zip-entry-panel {
        border: 1px solid rgba(15, 23, 42, 0.14);
        border-radius: 12px;
        padding: 1rem;
        background: #f8fafc;
    }

    .zip-count-list {
        display: grid;
        gap: 0.5rem;
    }

    .zip-count-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        border: 1px solid rgba(15, 23, 42, 0.10);
        border-radius: 10px;
        padding: 0.65rem 0.75rem;
        background: white;
    }

    .zip-count-row strong {
        color: var(--onejax-navy);
    }

    .zip-empty-state {
        color: #64748b;
        font-size: 0.95rem;
        padding: 0.6rem 0;
    }
</style>

<script>
    (function initZipCountEntry() {
        const form = document.getElementById('programDemographicsForm');
        const zipHidden = document.getElementById('ZipCodes');
        const zipInput = document.getElementById('zipCodeInput');
        const countInput = document.getElementById('zipCountInput');
        const addButton = document.getElementById('addZipCountButton');
        const list = document.getElementById('zipCountList');
        if (!form || !zipHidden || !zipInput || !countInput || !addButton || !list) return;

        const counts = new Map();

        function render() {
            list.innerHTML = '';
            if (!counts.size) {
                const empty = document.createElement('div');
                empty.className = 'zip-empty-state';
                empty.textContent = 'No ZIP codes added yet.';
                list.appendChild(empty);
                return;
            }

            for (const [zip, count] of counts.entries()) {
                const row = document.createElement('div');
                row.className = 'zip-count-row';
                row.innerHTML = `<div><strong>${zip}</strong><div class="text-muted small">${count} recorded</div></div>`;
                const remove = document.createElement('button');
                remove.type = 'button';
                remove.className = 'btn btn-sm btn-outline-secondary';
                remove.textContent = 'Remove';
                remove.addEventListener('click', function () {
                    counts.delete(zip);
                    render();
                });
                row.appendChild(remove);
                list.appendChild(row);
            }
        }

        function addZip() {
            const zip = (zipInput.value || '').trim();
            const count = Math.max(1, parseInt(countInput.value || '1', 10) || 1);
            if (!/^\\d{5}$/.test(zip)) {
                zipInput.setCustomValidity('Enter a 5-digit ZIP code.');
                zipInput.reportValidity();
                return;
            }
            zipInput.setCustomValidity('');
            counts.set(zip, (counts.get(zip) || 0) + count);
            zipInput.value = '';
            countInput.value = '1';
            render();
            zipInput.focus();
        }

        addButton.addEventListener('click', addZip);
        zipInput.addEventListener('keydown', function (event) {
            if (event.key === 'Enter') {
                event.preventDefault();
                addZip();
            }
        });

        form.addEventListener('submit', function (event) {
            const expanded = [];
            for (const [zip, count] of counts.entries()) {
                for (let i = 0; i < count; i++) expanded.push(zip);
            }

            zipHidden.value = expanded.join(', ');
            if (!zipHidden.value) {
                event.preventDefault();
                zipInput.setCustomValidity('Add at least one ZIP code.');
                zipInput.reportValidity();
                return;
            }
            if (zipHidden.value.length > 1000) {
                event.preventDefault();
                zipInput.setCustomValidity('This entry has too many ZIP records. Please split it into two submissions.');
                zipInput.reportValidity();
                return;
            }
            zipInput.setCustomValidity('');
        });

        render();
    })();
</script>
