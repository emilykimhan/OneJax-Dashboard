                                <form asp-controller="DataEntry" asp-action="DeleteCollabPartner" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this record?');">
                                    <input type="hidden" name="id" value="@cp.Id" />
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="no-records">No Collaborative Partner Touchpoint records found.</p>
            }
        </div>
        }

        <!-- Back to Data Entry Button -->
        <div class="back-navigation mt-4">
            <a asp-controller="DataEntry" asp-action="Index" class="btn-back">
                ← Back to Data Entry
            </a>
        </div>
    </div>
</div>

<style>
    /* Filter Section Styles */
