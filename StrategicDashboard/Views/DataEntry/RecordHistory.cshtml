                                            <span class="month-badge">Aug: @media.August</span>
                                        }
                                        @if (media.September.HasValue && media.September > 0)
                                        {
                                            <span class="month-badge">Sep: @media.September</span>
                                        }
                                        @if (media.October.HasValue && media.October > 0)
                                        {
                                            <span class="month-badge">Oct: @media.October</span>
                                        }
                                        @if (media.November.HasValue && media.November > 0)
                                        {
                                            <span class="month-badge">Nov: @media.November</span>
                                        }
                                        @if (media.December.HasValue && media.December > 0)
                                        {
                                            <span class="month-badge">Dec: @media.December</span>
                                        }
                                    </div>
                                </div>
                            </div>
                            <div class="record-actions mt-3">
                                <a asp-controller="DataEntry" asp-action="EditMediaPlacement" asp-route-id="@media.Id" class="btn btn-primary btn-sm">
                                    Edit
                                </a>
                                <form asp-controller="DataEntry" asp-action="DeleteMediaPlacement" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this record?');">
                                    <input type="hidden" name="id" value="@media.Id" />
                                    <button type="submit" class="btn btn-danger btn-sm">
                                        Delete
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="no-records">No Media Placements records found.</p>
            }
        </div>
        }

