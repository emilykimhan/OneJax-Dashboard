@{
    ViewData["Title"] = "Record History";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1 class="headline mb-4" style="color:var(--onejax-navy);">Record History</h1>

<div class="container mt-4">
    <div class="card p-4"
        style="background-color:var(--onejax-white); 
               box-shadow:0 4px 24px rgba(0,0,0,0.08); 
               border-radius:24px; 
               max-width:2000px;">

        <p class="mb-4">View all previously entered data records below.</p>
        
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
            </div>
        }

        <!-- Filter/Search Section -->
        <div class="filter-section mb-4">
            <form method="get" asp-action="RecordHistory">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="recordType" class="form-label fw-bold">Filter by Record Type:</label>
                        <select id="recordType" name="recordType" class="form-select">
                            <option value="all" selected="@(ViewBag.RecordType == "all" ? "selected" : null)">All Records</option>
                            <option value="staff-survey" selected="@(ViewBag.RecordType == "staff-survey" ? "selected" : null)">Staff Survey Only</option>
                            <option value="professional-development" selected="@(ViewBag.RecordType == "professional-development" ? "selected" : null)">Professional Development Only</option>
                            <option value="media-placements" selected="@(ViewBag.RecordType == "media-placements" ? "selected" : null)">Media Placements Only</option>
                            <option value="website-traffic" selected="@(ViewBag.RecordType == "website-traffic" ? "selected" : null)">Website Traffic Only</option>
                            <option value="donor-events" selected="@(ViewBag.RecordType == "donor-events" ? "selected" : null)">Donor/Honoree Engagement Only</option>
                            <option value="comm-rate" selected="@(ViewBag.RecordType == "comm-rate" ? "selected" : null)">Communication Satisfaction Only</option>
                            <option value="fee-for-service" selected="@(ViewBag.RecordType == "fee-for-service" ? "selected" : null)">Fee-For-Service Revenue Only</option>
                            <option value="earned-income" selected="@(ViewBag.RecordType == "earned-income" ? "selected" : null)">Earned Income Tracking Only</option>
                            <option value="budget-tracking" selected="@(ViewBag.RecordType == "budget-tracking" ? "selected" : null)">Annual Budget Tracking Only</option>
                            <option value="social-media" selected="@(ViewBag.RecordType == "social-media" ? "selected" : null)">Social Media Engagement Only</option>
                            <option value="milestone" selected="@(ViewBag.RecordType == "milestone" ? "selected" : null)">Milestone Achievement Only</option>
                            <option value="community-perception" selected="@(ViewBag.RecordType == "community-perception" ? "selected" : null)">Community Perception Survey Only</option>
                            <option value="programs-demographics" selected="@(ViewBag.RecordType == "programs-demographics" ? "selected" : null)">Programs Demographics Only</option>
                            <option value="framework-plan" selected="@(ViewBag.RecordType == "framework-plan" ? "selected" : null)">Framework Development Plan Only</option>
                            <option value="board-member" selected="@(ViewBag.RecordType == "board-member" ? "selected" : null)">Board Member Recruitment Only</option>
                            <option value="board-meeting" selected="@(ViewBag.RecordType == "board-meeting" ? "selected" : null)">Board Meeting Attendance Only</option>
                            <option value="self-assessment" selected="@(ViewBag.RecordType == "self-assessment" ? "selected" : null)">Board Self-Assessment Only</option>
                            <option value="volunteer-program" selected="@(ViewBag.RecordType == "volunteer-program" ? "selected" : null)">Volunteer Program Only</option>
                            <option value="interfaith-event" selected="@(ViewBag.RecordType == "interfaith-event" ? "selected" : null)">Interfaith Collaboration Events Only</option>
                            <option value="event-satisfaction" selected="@(ViewBag.RecordType == "event-satisfaction" ? "selected" : null)">Event Satisfaction Only</option>
                            <option value="faith-community" selected="@(ViewBag.RecordType == "faith-community" ? "selected" : null)">Faith Community Representation Only</option>
                            <option value="network-contacts" selected="@(ViewBag.RecordType == "network-contacts" ? "selected" : null)">Network Contacts Only</option>
                            <option value="youth-attendance" selected="@(ViewBag.RecordType == "youth-attendance" ? "selected" : null)">Youth Attendance Only</option>
                            <option value="participant-diversity" selected="@(ViewBag.RecordType == "participant-diversity" ? "selected" : null)">Participant Diversity Only</option>
                            <option value="first-time-participants" selected="@(ViewBag.RecordType == "first-time-participants" ? "selected" : null)">First-Time Participants Only</option>
                            <option value="collab-partners" selected="@(ViewBag.RecordType == "collab-partners" ? "selected" : null)">Collaborative Partner Touchpoints Only</option>
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label for="dateFilter" class="form-label fw-bold">Filter by Date:</label>
                        <select id="dateFilter" name="dateFilter" class="form-select">
                            <option value="all" selected="@(ViewBag.DateFilter == "all" ? "selected" : null)">All Dates</option>
                            <option value="today" selected="@(ViewBag.DateFilter == "today" ? "selected" : null)">Today</option>
                            <option value="week" selected="@(ViewBag.DateFilter == "week" ? "selected" : null)">Last 7 Days</option>
                            <option value="month" selected="@(ViewBag.DateFilter == "month" ? "selected" : null)">Last 30 Days</option>
                            <option value="custom" selected="@(ViewBag.DateFilter == "custom" ? "selected" : null)">Custom Range</option>
                        </select>
                    </div>
                </div>
                <div class="row" id="customDateRange">
                    <div class="col-md-6 mb-3">
                        <label for="startDate" class="form-label fw-bold">Start Date (for Custom Range):</label>
                        <input type="date" id="startDate" name="startDate" class="form-control" value="@ViewBag.StartDate">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label for="endDate" class="form-label fw-bold">End Date (for Custom Range):</label>
                        <input type="date" id="endDate" name="endDate" class="form-control" value="@ViewBag.EndDate">
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Apply Filters</button>
                    <a href="@Url.Action("RecordHistory")" class="btn btn-secondary">Clear Filters</a>
                    @if (ViewBag.TotalCount != null)
                    {
                        <span class="align-self-center ms-3 text-muted">Showing @ViewBag.VisibleCount of @ViewBag.TotalCount records</span>
                    }
                </div>
            </form>
        </div>

        <!-- Export Toolbar -->
        <div class="export-toolbar mb-3 p-3">
            <div class="d-flex align-items-center gap-3 flex-wrap">
                <div class="form-check mb-0">
                    <input class="form-check-input" type="checkbox" id="selectAllCheckbox" />
                    <label class="form-check-label fw-bold" for="selectAllCheckbox">Select All</label>
                </div>
                <button type="button" id="exportSelectedBtn" class="btn btn-success" disabled>
                    Export Selected (<span id="selectedCount">0</span>)
                </button>
                <span class="text-muted small" id="exportHint">Check records below, then click Export Selected.</span>
            </div>
        </div>

        <!-- Hidden export form (submitted by JS) -->
        <form id="exportForm" method="post" action="/Export/ExportSelected">
            @Html.AntiForgeryToken()
            <input type="hidden" name="format" value="excel" />
        </form>

        <div class="container">
    <h2>Record History</h2>
    
   
        
        @if (ViewBag.RecordType == "all" || ViewBag.RecordType == "staff-survey")
        {
        <!-- Staff Survey Records -->
        <div class="record-section">
            <h5 class="section-title">Staff Survey Records</h5>
            @if (ViewBag.StaffSurveys != null && ((List<OneJaxDashboard.Models.StaffSurvey_22D>)ViewBag.StaffSurveys).Any())
            {
                <div class="records-list">
                    @foreach (var survey in (List<OneJaxDashboard.Models.StaffSurvey_22D>)ViewBag.StaffSurveys)
                    {
                        <div class="record-item">
                            <div class="record-header">
                                <span class="record-type">Staff Survey</span>
                                <label class="export-checkbox-label">
                                    <input type="checkbox" class="record-checkbox" data-type="staff-survey" data-id="@survey.Id" />
                                    <span>Select</span>
                                </label>
                            </div>
                            <div class="record-details">
                                <div class="detail-item">
                                    <strong>Year:</strong> @survey.Year
                                </div>
                                <div class="detail-item">
                                    <strong>Month:</strong> @(string.IsNullOrWhiteSpace(survey.Month) ? "Not set" : survey.Month)
                                </div>
                                <div class="detail-item">
                                    <strong>Satisfaction Rate:</strong> @survey.SatisfactionRate%
                                </div>
                                <div class="detail-item">
                                    <strong>Created Date:</strong> @survey.CreatedDate.ToString("MM/dd/yyyy")
                                </div>
                            </div>
                            <div class="record-actions mt-3">
                                <a asp-controller="DataEntry" asp-action="EditStaffSurvey" asp-route-id="@survey.Id" class="btn btn-primary btn-sm">
                                    Edit
                                </a>
                                <form asp-controller="DataEntry" asp-action="DeleteStaffSurvey" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this record?');">
                                    <input type="hidden" name="id" value="@survey.Id" />
                                    <button type="submit" class="btn btn-danger btn-sm">
                                        Delete
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="no-records">No Staff Survey records found.</p>
            }
        </div>
        }

