        @if (ViewBag.RecordType == "all" || ViewBag.RecordType == "media-placements")
        {
        <!-- Media Placements Records -->
        <div class="record-section">
            <h5 class="section-title">Media Placements Records</h5>
            @if (ViewBag.MediaPlacements != null && ((List<OneJaxDashboard.Models.MediaPlacements_3D>)ViewBag.MediaPlacements).Any())
            {
                <div class="records-list">
                    @foreach (var media in (List<OneJaxDashboard.Models.MediaPlacements_3D>)ViewBag.MediaPlacements)
                    {
                        <div class="record-item">
                            <div class="record-header">
                                <span class="record-type">Media Placements</span>
                                <label class="export-checkbox-label">
                                    <input type="checkbox" class="record-checkbox" data-type="media-placements" data-id="@media.Id" />
                                    <span>Select</span>
                                </label>
