                                        {
                                            <span class="month-badge">Jan: @media.January</span>
                                        }
                                        @if (media.February.HasValue && media.February > 0)
                                        {
                                            <span class="month-badge">Feb: @media.February</span>
                                        }
                                        @if (media.March.HasValue && media.March > 0)
                                        {
                                            <span class="month-badge">Mar: @media.March</span>
                                        }
                                        @if (media.April.HasValue && media.April > 0)
                                        {
                                            <span class="month-badge">Apr: @media.April</span>
                                        }
                                        @if (media.May.HasValue && media.May > 0)
                                        {
                                            <span class="month-badge">May: @media.May</span>
                                        }
                                        @if (media.June.HasValue && media.June > 0)
                                        {
                                            <span class="month-badge">Jun: @media.June</span>
                                        }
                                        @if (media.July.HasValue && media.July > 0)
                                        {
                                            <span class="month-badge">Jul: @media.July</span>
                                        }
                                        @if (media.August.HasValue && media.August > 0)
