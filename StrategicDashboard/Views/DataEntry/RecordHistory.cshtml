            <h5 class="section-title">Fee-For-Service Revenue Records</h5>
            @if (ViewBag.FeeForServices != null && ((List<OneJaxDashboard.Models.feeForService_21D>)ViewBag.FeeForServices).Any())
            {
                <div class="records-list">
                    @foreach (var fee in (List<OneJaxDashboard.Models.feeForService_21D>)ViewBag.FeeForServices)
                    {
                        <div class="record-item">
                            <div class="record-header">
                                <span class="record-type">Fee-For-Service Revenue</span>
                                <label class="export-checkbox-label">
                                    <input type="checkbox" class="record-checkbox" data-type="fee-for-service" data-id="@fee.Id" />
                                    <span>Select</span>
                                </label>
                            </div>
                            <div class="record-details">
                                <div class="detail-item">
                                    <strong>Client Name:</strong> @fee.ClientName
                                </div>
                                <div class="detail-item">
                                    <strong>Event:</strong> @(fee.Strategy?.Name ?? fee.EventName ?? "N/A")
                                </div>
                                <div class="detail-item">
                                    <strong>Workshop Format:</strong> @fee.WorkshopFormat
                                </div>
                                @if (!string.IsNullOrEmpty(fee.WorkshopLocation))
