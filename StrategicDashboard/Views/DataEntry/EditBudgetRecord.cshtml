@model OneJaxDashboard.Models.BudgetTracking_28D
@{
    ViewData["Title"] = "Edit Annual Budget Tracking Record";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1 class="headline mb-4" style="color:var(--onejax-navy);">Edit Annual Budget Tracking Record</h1>

<div class="container mt-4">
    <div class="card p-4" style="background-color:var(--onejax-white); box-shadow:0 4px 24px rgba(0,0,0,0.08); border-radius:24px; max-width:900px;">

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <form asp-controller="DataEntry" asp-action="EditBudgetRecord" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedDate" />

            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="Quarter" class="form-label fw-bold">Quarter</label>
                    <select asp-for="Quarter" class="form-select">
                        <option value="">-- Select Quarter --</option>
                        <option value="Q1">Q1 (January - March)</option>
                        <option value="Q2">Q2 (April - June)</option>
                        <option value="Q3">Q3 (July - September)</option>
                        <option value="Q4">Q4 (October - December)</option>
                    </select>
                    <span asp-validation-for="Quarter" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Year" class="form-label fw-bold">Year</label>
                    <input asp-for="Year" type="number" min="2022" max="2100" class="form-control" />
                    <span asp-validation-for="Year" class="text-danger"></span>
                </div>
            </div>

            <h5 class="mt-4 mb-3" style="color:var(--onejax-navy); border-bottom:2px solid #dee2e6; padding-bottom:0.5rem;">Expenses</h5>
            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="CommunityPrograms" class="form-label fw-bold">Community Programs ($)</label>
                    <input asp-for="CommunityPrograms" type="number" step="0.01" min="0" class="form-control" />
                    <span asp-validation-for="CommunityPrograms" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="OneYouthPrograms" class="form-label fw-bold">OneYouth Programs ($)</label>
                    <input asp-for="OneYouthPrograms" type="number" step="0.01" min="0" class="form-control" />
                    <span asp-validation-for="OneYouthPrograms" class="text-danger"></span>
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="InterfaithPrograms" class="form-label fw-bold">Interfaith Programs ($)</label>
                    <input asp-for="InterfaithPrograms" type="number" step="0.01" min="0" class="form-control" />
                    <span asp-validation-for="InterfaithPrograms" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="HumanitarianEvent" class="form-label fw-bold">Humanitarian Event ($)</label>
                    <input asp-for="HumanitarianEvent" type="number" step="0.01" min="0" class="form-control" />
                    <span asp-validation-for="HumanitarianEvent" class="text-danger"></span>
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="MiscellaneousExpenses" class="form-label fw-bold">Miscellaneous Expenses ($)</label>
                    <input asp-for="MiscellaneousExpenses" type="number" step="0.01" min="0" class="form-control" />
                    <span asp-validation-for="MiscellaneousExpenses" class="text-danger"></span>
                </div>
            </div>

            <h5 class="mt-4 mb-3" style="color:var(--onejax-navy); border-bottom:2px solid #dee2e6; padding-bottom:0.5rem;">Revenues</h5>
            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="CorporateGiving" class="form-label fw-bold">Corporate Giving ($)</label>
                    <input asp-for="CorporateGiving" type="number" step="0.01" min="0" class="form-control" />
                    <span asp-validation-for="CorporateGiving" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="IndividualGiving" class="form-label fw-bold">Individual Giving ($)</label>
                    <input asp-for="IndividualGiving" type="number" step="0.01" min="0" class="form-control" />
                    <span asp-validation-for="IndividualGiving" class="text-danger"></span>
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="GrantsFoundations" class="form-label fw-bold">Grants &amp; Foundations ($)</label>
                    <input asp-for="GrantsFoundations" type="number" step="0.01" min="0" class="form-control" />
                    <span asp-validation-for="GrantsFoundations" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="CommunityEvents" class="form-label fw-bold">Community Events ($)</label>
                    <input asp-for="CommunityEvents" type="number" step="0.01" min="0" class="form-control" />
                    <span asp-validation-for="CommunityEvents" class="text-danger"></span>
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="PeopleCultureWorkshops" class="form-label fw-bold">People and Culture Workshops ($)</label>
                    <input asp-for="PeopleCultureWorkshops" type="number" step="0.01" min="0" class="form-control" />
                    <span asp-validation-for="PeopleCultureWorkshops" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="MiscellaneousRevenue" class="form-label fw-bold">Miscellaneous Revenue ($)</label>
                    <input asp-for="MiscellaneousRevenue" type="number" step="0.01" min="0" class="form-control" />
                    <span asp-validation-for="MiscellaneousRevenue" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Notes" class="form-label fw-bold">Notes <span class="text-muted fw-normal">(optional)</span></label>
                <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Notes" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-controller="DataEntry" asp-action="RecordHistory" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
