@model OneJaxDashboard.Models.feeForService_21D
@{
    ViewData["Title"] = "Edit Fee-For-Service Revenue Record";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1 class="headline mb-4" style="color:var(--onejax-navy);">Edit Fee-For-Service Revenue Record</h1>

<div class="container mt-4">
    <div class="card p-4" style="background-color:var(--onejax-white); box-shadow:0 4px 24px rgba(0,0,0,0.08); border-radius:24px; max-width:800px;">

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <form asp-controller="DataEntry" asp-action="EditFeeForService" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedDate" />

            <div class="mb-3">
                <label asp-for="ClientName" class="form-label fw-bold">Client Name</label>
                <input asp-for="ClientName" class="form-control" />
                <span asp-validation-for="ClientName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="StrategyId" class="form-label fw-bold">Event / Program</label>
                <select asp-for="StrategyId" asp-items="ViewBag.Strategies" class="form-select">
                    <option value="">-- Select Event --</option>
                </select>
                <span asp-validation-for="StrategyId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="WorkshopFormat" class="form-label fw-bold">Workshop Format</label>
                <select asp-for="WorkshopFormat" class="form-select">
                    <option value="">-- Select Format --</option>
                    <option value="In Person">In Person</option>
                    <option value="Online">Online</option>
                </select>
                <span asp-validation-for="WorkshopFormat" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="WorkshopLocation" class="form-label fw-bold">Workshop Location <span class="text-muted fw-normal">(if in person)</span></label>
                <input asp-for="WorkshopLocation" class="form-control" />
                <span asp-validation-for="WorkshopLocation" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="WorkshopDate" class="form-label fw-bold">Workshop Date</label>
                <input asp-for="WorkshopDate" type="date" class="form-control" />
                <span asp-validation-for="WorkshopDate" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="EventPartners" class="form-label fw-bold">Event Partners</label>
                <input asp-for="EventPartners" class="form-control" />
                <span asp-validation-for="EventPartners" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="NumberOfAttendees" class="form-label fw-bold">Number of Attendees</label>
                <input asp-for="NumberOfAttendees" type="number" class="form-control" />
                <span asp-validation-for="NumberOfAttendees" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ParticipantSatisfactionRating" class="form-label fw-bold">Participant Satisfaction Rating (%)</label>
                <input asp-for="ParticipantSatisfactionRating" type="number" step="0.01" min="0" max="100" class="form-control" />
                <span asp-validation-for="ParticipantSatisfactionRating" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="PartnerSatisfactionRating" class="form-label fw-bold">Partner Satisfaction Rating (%)</label>
                <input asp-for="PartnerSatisfactionRating" type="number" step="0.01" min="0" max="100" class="form-control" />
                <span asp-validation-for="PartnerSatisfactionRating" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="RevenueReceived" class="form-label fw-bold">Revenue Received ($)</label>
                <input asp-for="RevenueReceived" type="number" step="0.01" min="0" class="form-control" />
                <span asp-validation-for="RevenueReceived" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ExpenseReceived" class="form-label fw-bold">Expense ($)</label>
                <input asp-for="ExpenseReceived" type="number" step="0.01" min="0" class="form-control" />
                <span asp-validation-for="ExpenseReceived" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Year" class="form-label fw-bold">Year</label>
                <input asp-for="Year" type="number" min="2020" max="2100" class="form-control" />
                <span asp-validation-for="Year" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-controller="DataEntry" asp-action="RecordHistory" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
