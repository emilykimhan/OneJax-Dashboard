@model OneJaxDashboard.Models.Annual_average_7D

@{
    ViewData["Title"] = "Edit Community Perception Survey";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1 class="headline mb-4" style="color:var(--onejax-navy);">Edit Community Perception Survey</h1>

<div class="container mt-4">
    <div class="card p-4"
        style="background-color:var(--onejax-white); 
               box-shadow:0 4px 24px rgba(0,0,0,0.08); 
               border-radius:24px; 
               max-width:900px;">

        <form asp-action="EditCommunityPerception" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedDate" />

            <p class="mb-4">Update the community perception survey details below.</p>

            <div class="mb-3">
                <label asp-for="Year" class="form-label fw-bold">Year</label>
                <input asp-for="Year" type="number" class="form-control" min="2020" max="2100" required />
                <span asp-validation-for="Year" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Percentage" class="form-label fw-bold">% of Respondents Identifying OneJax as Trusted Leader</label>
                <input asp-for="Percentage" type="number" class="form-control" min="0" max="100" step="0.01" placeholder="e.g. 75.5" required />
                <span asp-validation-for="Percentage" class="text-danger"></span>
                <div class="form-text">Goal is 70% or higher.</div>
            </div>

            <div class="mb-3">
                <label asp-for="TotalRespondents" class="form-label fw-bold">Total Respondents</label>
                <input asp-for="TotalRespondents" type="number" class="form-control" min="0" placeholder="e.g. 250" />
                <span asp-validation-for="TotalRespondents" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="RespondentsIdentifyingAsTrusted" class="form-label fw-bold">Respondents Identifying as Trusted Leader</label>
                <input asp-for="RespondentsIdentifyingAsTrusted" type="number" class="form-control" min="0" placeholder="e.g. 185" />
                <span asp-validation-for="RespondentsIdentifyingAsTrusted" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Notes" class="form-label fw-bold">Notes</label>
                <textarea asp-for="Notes" class="form-control" rows="3" maxlength="500" placeholder="Optional notes..."></textarea>
                <span asp-validation-for="Notes" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="RecordHistory" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

<style>
    .form-label {
        color: var(--onejax-navy);
    }

    .form-control:focus {
        border-color: var(--onejax-navy);
        box-shadow: 0 0 0 0.2rem rgba(0, 123, 191, 0.25);
    }

    .btn-primary {
        background-color: var(--onejax-navy);
        border-color: var(--onejax-navy);
    }

    .btn-primary:hover {
        background-color: #1a365d;
        border-color: #1a365d;
    }
</style>
