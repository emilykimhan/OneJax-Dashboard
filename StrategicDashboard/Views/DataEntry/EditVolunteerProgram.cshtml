@model OneJaxDashboard.Models.volunteerProgram_40D
@{
    ViewData["Title"] = "Edit Volunteer Program";
}

<h1 class="headline mb-4" style="color:var(--onejax-navy);">Edit Volunteer Program</h1>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="form-card">
    <form asp-action="EditVolunteerProgram" method="post">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="CreatedDate" />

        <div class="mb-3">
            <label asp-for="Quarter" class="form-label">Quarter</label>
            <select asp-for="Quarter" class="form-select">
                <option value="1">Q1 (Jan–Mar)</option>
                <option value="2">Q2 (Apr–Jun)</option>
                <option value="3">Q3 (Jul–Sep)</option>
                <option value="4">Q4 (Oct–Dec)</option>
            </select>
            <span asp-validation-for="Quarter" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Year" class="form-label">Year</label>
            <input asp-for="Year" class="form-control" type="number" min="2020" max="2100" />
            <span asp-validation-for="Year" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="NumberOfVolunteers" class="form-label">Number of Volunteers</label>
            <input asp-for="NumberOfVolunteers" class="form-control" type="number" min="0" />
            <span asp-validation-for="NumberOfVolunteers" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="VolunteerLedInitiatives" class="form-label">Volunteer-Led Initiatives</label>
            <input asp-for="VolunteerLedInitiatives" class="form-control" type="number" min="0" max="100" />
            <span asp-validation-for="VolunteerLedInitiatives" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="CommunicationsActivities" class="form-label">Communications Activities</label>
            <textarea asp-for="CommunicationsActivities" class="form-control" rows="3"></textarea>
            <span asp-validation-for="CommunicationsActivities" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="RecognitionActivities" class="form-label">Recognition Activities</label>
            <textarea asp-for="RecognitionActivities" class="form-control" rows="3"></textarea>
            <span asp-validation-for="RecognitionActivities" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="InitiativeDescriptions" class="form-label">Initiative Descriptions</label>
            <textarea asp-for="InitiativeDescriptions" class="form-control" rows="3"></textarea>
            <span asp-validation-for="InitiativeDescriptions" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a asp-controller="DataEntry" asp-action="RecordHistory" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
