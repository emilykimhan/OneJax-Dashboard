@model OneJaxDashboard.Models.ContactsInterfaith_14D

@{
    ViewData["Title"] = "Edit Network Contacts";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1 class="headline mb-4" style="color:var(--onejax-navy);">Edit Network Contacts</h1>

<div class="container mt-4">
    <div class="card p-4"
        style="background-color:var(--onejax-white); 
               box-shadow:0 4px 24px rgba(0,0,0,0.08); 
               border-radius:24px; 
               max-width:800px;">

        <form asp-action="EditNetworkContacts" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedDate" />

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Year" class="form-label fw-bold">Year</label>
                    <input asp-for="Year" type="number" class="form-control" min="2020" max="2100" />
                    <span asp-validation-for="Year" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Month" class="form-label fw-bold">Month</label>
                    <select asp-for="Month" class="form-select" required>
                        <option value="">-- Select Month --</option>
                        <option value="1">January</option>
                        <option value="2">February</option>
                        <option value="3">March</option>
                        <option value="4">April</option>
                        <option value="5">May</option>
                        <option value="6">June</option>
                        <option value="7">July</option>
                        <option value="8">August</option>
                        <option value="9">September</option>
                        <option value="10">October</option>
                        <option value="11">November</option>
                        <option value="12">December</option>
                    </select>
                    <span asp-validation-for="Month" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="TotalInterfaithContacts" class="form-label fw-bold">Total Interfaith Contacts</label>
                <input asp-for="TotalInterfaithContacts" type="number" class="form-control" min="0" max="100000" />
                <span asp-validation-for="TotalInterfaithContacts" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="RecordHistory" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

<style>
    .form-label {
        color: var(--onejax-navy);
    }

    .form-control:focus {
        border-color: var(--onejax-navy);
        box-shadow: 0 0 0 0.2rem rgba(0, 123, 191, 0.25);
    }

    .btn-primary {
        background-color: var(--onejax-navy);
        border-color: var(--onejax-navy);
    }

    .btn-primary:hover {
        background-color: #1a365d;
        border-color: #1a365d;
    }
</style>
