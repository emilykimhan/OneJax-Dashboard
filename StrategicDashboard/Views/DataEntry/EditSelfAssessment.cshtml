@model OneJaxDashboard.Models.selfAssess_31D
@{
    ViewData["Title"] = "Edit Board Self-Assessment";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1 class="headline mb-4" style="color:var(--onejax-navy);">Edit Board Self-Assessment</h1>

<div class="container mt-4">
    <div class="card p-4"
        style="background-color:var(--onejax-white); 
               box-shadow:0 4px 24px rgba(0,0,0,0.08); 
               border-radius:24px; 
               max-width:800px;">

        <form asp-action="EditSelfAssessment" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedDate" />

            <div class="mb-3">
                <label asp-for="Year" class="form-label fw-bold">Year</label>
                <input asp-for="Year" type="number" class="form-control" min="2020" max="2100" />
                <span asp-validation-for="Year" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="SelfAssessmentScore" class="form-label fw-bold">Average Annual Board Self-Evaluation Score (0-100)</label>
                <input asp-for="SelfAssessmentScore" type="number" class="form-control" min="0" max="100" />
                <span asp-validation-for="SelfAssessmentScore" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="RecordHistory" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

<style>
    .form-label {
        color: var(--onejax-navy);
    }
    .btn-primary {
        background-color: var(--onejax-navy);
        border-color: var(--onejax-navy);
    }
    .btn-primary:hover {
        background-color: var(--onejax-blue);
        border-color: var(--onejax-blue);
    }
</style>
