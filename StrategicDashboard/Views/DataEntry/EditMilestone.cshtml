@model OneJaxDashboard.Models.achieveMile_6D

@{
    ViewData["Title"] = "Edit Milestone Achievement";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1 class="headline mb-4" style="color:var(--onejax-navy);">Edit Milestone Achievement</h1>

<div class="container mt-4">
    <div class="card p-4"
        style="background-color:var(--onejax-white); 
               box-shadow:0 4px 24px rgba(0,0,0,0.08); 
               border-radius:24px; 
               max-width:900px;">

        <form asp-action="EditMilestone" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedDate" />

            <p class="mb-4">Update the milestone achievement details below.</p>

            <div class="mb-3">
                <label asp-for="Percentage" class="form-label fw-bold">Percentage of Milestones Achieved (%)</label>
                <input asp-for="Percentage" type="number" class="form-control" min="0" max="100" step="0.01" placeholder="e.g. 80" required />
                <span asp-validation-for="Percentage" class="text-danger"></span>
                <div class="form-text">Goal is 75% or higher.</div>
            </div>

            <div class="mb-3">
                <div class="form-check">
                    <input asp-for="achievedReview" class="form-check-input" type="checkbox" />
                    <label asp-for="achievedReview" class="form-check-label fw-bold">Achieved in 6-Month Review</label>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="RecordHistory" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

<style>
    .form-label {
        color: var(--onejax-navy);
    }

    .form-control:focus {
        border-color: var(--onejax-navy);
        box-shadow: 0 0 0 0.2rem rgba(0, 123, 191, 0.25);
    }

    .btn-primary {
        background-color: var(--onejax-navy);
        border-color: var(--onejax-navy);
    }

    .btn-primary:hover {
        background-color: #1a365d;
        border-color: #1a365d;
    }
</style>
