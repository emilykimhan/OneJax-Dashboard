@model OneJaxDashboard.Models.BoardMeetingAttendance
@{
    ViewData["Title"] = "Edit Board Meeting Attendance";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1 class="headline mb-4" style="color:var(--onejax-navy);">Edit Board Meeting Attendance</h1>

<div class="container mt-4">
    <div class="card p-4"
        style="background-color:var(--onejax-white); 
               box-shadow:0 4px 24px rgba(0,0,0,0.08); 
               border-radius:24px; 
               max-width:800px;">

        <form asp-action="EditBoardMeetingAttendance" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedDate" />

            <div class="mb-3">
                <label asp-for="MeetingDate" class="form-label fw-bold">Board Meeting Date</label>
                <input asp-for="MeetingDate" type="date" class="form-control" />
                <span asp-validation-for="MeetingDate" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="MembersInAttendance" class="form-label fw-bold">Number of Board Members in Attendance</label>
                <input asp-for="MembersInAttendance" type="number" class="form-control" min="0" />
                <span asp-validation-for="MembersInAttendance" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="TotalBoardMembers" class="form-label fw-bold">
                    Total Board Members <small class="text-muted">(Optional)</small>
                </label>
                <input asp-for="TotalBoardMembers" type="number" class="form-control" min="1" />
                <span asp-validation-for="TotalBoardMembers" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="RecordHistory" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

<style>
    .form-label {
        color: var(--onejax-navy);
    }
    .btn-primary {
        background-color: var(--onejax-navy);
        border-color: var(--onejax-navy);
    }
    .btn-primary:hover {
        background-color: var(--onejax-blue);
        border-color: var(--onejax-blue);
    }
</style>
