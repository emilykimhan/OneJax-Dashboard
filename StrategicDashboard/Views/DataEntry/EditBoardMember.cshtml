@model OneJaxDashboard.Models.BoardMemberRecruitment
@{
    ViewData["Title"] = "Edit Board Member Recruitment";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1 class="headline mb-4" style="color:var(--onejax-navy);">Edit Board Member Recruitment</h1>

<div class="container mt-4">
    <div class="card p-4"
        style="background-color:var(--onejax-white); 
               box-shadow:0 4px 24px rgba(0,0,0,0.08); 
               border-radius:24px; 
               max-width:800px;">

        <form asp-action="EditBoardMember" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedDate" />

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Quarter" class="form-label fw-bold">Quarter (calendar quarter)</label>
                    <select asp-for="Quarter" class="form-select">
                        <option value="1">Q1 (Jan-Mar)</option>
                        <option value="2">Q2 (Apr-Jun)</option>
                        <option value="3">Q3 (Jul-Sep)</option>
                        <option value="4">Q4 (Oct-Dec)</option>
                    </select>
                    <span asp-validation-for="Quarter" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Year" class="form-label fw-bold">Year (calendar year)</label>
                    <input asp-for="Year" type="number" class="form-control" min="2020" max="2100" />
                    <span asp-validation-for="Year" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="TotalProspectOutreach" class="form-label fw-bold">Total Prospect Outreach</label>
                <input asp-for="TotalProspectOutreach" type="number" class="form-control" min="0" max="500" />
                <span asp-validation-for="TotalProspectOutreach" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ProspectNames" class="form-label fw-bold">
                    Prospect Names <small class="text-muted">(Separate multiple names with commas)</small>
                </label>
                <textarea asp-for="ProspectNames" class="form-control" rows="3"></textarea>
                <span asp-validation-for="ProspectNames" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="NumberRecruited" class="form-label fw-bold">Number Recruited</label>
                <input asp-for="NumberRecruited" type="number" class="form-control" min="0" max="100" />
                <span asp-validation-for="NumberRecruited" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="MemberNames" class="form-label fw-bold">
                    Board Member Names <small class="text-muted">(Optional, Separate multiple names with commas.)</small>
                </label>
                <textarea asp-for="MemberNames" class="form-control" rows="3"></textarea>
                <span asp-validation-for="MemberNames" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="RecordHistory" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

<style>
    .form-label {
        color: var(--onejax-navy);
    }

    .form-control:focus,
    .form-select:focus {
        border-color: var(--onejax-navy);
        box-shadow: 0 0 0 0.2rem rgba(0, 123, 191, 0.25);
    }

    .btn-primary {
        background-color: var(--onejax-navy);
        border-color: var(--onejax-navy);
    }

    .btn-primary:hover {
        background-color: #1a365d;
        border-color: #1a365d;
    }
</style>
