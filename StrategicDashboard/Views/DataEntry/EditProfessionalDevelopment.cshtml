@model OneJaxDashboard.Models.ProfessionalDevelopment
@{
    ViewData["Title"] = "Edit Professional Development";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var monthNames = new[]
    {
        "January", "February", "March", "April", "May", "June",
        "July", "August", "September", "October", "November", "December"
    };
}

<h1 class="headline mb-4" style="color:var(--onejax-navy);">Edit Professional Development</h1>

<div class="container mt-4">
    <div class="card p-4"
        style="background-color:var(--onejax-white); 
               box-shadow:0 4px 24px rgba(0,0,0,0.08); 
               border-radius:24px; 
               max-width:800px;">

        <form asp-action="EditProfessionalDevelopment" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedDate" />

            <div class="mb-3">
                <label asp-for="Year" class="form-label fw-bold">Year</label>
                <input asp-for="Year" type="number" class="form-control" min="2020" max="2100" />
                <span asp-validation-for="Year" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-bold">Staff Member Name</label>
                <select asp-for="Name" class="form-select" asp-items="ViewBag.StaffMembers">
                    <option value="">-- Select a Staff Member --</option>
                </select>
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Month" class="form-label fw-bold">Month</label>
                <select asp-for="Month" class="form-select">
                    <option value="">-- Select Month --</option>
                    @foreach (var month in monthNames)
                    {
                        <option value="@month" selected="@(Model.Month == month ? "selected" : null)">@month</option>
                    }
                </select>
                <span asp-validation-for="Month" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Activities" class="form-label fw-bold">Professional Development Activities</label>
                <textarea asp-for="Activities" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Activities" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="RecordHistory" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

<style>
    .form-label {
        color: var(--onejax-navy);
    }

    .form-control:focus {
        border-color: var(--onejax-navy);
        box-shadow: 0 0 0 0.2rem rgba(0, 123, 191, 0.25);
    }

    .btn-primary {
        background-color: var(--onejax-navy);
        border-color: var(--onejax-navy);
    }

    .btn-primary:hover {
        background-color: #1a365d;
        border-color: #1a365d;
    }
</style>
