@model OneJaxDashboard.Models.Programs
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var successMessage = TempData["ProgramsSuccess"] as string;
    var errorMessage = TempData["ProgramsError"] as string;
    var programTypes = ViewBag.ProgramTypes as string[] ?? Array.Empty<string>();
}

<style>
    :root {
        --onejax-blue: #0070AD;
        --onejax-teal: #00A3AD;
        --onejax-navy: #102840;
        --onejax-light: #F7F9FB;
    }

    body {
        background-color: var(--onejax-light);
        color: var(--onejax-navy);
    }

    .card-soft {
        background: #fff;
        border: none;
        border-radius: 18px;
        box-shadow: 0 6px 18px rgba(16, 40, 64, 0.08);
    }

    .pill-btn {
        border-radius: 999px;
        font-weight: 600;
    }

    .btn-onejax {
        background-color: var(--onejax-blue);
        border-color: var(--onejax-blue);
        color: #fff;
    }

    .btn-onejax:hover {
        background-color: var(--onejax-teal);
        border-color: var(--onejax-teal);
        color: #fff;
    }
</style>

<div class="container my-5">
    <div class="text-center mb-4">
        <h1 class="fw-bold text-uppercase" style="color: var(--onejax-blue);">Edit Program</h1>
        <p class="text-secondary fs-5">Update program details.</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="alert alert-success text-center">@successMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger text-center">@errorMessage</div>
    }

    <div class="card-soft p-4">
        <form asp-action="Edit" asp-controller="Programs" method="post" class="row g-3">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />

            <div class="col-md-6">
                <label class="form-label fw-semibold">Program Name</label>
                <input type="text" name="programName" class="form-control" value="@Model.ProgramName" required />
            </div>

            <div class="col-md-6">
                <label class="form-label fw-semibold">Program Type</label>
                <select name="programType" class="form-select" required>
                    <option value="" disabled>Select program type</option> 
                    @foreach (var type in programTypes)
                    {
                        if (Model.ProgramType == type)
                        {
                            <option value="@type" selected>@type</option>
                        }
                        else
                        {
                            <option value="@type">@type</option>
                        }
                    }
                </select>
            </div>

            <div class="col-12">
                <label class="form-label fw-semibold">Description</label>
                <textarea name="description" class="form-control" rows="3">@Model.Description</textarea>
            </div>

            <div class="col-12 d-flex gap-2">
                <button type="submit" class="btn btn-onejax pill-btn px-4">Save Changes</button>
                <a asp-action="Index" asp-controller="Programs" class="btn btn-outline-secondary pill-btn px-4">Back</a>
            </div>
        </form>
    </div>
</div>
