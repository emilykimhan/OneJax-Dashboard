@model OneJaxDashboard.Models.ContactsInterfaith_14D
@{
    ViewData["Title"] = "Clergy & Interfaith Network Contacts";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <div class="card p-4"
                 style="background-color:var(--onejax-white);
                        box-shadow:0 4px 24px rgba(0,0,0,0.08);
                        border-radius:24px;">

                <!-- Header -->
                <div class="d-flex align-items-center mb-4">
                    <a href="/CommunityEngagement"
                       class="btn btn-outline-secondary me-3"
                       style="border-radius:8px;">
                        ← Back
                    </a>
                    <h2 class="mb-0" style="color:var(--onejax-navy);">Clergy & Interfaith Network Contacts</h2>
                </div>

                <p class="text-center mb-4" style="color:var(--onejax-gray);">
                    Track interfaith contacts — Goal: Expand clergy and interfaith network contacts by 25% by end of FY 25-26.
                </p>

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success text-center" style="border-radius:12px;">
                        @TempData["Success"]
                    </div>

                    @if (ViewBag.ShowNewEntryButton == true)
                    {
                        <div class="text-center mb-4">
                            <a href="/CommContact14D/Index" class="btn btn-primary btn-lg"
                               style="background-color:var(--onejax-navy); border-color:var(--onejax-navy); border-radius:12px;">
                                Add New Entry
                            </a>
                        </div>
                    }
                }

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger text-center" style="border-radius:12px;">
                        @TempData["Error"]
                    </div>
                }

                <!-- Entry Form -->
                @if (ViewBag.ShowNewEntryButton != true)
                {
                    <div class="survey-form">
                        <h4 class="mb-4 text-center" style="color:var(--onejax-navy);">New Contact Entry</h4>

                        <form asp-controller="CommContact14D" asp-action="Index" method="post" novalidate>
                            @Html.AntiForgeryToken()

                            <div class="row justify-content-center">
                                <!-- Year -->
                                <div class="col-md-5 mb-3">
                                    <label asp-for="Year" class="form-label fw-bold">Year</label>
                                    <input asp-for="Year" type="number" class="form-control"
                                           placeholder="e.g. 2026" min="2020" max="2100" required />
                                    <span asp-validation-for="Year" class="text-danger"></span>
                                </div>

                                <!-- Month -->
                                <div class="col-md-5 mb-3">
                                    <label asp-for="Month" class="form-label fw-bold">Month</label>
                                    <select asp-for="Month" class="form-select" required>
                                        <option value="">-- Select Month --</option>
                                        <option value="1">January</option>
                                        <option value="2">February</option>
                                        <option value="3">March</option>
                                        <option value="4">April</option>
                                        <option value="5">May</option>
                                        <option value="6">June</option>
                                        <option value="7">July</option>
                                        <option value="8">August</option>
                                        <option value="9">September</option>
                                        <option value="10">October</option>
                                        <option value="11">November</option>
                                        <option value="12">December</option>
                                    </select>
                                    <span asp-validation-for="Month" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="row justify-content-center">
                                <!-- Total Interfaith Contacts -->
                                <div class="col-md-5 mb-3">
                                    <label asp-for="TotalInterfaithContacts" class="form-label fw-bold">Total Interfaith Contacts</label>
                                    <input asp-for="TotalInterfaithContacts" type="number" class="form-control"
                                           placeholder="e.g. 120" min="0" max="100000" required />
                                    <span asp-validation-for="TotalInterfaithContacts" class="text-danger"></span>
                                    <small class="form-text text-muted">Total clergy and interfaith network contacts for this year</small>
                                </div>
                            </div>

                            <!-- Submit -->
                            <div class="text-center mt-4">
                                <button type="submit" class="btn btn-primary btn-lg px-5 py-3"
                                        style="background-color:var(--onejax-navy); border-color:var(--onejax-navy); border-radius:12px; font-weight:600;">
                                    Submit Record
                                </button>
                            </div>
                        </form>
                    </div>
                }

            </div>
        </div>
    </div>
</div>

<style>
    .survey-form {
        padding: 1.5rem;
        background: #f8f9fa;
        border-radius: 12px;
        margin-top: 1rem;
    }

    .form-label {
        color: var(--onejax-navy);
        margin-bottom: 0.4rem;
    }

    .form-control:focus {
        border-color: var(--onejax-navy);
        box-shadow: 0 0 0 0.2rem rgba(0, 123, 191, 0.25);
    }

    .card { border: none; }

    .text-danger {
        font-size: 0.875rem;
        margin-top: 0.25rem;
        display: block;
    }

    .btn-outline-secondary {
        border-color: var(--onejax-navy);
        color: var(--onejax-navy);
    }

    .btn-outline-secondary:hover {
        background-color: var(--onejax-navy);
        border-color: var(--onejax-navy);
        color: white;
    }

    input[type="number"]::-webkit-inner-spin-button,
    input[type="number"]::-webkit-outer-spin-button {
        opacity: 1;
    }
</style>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
